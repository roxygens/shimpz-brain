{
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["message", "power"]
    },
    "message": {
      "type": "string",
      "maxLength": 32000
    },
    "power": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^$|^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "input": {
      "type": "string",
      "maxLength": 16384
    }
  },
  "required": ["kind", "message", "power", "input"],
  "additionalProperties": false
}
