#!/usr/bin/env bash
# html2pdf-chrome <input.html|url> [output.pdf]
#   HTML/URL -> PDF via a SEPARATE headless Chrome. Use ONLY when you need live JavaScript
#   (Chart.js/D3/Mermaid rendered in-browser) or CSS WeasyPrint lacks (box-shadow, 3D).
#   NOTE: the headful Chrome on :9222 cannot print (printToPDF is headless-only) — this
#   spawns its own throwaway headless instance and waits for fonts/JS via virtual-time.
#   For normal documents prefer md2pdf / html2pdf (deterministic, never blank).
set -euo pipefail
in="${1:?usage: html2pdf-chrome <input.html|url> [output.pdf]}"
case "$in" in
    http://*|https://*|file://*) url="$in"; base="page" ;;
    *) [ -f "$in" ] || { echo "ERROR: not found: $in" >&2; exit 1; }
       url="file://$(readlink -f "$in")"; base="${in%.*}" ;;
esac
out="${2:-${base}.pdf}"

google-chrome-stable --headless=new --no-sandbox --disable-gpu --disable-dev-shm-usage \
    --no-pdf-header-footer --virtual-time-budget=15000 \
    --run-all-compositor-stages-before-draw \
    --print-to-pdf="$out" "$url" >/dev/null 2>&1

chars="$(pdftotext "$out" - 2>/dev/null | tr -d '[:space:]' | wc -c)"
if [ "${chars:-0}" -lt 20 ]; then
    echo "WARN: $out looks BLANK — increase --virtual-time-budget or check the JS." >&2
fi
echo "$out"
