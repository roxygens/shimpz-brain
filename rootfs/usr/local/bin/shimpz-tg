#!/opt/venv/bin/python
"""shimpz-tg — Shimpz's OUTBOUND Telegram channel (used by the brain to reach Juliano).

Talks straight to the Bot API (it has the token), independent of the gateway's poll.

Usage:
  shimpz-tg notify "text"                  # send a message to the owner
  shimpz-tg send <file> ["caption"]        # send a file (auto: photo/voice/audio/document)
  shimpz-tg desktop ["text"]               # send a button that opens the live desktop (KasmVNC)
                                        #   on the phone — for solving a CAPTCHA / taking over
"""

import json
import os
import sys
from pathlib import Path

SHIMPZ_HOME = os.environ.get("SHIMPZ_HOME", "/config/.shimpz")
DESKTOP_URL = os.environ.get("SHIMPZ_DESKTOP_URL", "https://agents.zyon.network")

sys.path.insert(0, "/opt/shimpz-lib")
import shimpzenv

shimpzenv.load(SHIMPZ_HOME)  # single source of truth for $SHIMPZ_HOME/.env (see /opt/shimpz-lib/shimpzenv.py)

TOKEN = os.environ.get("TELEGRAM_BOT_TOKEN", "").strip()
OWNER = next(
    (x for x in os.environ.get("TELEGRAM_ALLOWED_USERS", "").replace(" ", "").split(",") if x.strip().isdigit()),
    "",
)
API = f"https://api.telegram.org/bot{TOKEN}"

# --- pt/en language switch for the two static human-facing strings this file authors — same pattern
# as shimpz-gateway's SHIMPZ_UI_LANG (see that file for the full rationale). English is the untouched coded
# default (byte-identical to what shipped before this switch existed).
SHIMPZ_UI_LANG = os.environ.get("SHIMPZ_UI_LANG", "en")
_UI_EN = {
    "desktop_default": "🖥️ Open the live desktop (solve CAPTCHA / take control):",
    "btn_open_desktop": "🖥️ Open desktop",
}
_UI_PT = {
    "desktop_default": "🖥️ Abra o desktop ao vivo (resolva CAPTCHA / assuma o controle):",
    "btn_open_desktop": "🖥️ Abrir desktop",
}


def _t(key):
    return (_UI_PT if SHIMPZ_UI_LANG == "pt" else _UI_EN)[key]


DESKTOP_DEFAULT = _t("desktop_default")


def _method_field(ext):
    """Bot API method + multipart field for a file extension.

    PURE — this is the exact routing that decides 'photo vs voice vs audio vs document', the tool's
    central 'don't send the wrong type' guarantee, so it's unit-tested for real without a network call.
    """
    if ext in (".jpg", ".jpeg", ".png", ".webp"):
        return "sendPhoto", "photo"
    if ext in (".ogg", ".oga", ".opus"):
        return "sendVoice", "voice"
    if ext in (".mp3", ".m4a", ".wav"):
        return "sendAudio", "audio"
    return "sendDocument", "document"


def plan(cmd, args):
    """Resolve (cmd, args) into the exact Telegram call it WILL make, WITHOUT sending.

    Returns a dict with `method`, `data` (the POST body incl. chat_id=OWNER), and — for `send` —
    `file_path`/`file_field`. PURE + no network → the dispatch, extension routing, owner targeting
    and payload shape are all
    validated for real; main() executes the plan (opens the file, POSTs). Exits 2 on an unknown
    command (unchanged). `send` with no file arg raises IndexError, exactly as before.
    """
    match cmd:
        case "notify":
            return {
                "method": "sendMessage",
                "data": {"chat_id": OWNER, "text": args[0] if args else ""},
            }
        case "send":
            path = args[0]
            caption = args[1] if len(args) > 1 else ""
            method, field = _method_field(Path(path).suffix.lower())
            return {
                "method": method,
                "data": {"chat_id": OWNER, "caption": caption[:1024]},
                "file_path": path,
                "file_field": field,
            }
        case "desktop":
            kb = {"inline_keyboard": [[{"text": _t("btn_open_desktop"), "url": DESKTOP_URL}]]}
            return {
                "method": "sendMessage",
                "data": {
                    "chat_id": OWNER,
                    "text": args[0] if args else DESKTOP_DEFAULT,
                    "reply_markup": json.dumps(kb),
                },
            }
        case _:
            print(f"unknown command: {cmd}", file=sys.stderr)
            sys.exit(2)


def _post(method, data=None, files=None):
    if not TOKEN or not OWNER:
        print(
            "ERROR: TELEGRAM_BOT_TOKEN or TELEGRAM_ALLOWED_USERS missing",
            file=sys.stderr,
        )
        sys.exit(1)
    # Imported HERE, at the only network boundary: the pure plan() / config-error paths need no
    # third-party dep, so they run (and are tested) on any interpreter without `requests` installed.
    import requests

    r = requests.post(f"{API}/{method}", data=data or {}, files=files, timeout=60)
    if not r.ok:
        print(f"ERROR Telegram {r.status_code}: {r.text[:200]}", file=sys.stderr)
        sys.exit(1)
    return r.json()


def _execute(spec):
    """Send a plan()'d call. The only place the real network is touched (the HITL surface)."""
    fp = spec.get("file_path")
    if fp is None:
        _post(spec["method"], spec["data"])
    else:
        p = Path(fp)
        if not p.exists():
            print(f"ERROR: file does not exist: {fp}", file=sys.stderr)
            sys.exit(1)
        with p.open("rb") as f:
            _post(spec["method"], spec["data"], files={spec["file_field"]: f})
    print("ok")


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(2)
    _execute(plan(sys.argv[1], sys.argv[2:]))


if __name__ == "__main__":
    main()
