#!/opt/venv/bin/python
"""shimpz-depaudit — dependency-vulnerability gate for shimpz-publish (item 2).

Surfaces ONLY ACTIONABLE security vulns — ones with a FIX available — and prints the exact upgrade, so
the AGENT fixes them and re-publishes (NOT a shimpz-approve decision, and NOT cosmetic noise). The rule:
report a vuln only when (a) it is security-relevant and (b) it has a fix version you can actually act
on. An unfixable or low advisory is not worth stopping a publish over (otherwise the gate turns into
needless cosmetic noise).

Two ecosystems, audited where their manifest lives:
  • Python backend (pyproject.toml) — `uv export` → `pip-audit --format json`. pip-audit reports a vuln
    by id + its fix_versions; severity isn't reliably present, so the ACTIONABLE signal is "has a fix"
    (fixable = you bump the pin). Unfixable advisories are counted but not blocked.
  • pnpm frontend (package.json) — `pnpm audit --json`. ACTIONABLE = severity high|critical AND a
    patched version exists.

FAIL-OPEN but NEVER SILENT (the fail-fast contract): a tool error OR unparseable tool output makes
main() exit 0 — a hiccup or an upstream format change must NOT wedge a publish while Juliano is driving
(dep-audit is defense-in-depth; the JUDGMENT gate is shimpz-secaudit) — BUT every such error is written to
stderr, never swallowed. The parse layer itself is fail-LOUD: parse_pip_audit/parse_pnpm_audit RAISE on
an unrecognized shape (so a format drift can't masquerade as data); the integrated audit_* CATCHES that
raise and turns it into a SURFACED error string rather than a silent "clean". A missing tool / absent
manifest is likewise "nothing to audit here" (exit 0, reported). The ONLY thing that blocks is a
CONFIRMED actionable vuln → exit 3 → shimpz-publish ABORTS with the fix.

Exit: 0 clean / nothing to audit / tool-error (each surfaced to stderr) · 3 actionable vulns (printed
with fixes) · 1 usage or bad-dir. Usage: shimpz-depaudit <project-or-app-dir> [--json]
"""

import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzaudit  # shared owner-notification (kill-switch/fail-open visibility, R89)

SECURE_SEVERITIES = {"high", "critical"}
TIMEOUT = int(os.environ.get("SHIMPZ_DEPAUDIT_TIMEOUT", "180"))


# ── PURE parsers + filter (unit-tested in tests/test-shimpz-depaudit.py; no network) ───────────────
def parse_pip_audit(text):
    """pip-audit --format=json → (actionable, skipped_unfixable).

    Accepts the wrapped {'dependencies':[...]} (pip-audit ≥2) and a bare [...] list (older).
    Actionable = a vuln WITH a fix_version. Raises ValueError on an unrecognized shape (fail-loud —
    never a silent empty).
    """
    data = json.loads(text)  # JSONDecodeError → caller maps to ERROR
    deps = data.get("dependencies") if isinstance(data, dict) else data
    if not isinstance(deps, list):
        raise ValueError("pip-audit json: expected a 'dependencies' list")
    actionable, skipped = [], 0
    for d in deps:
        name, ver = d.get("name"), d.get("version")
        for v in d.get("vulns") or []:
            fixes = v.get("fix_versions") or []
            vid = v.get("id") or (v.get("aliases") or [None])[0]
            if fixes:
                actionable.append(
                    {
                        "eco": "pip",
                        "name": name,
                        "version": ver,
                        "id": vid,
                        "fix": fixes[0],
                    }
                )
            else:
                skipped += 1
    return actionable, skipped


def parse_pnpm_audit(text):
    """Pnpm audit --json → (actionable, skipped).

    pnpm emits the npm-v6 shape:
    {'advisories': {id: {module_name, severity, patched_versions, ...}}, 'metadata': {...}}. Actionable =
    severity in {high,critical} AND a real patched version exists (not the '<0.0.0' = no-fix sentinel).
    Raises ValueError if neither the 'advisories' nor a recognized alternative shape is present.
    """
    data = json.loads(text)
    if not isinstance(data, dict):
        raise ValueError("pnpm audit json: expected an object")
    advisories = data.get("advisories")
    if advisories is None:
        # tolerate an empty clean run that omits 'advisories' but DOES carry metadata; anything else is
        # an unrecognized shape and must fail loud rather than pass as clean.
        if "metadata" in data or data == {}:
            return [], 0
        raise ValueError("pnpm audit json: no 'advisories' key (unrecognized format)")
    actionable, skipped = [], 0
    for a in advisories.values():
        sev = str(a.get("severity", "")).lower()
        patched = (a.get("patched_versions") or "").strip()
        has_fix = bool(patched) and patched not in ("<0.0.0", "<0.0.0 ")
        if sev in SECURE_SEVERITIES and has_fix:
            actionable.append(
                {
                    "eco": "npm",
                    "name": a.get("module_name"),
                    "severity": sev,
                    "patched": patched,
                    "id": a.get("github_advisory_id") or a.get("id"),
                    "title": a.get("title"),
                }
            )
        else:
            skipped += 1
    return actionable, skipped


# A requirements line that is NOT a published PyPI package: an editable install, a local path, or a
# PEP 508 / bare direct-URL reference. pip-audit checks names+versions against PyPI advisories, so it
# resolve-installs the requirements first — and DIES on these forms (a local `./vendor/shimpzbus` has no
# index entry). That death produced no JSON, which fail-open mapped to INCOMPLETE, silently disabling
# the WHOLE backend audit for every R110 shimpzbus-vendoring project. We strip them so the audit runs.
_LOCAL_REQ = re.compile(
    r"""^(
        -e\b | --editable\b            # editable install
        | \.{0,2}/                     # ./  ../  or /abs  local path
        | [A-Za-z0-9._-]+\s*@\s        # PEP 508 direct reference:  name @ <url|file|git+…>
        | [A-Za-z][A-Za-z0-9+.-]*://   # bare URL / VCS requirement  (https://, file://, git+https://)
    )""",
    re.VERBOSE,
)


def pypi_only(req_text):
    """requirements.txt text → only the lines pip-audit can check against PyPI advisories.

    Drops local/vendored/direct-URL requirements (see _LOCAL_REQ); keeps real pinned deps plus
    comments and blank lines (pip-audit ignores those). Pure + fully unit-tested — no network.
    """
    kept = [
        line
        for line in req_text.splitlines()
        if not ((s := line.strip()) and not s.startswith("#") and _LOCAL_REQ.match(s))
    ]
    return "\n".join(kept) + "\n"


def fix_command(f):
    """The exact command the agent runs to fix one finding."""
    if f["eco"] == "pip":
        return "cd backend && uv add '{}>={}'".format(f["name"], f["fix"])
    return "cd frontend && pnpm update '{}'  # to a version satisfying {}".format(f["name"], f.get("patched", ""))


def format_report(findings, skipped):
    lines = [f"🔒 DEPENDENCY AUDIT — {len(findings)} actionable security vuln(s) with a fix available:"]
    for f in findings:
        tag = ("{} {}".format(f.get("severity", "").upper(), f.get("id") or "")).strip()
        lines.append(
            "  • {} {}@{}  [{}]\n      fix: {}".format(
                f["eco"],
                f.get("name"),
                f.get("version", f.get("patched", "?")),
                tag,
                fix_command(f),
            )
        )
    if skipped:
        lines.append(f"  ({skipped} advisory/-ies skipped: low severity or no fix available — not blocking)")
    return "\n".join(lines)


# ── toolchain layer (real CLIs — exercised LIVE in tests/test-shimpz-depaudit-live.py, never mocked) ──
def _find_manifest(root, fname, sub):
    """Locate a manifest: <root>/<fname>, <root>/<sub>/<fname>, or the given dir if it IS that subtree.

    Returns the directory containing the manifest, or None.
    """
    for d in (Path(root), Path(root) / sub):
        if (d / fname).is_file():
            return d
    return None


def _exec_tmp(base):
    """An EXEC-capable temp dir + an env that points TMPDIR at it.

    The container mounts /tmp `noexec`, so a tool that builds an ephemeral venv there (uvx pip-audit)
    dies with a noexec error; a temp dir INSIDE the project tree shares the project's exec-ok mount.
    Returns (dir, env). Caller rmtree's dir.
    """
    work = tempfile.mkdtemp(prefix=".depaudit-", dir=base)
    return work, {**os.environ, "TMPDIR": work}


def _audit(root, fname, sub, tool, label, cmds, parser, runner, prep=None):
    """The shared per-ecosystem scaffold: manifest → tool chain in an exec-capable temp dir → parse.

    `cmds(work)` returns the command lists to run in order: every command but the last must exit 0
    (a setup step like `uv export`); the last is the audit tool itself, which exits NON-ZERO when it
    finds vulns — that's data, not an error (the JSON is on stdout; a real failure prints to stderr
    with no JSON → parse raises → surfaced error). An optional `prep(work)` runs AFTER the setup
    commands and BEFORE the audit tool — the seam where python filters the exported requirements down
    to real PyPI deps. `tool`/`label` name the audit in error strings.
    Returns (actionable, skipped, error|None). A missing manifest or a missing tool is ([], 0, None)
    or a surfaced not-audited note — never a crash, never a silent clean.
    """
    d = _find_manifest(root, fname, sub)
    if not d:
        return [], 0, None
    work = None
    try:
        work, aenv = _exec_tmp(d)
        *setup, final = cmds(work)
        for cmd in setup:
            r = runner(cmd, cwd=d, capture_output=True, text=True, timeout=TIMEOUT, env=aenv)
            if r.returncode != 0:
                return [], 0, "{} {} failed: {}".format(cmd[0], cmd[1], (r.stderr or "")[-200:])
        if prep:
            prep(work)
        r = runner(final, cwd=d, capture_output=True, text=True, timeout=TIMEOUT, env=aenv)
        if not (r.stdout or "").strip():
            return [], 0, "{} produced no output: {}".format(tool, (r.stderr or "")[-200:])
        actionable, skipped = parser(r.stdout)
    except FileNotFoundError as e:
        return [], 0, f"tool not found ({e}) — {sub} deps not audited"
    except (OSError, subprocess.SubprocessError, json.JSONDecodeError, ValueError) as e:
        return [], 0, f"{label} audit error: {e!r}"
    else:
        return actionable, skipped, None
    finally:
        if work:
            shutil.rmtree(work, ignore_errors=True)


def audit_python(root, runner=subprocess.run):
    """Uv export → strip local/vendored deps → pip-audit the real PyPI deps.

    `--no-hashes`: pip-audit doesn't need hashes to check advisories, and dropping them avoids pip's
    require-hashes mode (which rejects the whole file the moment one line — the vendored local dep —
    lacks a hash). Then `prep` filters the export down to PyPI-resolvable lines. Returns
    (actionable, skipped, error|None).
    """

    def cmds(work):
        full = str(Path(work) / "requirements.full.txt")
        req = str(Path(work) / "requirements.txt")
        return [
            [
                "uv",
                "export",
                "--no-dev",
                "--no-emit-project",
                "--no-hashes",
                "--format",
                "requirements-txt",
                "-o",
                full,
            ],
            ["uvx", "pip-audit", "--format", "json", "-r", req],
        ]

    def prep(work):
        full = (Path(work) / "requirements.full.txt").read_text(encoding="utf-8")
        (Path(work) / "requirements.txt").write_text(pypi_only(full), encoding="utf-8")

    return _audit(root, "pyproject.toml", "backend", "pip-audit", "python", cmds, parse_pip_audit, runner, prep=prep)


def audit_node(root, runner=subprocess.run):
    """Pnpm audit --json in the frontend. Returns (actionable, skipped, error|None)."""
    return _audit(
        root,
        "package.json",
        "frontend",
        "pnpm audit",
        "node",
        lambda _work: [["pnpm", "audit", "--json"]],
        parse_pnpm_audit,
        runner,
    )


def run(root, runner=subprocess.run):
    """Audit both ecosystems. Returns (findings, skipped, errors[])."""
    findings, skipped, errors = [], 0, []
    for fn in (audit_python, audit_node):
        a, s, err = fn(root, runner=runner)
        findings += a
        skipped += s
        if err:
            errors.append(err)
    return findings, skipped, errors


def main(argv):
    target, as_json = shimpzaudit.cli_arg(argv, "usage: shimpz-depaudit <project-or-app-dir> [--json]")
    if target is None:
        return 64
    root = os.path.abspath(target)  # noqa: PTH100 — must NOT resolve symlinks
    if not Path(root).is_dir():
        sys.stderr.write(f"shimpz-depaudit: not a directory: {root}\n")
        return 1
    if shimpzaudit.kill_switch("SHIMPZ_DEPAUDIT", root, "dependency audit"):
        return 0
    findings, skipped, errors = run(root)
    # surface every tool error LOUDLY (fail-open: an infra hiccup must not block a publish, but is never
    # swallowed — the user must SEE that the audit was incomplete, and so must the OWNER: the /tmp-noexec
    # incident ran this audit as a permanent false-clean until a live test caught it).
    for e in errors:
        sys.stderr.write(f"shimpz-depaudit: {e}\n")
    if errors and not findings:
        shimpzaudit.notify_owner(
            "⚠️ dependency audit INCOMPLETE for {} (fail-open): {}".format(root, "; ".join(errors)[:300])
        )
    if as_json:
        print(json.dumps({"findings": findings, "skipped": skipped, "errors": errors}))
    elif findings:
        print(format_report(findings, skipped))
    elif not errors:
        print(
            f"✅ dependency audit clean ({skipped} non-actionable advisory/-ies skipped)"
            if skipped
            else "✅ dependency audit clean"
        )
    if findings:
        return 3  # actionable vulns → shimpz-publish ABORTS with fixes
    return 0  # clean, or only errors (fail-open: surfaced, not blocking)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
