#!/usr/bin/env bash
# shimpz-unpublish <fqdn> — the inverse of shimpz-publish: fully remove a published domain from the air.
# Removes the tunnel ingress rule + proxied DNS record(s) + Caddy route + any Cloudflare Access app.
# Does NOT touch the supervised app or its database — tear those down with `shimpz-app rm <name>` and
# `shimpz-db drop <name>`.
#
# SECURITY_ENGINEERING_PLAN.md item 3: goes through cf-driver (cfdriver.sh) instead of the old
# permissive `cf` helper — `shimpz-brain` never holds SHIMPZ_CF_TOKEN. Zone resolution, tunnel-ingress
# read-modify-write, and DNS record lookup all happen SERVER-SIDE now; this script just calls the
# named operations and reports what happened.
set -uo pipefail
. "${SHIMPZ_LIB:-/opt/shimpz-lib}/shimpzdetect.sh"
. "${SHIMPZ_LIB:-/opt/shimpz-lib}/cfdriver.sh"
fqdn="${1:?usage: shimpz-unpublish <fqdn>}"
echo "▶ shimpz-unpublish $fqdn"

# 1) tunnel ingress — tolerant of failure (e.g. no active tunnel): DNS/route/Access below are
#    independent safe deletes, matching the original script's own tolerance for a partial teardown.
if out=$(_cfdriver_ingress_delete "$fqdn" 2>&1); then
  [ "$(echo "$out" | jq -r '.removed')" = true ] && echo "  OK ingress rule removed"
else
  echo "  WARN ingress removal failed (continuing — DNS/route/Access below are independent): $out" >&2
fi

# 2) DNS record(s) — CNAME is the only type shimpz-publish ever creates, but A/AAAA are checked too
#    in case a domain was pointed here manually before Shimpz took it over.
for t in CNAME A AAAA; do
  out=$(_cfdriver_dns_delete "$fqdn" "$t" 2>&1) || continue
  [ "$(echo "$out" | jq -r '.deleted')" -gt 0 ] 2>/dev/null && echo "  OK DNS $t removed"
done

# 3) Caddy route
shimpz-route del "$fqdn" >/dev/null 2>&1 && echo "  OK Caddy route removed"

# 4) Access app(s)
if out=$(_cfdriver_access_public "$fqdn" 2>&1); then
  count=$(echo "$out" | jq -r '.removed | length')
  [ "$count" -gt 0 ] 2>/dev/null && echo "  OK Access app removed"
fi

echo "$fqdn unpublished. (app + database untouched — shimpz-app rm / shimpz-db drop to remove those.)"
