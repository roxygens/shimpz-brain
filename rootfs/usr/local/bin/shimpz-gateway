# --- pt/en language switch for the static UI strings a human reads (buttons, cards, status ticker,
# error notices) — mirrors scripts/battle-test-gate.py's BATTLE_GATE_LANG. English is the untouched
# coded default (every _UI_EN value below is byte-identical to what shipped before this switch existed,
# so SHIMPZ_UI_LANG unset changes nothing observable); Portuguese is additive. Shimpz's own free-form
# conversational replies already mirror Juliano's language dynamically (CLAUDE.md/shimpzprompt.py) — this
# is a SEPARATE, narrower switch for the fixed strings the CODE authors, not the LLM.
# EXCEPTION: the /login flow (login_*) was ALREADY hardcoded in Portuguese before this switch existed —
# an inconsistency in an otherwise-English file. For those keys ONLY, _UI_PT is the existing/unchanged
# text (verbatim) and _UI_EN is newly authored (a natural translation) — the one place SHIMPZ_UI_LANG
# unset legitimately changes observable behavior (PT → EN), by explicit owner directive.
#
# R99: SHIMPZ_UI_LANG is the process-wide DEFAULT, set once at container boot. On top of it, a chat can
# flip its OWN language live with /lang (LANG_PREF: chat_id -> "pt"/"en"; R106: persisted in
# $SHIMPZ_HOME/prefs.json and seeded from Telegram's user.language_code — see _seed_lang). _t() takes an
# optional chat_id: given one, the chat's own LANG_PREF choice wins, falling back to SHIMPZ_UI_LANG when
# that chat never chose; omitted, _t() uses the global SHIMPZ_UI_LANG only — for call sites with no chat
# in scope. The `/` command menu is layered separately (_bot_commands/_set_chat_commands): a global
# SHIMPZ_UI_LANG default + per-client-locale variants + a BotCommandScopeChat pin per explicit choice.
SHIMPZ_UI_LANG = os.environ.get("SHIMPZ_UI_LANG", "en")

import shimpzi18n

# The pt/en string dicts moved to the shimpzi18n leaf (Phase D1) so shimpzchat.py can render text too.
# Re-export the aliases (immutable dicts — safe to alias) so the gateway's _bot_commands + the suite
# keep referencing _UI_EN/_UI_PT unchanged. _t below becomes a thin wrapper over the leaf.
_UI_EN = shimpzi18n._UI_EN
_UI_PT = shimpzi18n._UI_PT


def _lang_for(chat_id):
    """The active language for ONE chat: its own /lang choice (LANG_PREF) if it ever ran /lang, else SHIMPZ_UI_LANG."""
    return LANG_PREF.get(chat_id, SHIMPZ_UI_LANG)


def _t(key, *args, chat_id=None):
    """The active-language string for `key`, `.format(*args)`'d if any were given.

    Pass `chat_id` to honor THAT chat's own /lang choice (falling back to SHIMPZ_UI_LANG when it never
    ran /lang). Omitted (the default), the global SHIMPZ_UI_LANG decides — for call sites with no chat
    in scope. (BotCommand descriptions don't use _t() at all: _bot_commands renders them per
    explicit language for the global/per-locale/per-chat menus.)
    """
    lang = _lang_for(chat_id) if chat_id is not None else SHIMPZ_UI_LANG
    return shimpzi18n.t(key, *args, lang=lang)


