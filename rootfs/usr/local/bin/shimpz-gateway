}
OWNER = next(iter(ALLOWED), None)
# LANG_PREF/SPEAK_PREF/etc are all keyed by the STRING chat_id (str(update.effective_chat.id)) — OWNER
# itself is an int (from ALLOWED). Keep a string form so passing chat_id=OWNER_CID into _t()/_lang_for()
# actually matches the key OWNER's own /lang tap would have written (an int/str key mismatch would
# silently miss OWNER's preference and fall back to SHIMPZ_UI_LANG every time — a real, silent bug).
OWNER_CID = str(OWNER)
# SECURITY_ENGINEERING_PLAN.md item 7: the gateway no longer holds the OpenAI key. Voice availability
# is now "is the openai-driver sidecar wired?" (its token readable) instead of "is OPENAI_KEY set".
STT_MODEL = "gpt-4o-transcribe"
