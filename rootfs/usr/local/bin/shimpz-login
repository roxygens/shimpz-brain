#!/opt/venv/bin/python
"""shimpz-login — Telegram-driven Claude Code login bridge.

When Shimpz's brain (`claude -p`) is logged out, the gateway can't authenticate it from the phone any other
way: the real login is an interactive OAuth flow that prints a URL and then BLOCKS reading the
authorization code from a terminal. This bridges that flow over files so the Telegram gateway can run it:

  shimpz-login run      ── spawns `claude auth login --claudeai` under a (WIDE) pty, extracts the OAuth URL
                        and writes it to $SHIMPZ_LOGIN_DIR/url, then WAITS for $SHIMPZ_LOGIN_DIR/code, types it
                        into the pty, waits for the CLI to finish, and writes $SHIMPZ_LOGIN_DIR/result
                        ({"ok":bool,"code":str,"args":list,"message":str} — code/args let the gateway
                        render the outcome in the chat's language; message is the human/English form).
                        Long-running; the gateway launches it DETACHED (start_new_session) so it
                        survives a gateway restart while holding the PKCE state.
  shimpz-login submit <code>
                     ── validate the code (charset ^[A-Za-z0-9._~=/+-]{1,4096}$, no whitespace) then
                        atomically write it to $SHIMPZ_LOGIN_DIR/code (the live `run` picks it up). exit 0
                        on write, 2 on a malformed code. Lets the driver hand a code straight in
                        as an argv element — never a shell string — instead of interpolating a file write.
  shimpz-login status   ── prints `claude auth status` (loggedIn + email); exit 0 if logged in, else 1.
                        `status --json` prints {"loggedIn":bool,"email":str|null} for the gateway.

Why a wide pty: the CLI hard-wraps the URL at the terminal width; a 4000-col pty keeps it on ONE line so
it extracts cleanly. Why a pty at all: with a plain pipe the CLI detects no tty and never prints the URL.

The flow is single-use and the PKCE code_verifier lives ONLY inside the live `claude` child, so it cannot
be recovered if `run` dies — a crash/restart just means the user runs /login again. A hard timeout
(SHIMPZ_LOGIN_TIMEOUT, default 600s) guarantees `run` never hangs forever: it kills the child and writes a
failure result. FAIL-LOUD: every error path writes a result and surfaces to stderr, never a silent hang.

Env: SHIMPZ_LOGIN_DIR (default $SHIMPZ_HOME/login), SHIMPZ_CLAUDE_BIN (default /usr/local/bin/claude, overridable
for tests), SHIMPZ_LOGIN_TIMEOUT.
"""

import contextlib
import fcntl
import json
import os
import pty
import re
import select
import signal
import struct
import subprocess
import sys
import termios
import time
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
from shimpzipc import atomic_write  # the ONE atomic tmp+rename write (shared with the gateway/IPC)

SHIMPZ_HOME = os.environ.get("SHIMPZ_HOME", "/config/.shimpz")
LOGIN_DIR = os.environ.get("SHIMPZ_LOGIN_DIR", str(Path(SHIMPZ_HOME) / "login"))
CLAUDE_BIN = os.environ.get("SHIMPZ_CLAUDE_BIN", "/usr/local/bin/claude")
TIMEOUT = int(os.environ.get("SHIMPZ_LOGIN_TIMEOUT", "600"))
PTY_COLS = 4000

# `submit` accepts any PRINTABLE, non-whitespace token as the pasted OAuth code — Claude's code is
# `<code>#<state>`, so the charset must NOT be narrower than "printable ASCII, no space". The one real
# risk is whitespace/newline (a second line into the interactive CLI's stdin), which this excludes; the
# code is always passed on as a single argv element + written to a file (never a shell), and `run`
# re-cleans it through _clean_code, so a `;`/backtick/`$` in it is inert. The driver validates
# with the IDENTICAL regex before it ever execs us.
SUBMIT_CODE_RE = re.compile(r"^[!-~]{1,4096}$")

# Strip ANSI/terminal control so the URL and prompts are plain text. Keep \t (\x09) and \n (\x0a):
# the control-char class is split AROUND 0x0a so newlines survive (line structure matters for parsing).
ANSI_RE = re.compile(rb"\x1b\[[0-9;?]*[A-Za-z]|\x1b\][^\x07]*\x07|\x1b[>=]|\x1b[()][AB0]|[\x00-\x08\x0b-\x1f\x7f]")


def strip_ansi(data):
    """ANSI/control bytes → plain str. Every caller feeds raw bytes from os.read."""
    return ANSI_RE.sub(b"", data).decode("utf-8", "replace")


def extract_url(text):
    """The OAuth authorize URL out of the (ANSI-stripped) CLI output, or None.

    ONLY an oauth/authorize URL counts — any other https link (docs, help) must never be latched as
    the login URL. Tolerates trailing punctuation. With the wide pty the whole URL is on one line, so
    a plain https://<non-space> match captures it intact (query string included).
    """
    for m in re.finditer(r"https://[^\s'\"<>]+", text):
        u = m.group(0).rstrip(".,)]}>")
        if "oauth" in u or "authorize" in u:
            return u
    return None


def url_from_complete_lines(buf):
    """Extract the OAuth URL ONLY from COMPLETE (newline-terminated) lines.

    The CLI streams its output in pty frames, so a URL still arriving on the current, not-yet-terminated
    line must NOT be latched truncated (extract_url fires on the 'oauth' prefix). Requiring a trailing
    newline guarantees the whole URL line is present before we extract — a URL split across reads is
    only taken once its newline lands.
    """
    if "\n" not in buf:
        return None
    return extract_url(buf.rsplit("\n", 1)[0])  # only the portion up to the last newline


def _last_line(text):
    for ln in reversed(text.splitlines()):
        if ln.strip():
            return ln.strip()
    return ""


def _exit_code(status):
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


def _clean_code(s):
    r"""A pasted OAuth code is a single opaque token.

    Take ONLY the first line and keep only printable chars, so an embedded newline or control byte
    can't inject a SECOND line into the interactive CLI's stdin (e.g. 'realcode\nyes' must become
    'realcode', never type a second answer at the prompt).
    """
    s = (s or "").strip()
    first = s.splitlines()[0] if s else ""
    return "".join(ch for ch in first if ch.isprintable()).strip()


def _read_code(path):
    """Read + clean the pasted code.

    A MISSING file is normal (not pasted yet) → '' quietly; any OTHER read error (permission /
    is-a-directory / I/O) is SURFACED to stderr (fail-fast) instead of being silently coerced to ''
    and masquerading as the generic hard-timeout — but still returns '' so a transient glitch can't
    crash the poll loop.
    """
    try:
        return _clean_code(Path(path).read_text())
    except FileNotFoundError:
        return ""
    except OSError as e:
        sys.stderr.write(f"shimpz-login: cannot read code file {path}: {e!r}\n")
        return ""


def _verdict(exit_code, code_sent, logged_in):
    """Ok ONLY if ALL THREE hold: the CLI exited 0, we actually submitted a code, AND auth-status confirms loggedIn.

    A non-zero exit, a never-sent code, OR an unverified/false login each forces not-ok — so a
    'success' can never be reported without the login being independently verified.
    """
    return exit_code == 0 and code_sent and logged_in


def _acquire_singleton_lock(login_dir):
    """Exclusive non-blocking flock so only ONE bridge runs per LOGIN_DIR.

    A 2nd concurrent `run` can't race the first on the shared url/code/result files (which would
    let one bridge's failure clobber the other's success). Returns the held fd (keep it open for
    the process lifetime) or None if another bridge already holds it.
    """
    Path(login_dir).mkdir(parents=True, exist_ok=True)
    fd = os.open(Path(login_dir) / ".lock", os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        os.close(fd)
        return None
    else:
        return fd


def _auth_status():
    """(loggedIn, email|None) from `claude auth status --json`.

    Never raises, but NEVER swallows silently: a "not logged in" answer (the CLI ran, said so) is
    normal and quiet; an ERROR (couldn't run, or unparseable output) is SURFACED to stderr (fail-fast)
    AND treated as not-logged-in so a verify can't falsely claim success on an audit it couldn't
    actually perform.
    """
    try:
        r = subprocess.run(
            [CLAUDE_BIN, "auth", "status", "--json"],
            capture_output=True,
            text=True,
            timeout=30,
            check=False,
        )
    except (OSError, subprocess.SubprocessError) as e:
        sys.stderr.write(f"shimpz-login: `auth status` could not run: {e!r}\n")
        return False, None
    try:
        d = json.loads(r.stdout or "{}")
    except json.JSONDecodeError as e:
        sys.stderr.write("shimpz-login: `auth status` output unparseable: {!r} ({!r})\n".format(e, (r.stdout or "")[:120]))
        return False, None
    return bool(d.get("loggedIn")), d.get("email")


def _kill(pid):
    for sig in (signal.SIGTERM, signal.SIGKILL):
        try:
            os.kill(pid, sig)
            time.sleep(0.2)
        except OSError:
            return


def _pump_output(fd, buf, url_found, url_path):
    """Read whatever the pty has (0.3s poll), strip ANSI, latch the login URL once a complete line shows one.

    Returns the updated (buf, url_found).
    """
    r, _, _ = select.select([fd], [], [], 0.3)
    if r:
        try:
            data = os.read(fd, 8192)
        except OSError:
            data = b""
        if data:
            buf += strip_ansi(data)
            if not url_found:
                u = url_from_complete_lines(buf)  # complete-line only → never latch a partial URL
                if u:
                    atomic_write(url_path, u)
                    url_found = True
    return buf, url_found


def _maybe_inject_code(fd, code_path, url_found, code_sent):
    """The user pasted the code (gateway dropped it as $LOGIN_DIR/code)? → inject it into the pty.

    Returns the updated code_sent.
    """
    if not (url_found and not code_sent and code_path.exists()):
        return code_sent
    code = _read_code(code_path)  # clean single line; surfaces a real read error
    # Only CONSUME (unlink + inject) a NON-empty code. A transient empty read (writer mid-write)
    # must NOT drop the pasted code: leave the file and retry next poll. Belt-and-suspenders with
    # the gateway's ATOMIC code write (os.replace), which already prevents a partial read.
    if code:
        with contextlib.suppress(OSError):
            code_path.unlink()
        with contextlib.suppress(OSError):
            os.write(fd, (code + "\n").encode())
        code_sent = True
    return code_sent


def _result_payload(ok, email, buf, exitcode):
    """The bridge result dict: ok + a stable code/args pair (the gateway localizes it) + a human message.

    PURE (unit-tested). Codes: logged_in_as(email) / logged_in on success; on failure the last CLI
    line verbatim (cli_output) when there is one, else failed_exit(exitcode).
    """
    if ok:
        code, args = ("logged_in_as", [email]) if email else ("logged_in", [])
        msg = f"logged in as {email}" if email else "logged in"
    else:
        last = _last_line(buf)
        code, args = ("cli_output", [last]) if last else ("failed_exit", [exitcode])
        msg = last or f"login failed (exit {exitcode})"
    return {"ok": ok, "code": code, "args": args, "message": msg, "exit": exitcode}


def _child_result(fd, buf, status, code_sent):
    """Child exited: drain the last output, compute the verdict. Returns the result dict."""
    # drain whatever's left so the final "success/failure" line is captured
    for _ in range(20):
        r, _, _ = select.select([fd], [], [], 0.05)
        if not r:
            break
        try:
            d = os.read(fd, 8192)
        except OSError:
            break
        if not d:
            break
        buf += strip_ansi(d)
    exitcode = _exit_code(status)
    logged_in, email = _auth_status()
    ok = _verdict(exitcode, code_sent, logged_in)
    return _result_payload(ok, email, buf, exitcode)


def run():
    Path(LOGIN_DIR).mkdir(parents=True, exist_ok=True)
    # RE-ENTRANCY: only one bridge per LOGIN_DIR. A 2nd concurrent run refuses (and does NOT touch the
    # in-progress files), so two bridges can't race the shared url/code/result and clobber each other.
    lock_fd = _acquire_singleton_lock(LOGIN_DIR)
    if lock_fd is None:
        sys.stderr.write("shimpz-login: another login is already in progress — refusing to start a second bridge\n")
        return 1
    url_path = Path(LOGIN_DIR) / "url"
    code_path = Path(LOGIN_DIR) / "code"
    result_path = Path(LOGIN_DIR) / "result"
    for p in (
        url_path,
        code_path,
        result_path,
    ):  # clear any stale prior-run files (we hold the lock)
        p.unlink(missing_ok=True)

    pid, fd = pty.fork()
    if pid == 0:  # child: become claude under the pty
        env = dict(os.environ)
        env["BROWSER"] = "true"  # no spurious browser tab; URL prints as fallback
        env.setdefault("HOME", "/config")
        try:
            os.execvpe(CLAUDE_BIN, [CLAUDE_BIN, "auth", "login", "--claudeai"], env)  # noqa: S606  # intentional exec under pty
        except OSError:
            os._exit(127)

    # parent: WIDE window so the URL never wraps, then drive the flow
    with contextlib.suppress(OSError):
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", 50, PTY_COLS, 0, 0))
    buf = ""
    url_found = code_sent = False
    t0 = time.time()
    result = None
    try:
        while True:
            if time.time() - t0 > TIMEOUT:
                _kill(pid)
                result = {
                    "ok": False,
                    "code": "timeout",
                    "args": [TIMEOUT],
                    "message": f"login timed out (no code received in {TIMEOUT}s)",
                }
                break
            buf, url_found = _pump_output(fd, buf, url_found, url_path)
            code_sent = _maybe_inject_code(fd, code_path, url_found, code_sent)
            # child finished?
            try:
                wpid, status = os.waitpid(pid, os.WNOHANG)
            except ChildProcessError:
                wpid, status = pid, 0
            if wpid == pid:
                result = _child_result(fd, buf, status, code_sent)
                break
    except OSError as e:
        sys.stderr.write(f"shimpz-login: run error: {e!r}\n")
        _kill(pid)
        result = {"ok": False, "code": "error", "args": [repr(e)], "message": f"login error: {e!r}"}
    finally:
        with contextlib.suppress(OSError):
            os.close(fd)
        if result is None:
            result = {"ok": False, "code": "ended_unexpectedly", "args": [], "message": "login ended unexpectedly"}
        try:
            atomic_write(result_path, json.dumps(result))
        except OSError as e:
            sys.stderr.write(f"shimpz-login: could not write result: {e!r}\n")
    return 0 if result.get("ok") else 1


def status(as_json=False):
    logged_in, email = _auth_status()
    if as_json:  # machine-readable form: the gateway renders it in the chat's language
        print(json.dumps({"loggedIn": logged_in, "email": email}))
        return 0 if logged_in else 1
    if logged_in:
        print("logged in%s" % ((f" as {email}") if email else ""))
        return 0
    print("not logged in")
    return 1


def submit(code):
    r"""Validate a pasted OAuth code, then atomically drop it as $SHIMPZ_LOGIN_DIR/code for a live `run` to inject.

    The driver hands the code straight here as an argv element (never a shell string), so this
    charset gate — ^[A-Za-z0-9._~=/+-]{1,4096}$, no whitespace/newline/`;`/backtick — is the trust
    boundary: a malformed code writes NOTHING and exits 2; a valid one atomic-writes the file (the
    live `run` picks it up on its next poll) and exits 0. Never echoes the code back.
    """
    if not isinstance(code, str) or not SUBMIT_CODE_RE.match(code):
        sys.stderr.write("shimpz-login: malformed OAuth code (must match ^[A-Za-z0-9._~=/+-]{1,4096}$, no whitespace)\n")
        return 2
    Path(LOGIN_DIR).mkdir(parents=True, exist_ok=True)
    atomic_write(Path(LOGIN_DIR) / "code", code)  # the SAME atomic tmp+rename the gateway used to write it
    return 0


def main(argv):
    cmd = argv[0] if argv else ""
    if cmd == "run":
        return run()
    if cmd == "submit":
        return submit(argv[1] if len(argv) > 1 else "")
    if cmd == "status":
        return status(as_json="--json" in argv[1:])
    sys.stderr.write("usage: shimpz-login run|submit <code>|status [--json]\n")
    return 64


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
