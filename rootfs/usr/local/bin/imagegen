#!/opt/venv/bin/python
"""imagegen "<prompt>" [output.png] [size] — generate an image with gpt-image-2 (quality low by default).

  size: 1024x1024 (default) | 1536x1024 (landscape) | 1024x1536 (portrait).
  Model/quality overridable via IMAGEGEN_MODEL / IMAGEGEN_QUALITY without editing this script.

SECURITY_ENGINEERING_PLAN.md item 7: the OpenAI key lives in the separate `openai-driver`
container now — this calls its restricted API (shimpzopenai) which holds the secret and does the
generation. The brain no longer holds OPENAI_API_KEY at all.
"""

from __future__ import annotations

import os
import sys
import time
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzopenai  # shared openai-driver HTTP client (see /opt/shimpz-lib/shimpzopenai.py)


def _human(n: int) -> str:
    size = float(n)
    for unit in ("B", "K", "M", "G"):
        if size < 1024 or unit == "G":
            return f"{size:.0f}{unit}" if unit == "B" else f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}G"


def main() -> None:
    if len(sys.argv) < 2:
        sys.exit('usage: imagegen "<prompt>" [output.png] [size]')
    prompt = sys.argv[1]
    if len(sys.argv) > 2:
        out = Path(sys.argv[2])
    else:
        out = Path(f"/config/workspace/img-{time.strftime('%Y%m%d-%H%M%S', time.gmtime())}.png")
    size = sys.argv[3] if len(sys.argv) > 3 else "1024x1024"
    model = os.environ.get("IMAGEGEN_MODEL", "gpt-image-2")
    quality = os.environ.get("IMAGEGEN_QUALITY", "low")

    out.parent.mkdir(parents=True, exist_ok=True)
    try:
        png = shimpzopenai.image(prompt, size=size, quality=quality, model=model)
    except shimpzopenai.OpenAIDriverError as exc:
        sys.exit(f"OpenAI ERROR: {exc}")
    out.write_bytes(png)
    print(f"image generated ({model}/{quality}, {size}): {out}  ({_human(len(png))})")


if __name__ == "__main__":
    main()
