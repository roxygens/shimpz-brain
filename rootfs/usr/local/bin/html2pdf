#!/usr/bin/env bash
# html2pdf <input.html> [output.pdf]
#   Hand-authored HTML -> professional PDF via WeasyPrint (no JS, deterministic, never blank).
#   The house theme is applied automatically; author with its classes (.cover, .callout,
#   <table>, <figure>). For LIVE JavaScript charts (Chart.js/D3) use html2pdf-chrome instead.
set -euo pipefail
THEME="${SHIMPZ_PDF_THEME:-/usr/local/share/shimpz-pdf/theme.css}"
in="${1:?usage: html2pdf <input.html> [output.pdf]}"
out="${2:-${in%.*}.pdf}"
[ -f "$in" ] || { echo "ERROR: file not found: $in" >&2; exit 1; }

weasyprint -s "$THEME" "$in" "$out" 2>/dev/null

chars="$(pdftotext "$out" - 2>/dev/null | tr -d '[:space:]' | wc -c)"
if [ "${chars:-0}" -lt 20 ]; then
    echo "WARN: $out looks BLANK — inspect before sending." >&2
fi
echo "$out"
