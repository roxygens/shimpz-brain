#!/opt/venv/bin/python
"""shimpz-secaudit — the JUDGMENT security gate for `shimpz-publish`.

Before a backend is exposed to the PUBLIC internet, summon an independent, READ-ONLY Opus auditor
that threat-models the EXPOSED surface for the things a deterministic linter (shimpz-stdcheck)
cannot judge: object-level authorization
(BOLA/IDOR), private/user data served without authentication, injection, mass assignment, secrets in
responses, missing brute-force limits on auth. It returns a strict JSON verdict; shimpz-publish turns a
non-SAFE verdict into a `shimpz-approve` decision (Juliano decides, informed) and ABORTS on deny/timeout.

This is judgment, not regex — so it runs ONLY at publish time of a PUBLIC API (rare, justified cost),
mirroring the dev-side battle-test-gate's military auditor. Read-only (`--allowedTools Read,Grep,Glob`),
so it can inspect but never mutate the project it judges.

Calibration is the whole point: most Shimpz backends are public marketing/content APIs that legitimately
need NO auth — those are SAFE. The auditor flags only a GENUINE exposure: private/user data reachable
without authz, a handler that trusts a client-supplied id, an injection sink, a leaked secret. "This
public endpoint has no login" is NOT a finding unless it exposes data that should be protected.

Exit: 0 SAFE · 2 REVIEW (uncertain/medium) · 3 UNSAFE (critical) · 1 audit could-not-run.
Usage: shimpz-secaudit <backend-dir> [--json]
"""

import json
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzaudit  # shared auditor plumbing (collect/extract/run)

MODEL = os.environ.get("SHIMPZ_SECAUDIT_MODEL", "opus")
TIMEOUT = int(os.environ.get("SHIMPZ_SECAUDIT_TIMEOUT", "600"))
MAX_BYTES = shimpzaudit.DEFAULT_MAX_BYTES
SENTINEL = "SHIMPZ_SECAUDIT_RUNNING"  # set in the sub-run's env so its own hooks know not to recurse

PROTOCOL = (
    "You are the PUBLISH SECURITY AUDITOR for an autonomous agent that is about to expose this backend "
    "on the PUBLIC INTERNET (no Cloudflare Access in front). A defect you miss becomes a live, "
    "internet-facing vulnerability on a real domain. Your standard is the OWASP API Security Top 10. You "
    "are adversarial, READ-ONLY, and you certify PROOF, not hope — but you are also CALIBRATED: most of "
    "these backends are public marketing/content APIs that legitimately need NO authentication, and "
    "those are SAFE. You judge whether this surface is SAFE TO BE PUBLIC, not whether it has a login.\n\n"
    "You may Read/Grep/Glob the backend below. EXECUTE EVERY STEP:\n"
    "1) ENDPOINT INVENTORY — enumerate every route (path + method) and, for each, what it READS or "
    "MUTATES and whether it returns/accepts data that is private, per-user, financial, or administrative.\n"
    "2) THREAT MODEL each endpoint against the OWASP API Top 10, in particular:\n"
    "   • BOLA/IDOR (API1): a handler that loads or mutates a row by a CLIENT-SUPPLIED id WITHOUT checking "
    "ownership (no `WHERE owner_id == current_user.id` / equivalent) — the #1 API bug. Proven exposure of "
    "another user's object = UNSAFE.\n"
    "   • Broken authentication (API2): an endpoint serving/mutating PRIVATE or per-user data with no "
    "auth dependency at all; tokens without expiry; passwords not hashed (argon2/bcrypt).\n"
    "   • Broken object-property-level authz / mass assignment (API3): a write that binds the whole "
    "request body to the model so a client can set fields it must not (role, owner_id, is_admin, price).\n"
    "   • Injection (API8-ish): raw SQL string interpolation / shell with request data / path traversal.\n"
    "   • Secrets exposure: a secret/token/private key returned in a response or logged; debug tracebacks "
    "to clients; an admin/mutating endpoint reachable with no key.\n"
    "   • Missing brute-force protection on login/token endpoints.\n"
    "3) CALIBRATE — a PUBLIC, read-only marketing/content endpoint that returns only data meant to be "
    "public, with no mutating/admin route exposed, is SAFE; do NOT flag it for 'no login'. The decision "
    "to be public-with-no-auth is legitimate. Flag ONLY a genuine exposure of data/operations that SHOULD "
    "be protected, or an injection/secret/mass-assignment defect.\n\n"
    "VERDICT RULES: UNSAFE if any endpoint provably exposes private/per-user/financial/admin data or "
    "operations to an unauthenticated or unauthorized caller, or there is a real injection / secret-leak "
    "/ mass-assignment defect. REVIEW if there is a plausible but unproven concern, or you cannot tell "
    "whether returned data is private. SAFE only when every exposed endpoint is either properly "
    "authorized or legitimately public. For each finding give the exact route, the OWASP class, a "
    "concrete attack (the request a stranger sends and what they get), and the one-line fix.\n\n"
    "OUTPUT — emit ONLY this JSON object, nothing else:\n"
    '{"verdict":"SAFE"|"REVIEW"|"UNSAFE", "risk":"none"|"low"|"medium"|"high"|'
    '"critical", "findings":[{"route":"METHOD /path","owasp":"API1 BOLA","attack":"the '
    'exact request a stranger sends + what they obtain","fix":"one line"}], "reason":"one tight '
    'paragraph justifying the verdict"}'
)


INTERNAL_CONTEXT = (
    "DEPLOYMENT CONTEXT — INTERNAL SERVICE (platform-ENFORCED, not a promise): this service is "
    "registered internal=True. The publish gate hard-refuses to expose it on any domain; it has no "
    "edge route and no public surface. The ONLY network paths to it are other services that "
    "explicitly DECLARED it at their own deploy (pairwise, audited wiring — an undeclared app "
    "cannot even resolve its hostname). Therefore judge against this REAL surface, overriding the "
    "public-internet framing below: an attack that requires an internet stranger reaching the API "
    "is NOT a blocking finding here — include it in findings with its owasp field prefixed "
    "'IF-EXPOSED ' and let it NEVER affect the verdict. Blocking findings are ONLY those "
    "exploitable from the real surface: a malicious or compromised DECLARED consumer escalating "
    "beyond what it could already do, poisoned bus/event data, injection via data arriving through "
    "legitimate internal calls, secrets leaked into logs/responses, or damage to third parties. "
    "Missing auth on an internal-only route is an IF-EXPOSED note, not a verdict driver.\n\n"
)


def internal_context(app_name):
    """The exposure-aware preamble — non-empty ONLY when the app's registry manifest says internal.

    First deploy of a new service has no manifest yet → strict public-grade audit by default
    (conservative); redeploys of a registered internal service get the calibrated surface.
    """
    if not app_name:
        return ""
    mf = Path(os.environ.get("SHIMPZ_REGISTRY", "/config/workspace/registry")) / f"{app_name}.json"
    try:
        raw = mf.read_text()
    except OSError:
        return ""  # missing/unreadable manifest → strict public-grade audit (the safe direction)
    try:
        manifest = json.loads(raw)
    except ValueError:
        return ""
    return INTERNAL_CONTEXT if manifest.get("internal") is True else ""


def parse_verdict(stdout):
    """Pull the verdict out of the raw auditor stdout (envelope-aware).

    Unreadable → ERROR (never a silent SAFE).
    """
    v = shimpzaudit.extract_json_obj(stdout, required_key="verdict")
    if not v or "verdict" not in v:
        return {"verdict": "ERROR", "reason": "unparseable auditor output"}
    v["verdict"] = str(v.get("verdict", "")).upper()
    return v


def run_secaudit(backend_dir, runner=subprocess.run, context=""):
    """Summon the read-only Opus auditor on the backend source.

    `runner` is injectable so tests never spawn a real model. Returns a verdict dict (verdict ∈
    SAFE/REVIEW/UNSAFE/ERROR). The sub-run gets SENTINEL=1 in its env so its own Stop hooks know this is
    a nested, read-only audit. Any could-not-audit condition (unreadable/empty source, spawn error,
    non-zero exit) → ERROR: fail-CLOSED, never a partial-source SAFE.
    """
    payload, truncated, err = shimpzaudit.judge(
        backend_dir,
        context + PROTOCOL,
        "BACKEND UNDER AUDIT (about to be PUBLIC)",
        model=MODEL,
        timeout=TIMEOUT,
        sentinel=SENTINEL,
        max_turns=30,
        max_bytes=MAX_BYTES,
        runner=runner,
    )
    if err is not None:
        return {"verdict": "ERROR", "reason": err}  # fail-CLOSED
    v = parse_verdict(payload)
    if truncated and v.get("verdict") == "SAFE":
        # a SAFE verdict over TRUNCATED source isn't trustworthy (a later file may hold the bug) →
        # downgrade to REVIEW so it can never auto-publish; the human is asked.
        v["verdict"] = "REVIEW"
        v["reason"] = "backend source exceeded the audit size limit and was TRUNCATED — audit incomplete; " + (
            v.get("reason") or ""
        )
    return v


# exit code per verdict — shimpz-publish treats 0 as proceed and everything else as "ask Juliano".
EXIT = {"SAFE": 0, "REVIEW": 2, "UNSAFE": 3, "ERROR": 1}


def format_human(v):
    out = ["🔒 PUBLISH SECURITY AUDIT — {} (risk: {})".format(v.get("verdict", "?"), v.get("risk", "?"))]
    out.extend(
        "  • [{}] {}\n      attack: {}\n      fix: {}".format(
            f.get("owasp", "?"),
            f.get("route", "?"),
            f.get("attack", ""),
            f.get("fix", ""),
        )
        for f in v.get("findings") or []
    )
    if v.get("reason"):
        out.append("  {}".format(v["reason"]))
    return "\n".join(out)


def main(argv):
    app_name = None
    if "--app" in argv:
        i = argv.index("--app")
        if i + 1 >= len(argv):
            sys.stderr.write("usage: shimpz-secaudit <backend-dir> [--json] [--app <name>]\n")
            return 64
        app_name = argv[i + 1]
        argv = argv[:i] + argv[i + 2 :]
    target, as_json = shimpzaudit.cli_arg(argv, "usage: shimpz-secaudit <backend-dir> [--json] [--app <name>]")
    if target is None:
        return 64
    if shimpzaudit.kill_switch("SHIMPZ_SECAUDIT", target, "security audit"):
        # explicit kill-switch (surfaced by kill_switch: stderr + owner note) — print a SAFE-equivalent
        print(
            json.dumps(
                {
                    "verdict": "SAFE",
                    "risk": "none",
                    "findings": [],
                    "reason": "skipped (SHIMPZ_SECAUDIT=0)",
                }
            )
            if as_json
            else "audit skipped (SHIMPZ_SECAUDIT=0)"
        )
        return 0
    verdict = run_secaudit(target, context=internal_context(app_name))
    v = verdict.get("verdict", "ERROR")
    if as_json:
        print(json.dumps(verdict))
    else:
        print(format_human(verdict))
    return EXIT.get(v, 1)


if __name__ == "__main__":
    # recursion guard: if WE are already inside an audit's sub-run, do nothing (defensive — shimpz-secaudit
    # isn't a hook, but a future caller could chain it; never let it summon itself).
    if os.environ.get(SENTINEL) == "1":
        print('{"verdict":"SAFE","risk":"none","findings":[],"reason":"nested audit no-op"}')
        sys.exit(0)
    sys.exit(main(sys.argv[1:]))
