#!/opt/venv/bin/python
"""uiclick/uikey/uitype — REAL input via XTEST, over browser-agent.

  uiclick <x> <y> [left|right|middle] [count]   click
  uikey   <keysym...>                            real key(s) (e.g.: Return, ctrl+l, alt+F4)
  uitype  "<text>"                                types real text

Use this for ANY NATIVE window/dialog (outside the Chrome page). Synthetic events (XSendEvent)
are silently discarded by GTK/Qt; these inject REAL XTEST events, which the toolkits accept.
x,y are SCREEN coordinates (not relative to the window) — get them from shimpz-cdp rect or a
shimpz-shot screenshot.

SECURITY_ENGINEERING_PLAN.md item 0: the X11 display these used to drive directly is a Unix domain
socket inside the `shimpz-browser` container (svc-kasmvnc's Xvnc has no `-listen tcp`) — unreachable
from here. This is now a thin HTTP client of browser-agent's /v1/browser/click|key|type.
"""

import os
import sys
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzbrowser  # shared browser-agent HTTP client (see /opt/shimpz-lib/shimpzbrowser.py)


def cmd_click(argv: list[str]) -> None:
    if len(argv) < 2:
        sys.exit("usage: uiclick <x> <y> [left|right|middle] [count]")
    x, y = int(argv[0]), int(argv[1])
    button = argv[2] if len(argv) > 2 else "left"
    count = int(argv[3]) if len(argv) > 3 else 1
    shimpzbrowser.call_json("POST", "/v1/browser/click", {"x": x, "y": y, "button": button, "count": count})
    print(f"OK: click ({button} x{count}) at ({x},{y}) via XTEST.")


def cmd_key(argv: list[str]) -> None:
    if not argv:
        sys.exit("usage: uikey <keysym...>")
    # Each keysym/combo is its OWN call (matches the original `xdotool key a b c` behavior of
    # pressing each in sequence) — browser-agent's /v1/browser/key validates one combo per call.
    for combo in argv:
        shimpzbrowser.call_json("POST", "/v1/browser/key", {"combo": combo})
    print(f"OK: key(s) '{' '.join(argv)}' via XTEST.")


def cmd_type(argv: list[str]) -> None:
    if not argv:
        sys.exit('usage: uitype "<text>"')
    text = argv[0]
    shimpzbrowser.call_json("POST", "/v1/browser/type", {"text": text})
    print("OK: text typed via XTEST.")


def main() -> None:
    prog = Path(sys.argv[0]).name
    argv = sys.argv[1:]
    try:
        if prog == "uiclick":
            cmd_click(argv)
        elif prog == "uikey":
            cmd_key(argv)
        elif prog == "uitype":
            cmd_type(argv)
        else:
            sys.exit("call as uiclick / uikey / uitype")
    except shimpzbrowser.BrowserAgentError as exc:
        sys.exit(f"ERROR: {exc}")


if __name__ == "__main__":
    main()
