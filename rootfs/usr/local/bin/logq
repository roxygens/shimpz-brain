#!/usr/bin/env bash
# logq — the agent's log-sniffing CLI. ONE interface to read the whole fleet's structured logs, so Shimpz
# debugs from evidence, never a guess. Primary backend = VictoriaLogs (LogsQL over $VICTORIALOGS_URL);
# if VictoriaLogs is unreachable it falls back — LOUDLY, never silently — to the raw JSONL files under
# $SHIMPZ_LOG_DIR. Every service logs JSON (structlog/pino) with the same schema, so the columns below always
# line up. See `logq schema`.
#
#   logq services [--since 24h]     which services are logging + line counts (start here)
#   logq tail <service>             live-follow one service
#   logq trace <trace_id>           one request end-to-end, ACROSS services, time-ordered
#   logq errors [--since 1h]        recent error/warn lines, newest first
#   logq q '<logsql>'               raw LogsQL passthrough (VictoriaLogs only)
#   logq schema                     the canonical field schema
#
# Fail-fast: a query error surfaces; nothing is swallowed.
set -euo pipefail

VL="${VICTORIALOGS_URL:-http://victorialogs:9428}"
# The supervisor (shimpz-app) already writes each app's JSON stdout to $SHIMPZ_HOME/logs/app-<name>.log,
# rotated (10MB×3) — that IS the zero-infra centralized store. VictoriaLogs (opt-in) indexes the same
# files for high-volume LogsQL; when it's down we read the files directly.
SHIMPZ_HOME="${SHIMPZ_HOME:-/config/.shimpz}"
LOG_DIR="${SHIMPZ_LOG_DIR:-$SHIMPZ_HOME/logs}"

die() { printf 'logq: %s\n' "$*" >&2; exit 1; }
need_jq() { command -v jq >/dev/null 2>&1 || die "jq is required (present in the shimpz-brain container)"; }

# One human line per JSON event: TIME  LEVEL  [service]  trace  message   {+error}.
# Read RAW (-R) and parse per-line with fromjson?: jq stops the whole stream at the first parse error, so
# a single non-JSON line (a crash before logging init) would otherwise swallow every line after it. Here a
# bad/non-object line falls through to `// $raw` — printed as-is, never dropped, never fatal.
fmt() {
  # --unbuffered: flush each line immediately so `tail` (a live follow) streams in real time instead of
  # sitting in jq's block buffer until EOF.
  jq --unbuffered -rR '
    . as $raw
    | (fromjson? | select(type == "object")
       | (._time // .ts // "?") as $t
       | (.level // "?" | ascii_upcase) as $l
       | (.service // "?") as $s
       | ((.trace_id // "-")[0:12]) as $tid
       | (._msg // .msg // .message // "") as $m
       | (if .error then "  ⟪" + ((.error.type // "error")|tostring) + ": " + ((.error.msg // .error.message // "")|tostring) + "⟫"
          elif ((.exception | type) == "array") and ((.exception | length) > 0) then
            "  ⟪" + ((.exception[0].exc_type // "exception")|tostring) + ": " + ((.exception[0].exc_value // "")|tostring) + "⟫"
          else "" end) as $e
       | "\($t)  \($l)\t[\($s)] \($tid)  \($m)\($e)"
      ) // $raw
  '
}

vl_up() { curl -sf -m 2 "$VL/health" >/dev/null 2>&1; }

# GET /select/logsql/query — returns JSONL. Args: <logsql> [limit]
vl_query() {
  local q="$1" limit="${2:-500}"
  curl -sf -G "$VL/select/logsql/query" \
    --data-urlencode "query=$q" --data-urlencode "limit=$limit" \
    || die "VictoriaLogs query failed: $q"
}

vl_tail() {
  local q="$1"
  # streaming endpoint — no limit; Ctrl-C to stop
  curl -sN -G "$VL/select/logsql/tail" --data-urlencode "query=$q"
}

# ── file fallback (the supervisor's per-app JSONL) — used when VictoriaLogs is down ───────────────
files() {
  local any=1
  for g in "$LOG_DIR"/app-*.log "$LOG_DIR"/*.jsonl; do
    compgen -G "$g" >/dev/null 2>&1 && { printf '%s\n' $g; any=0; }
  done
  return $any
}
file_backend_or_die() {
  files >/dev/null 2>&1 || die "VictoriaLogs unreachable ($VL) and no JSONL files in $LOG_DIR — nothing to read"
  printf 'logq: VictoriaLogs unreachable (%s) — falling back to files in %s\n' "$VL" "$LOG_DIR" >&2
}

since_of() {  # parse a trailing "--since <dur>" → echo dur (default given as $1)
  local def="$1"; shift || true
  while [ $# -gt 0 ]; do case "$1" in --since) echo "${2:-$def}"; return;; esac; shift; done
  echo "$def"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  services)
    need_jq
    since="$(since_of 24h "$@")"
    # shellcheck disable=SC2046  # files() emits a deliberately word-split list of log-file paths
    if vl_up; then
      vl_query "_time:$since * | stats by (service) count() as lines | sort by (lines desc)" \
        | jq -rc '"\(.lines)\t\(.service // "?")"' | { printf 'LINES\tSERVICE\n'; sort -rn; } | column -t -s$'\t'
    else
      file_backend_or_die
      # fromjson? per raw line → a non-JSON line is skipped, not fatal (jq would otherwise die on it)
      cat $(files) | jq -rR 'fromjson? | select(type == "object") | .service // "?"' | sort | uniq -c | sort -rn
    fi
    ;;
  tail)
    need_jq
    svc="${1:?usage: logq tail <service>}"
    # shellcheck disable=SC2046  # files() emits a deliberately word-split list of log-file paths
    if vl_up; then vl_tail "service:$svc" | fmt
    else file_backend_or_die; tail -n0 -F $(files) 2>/dev/null | grep --line-buffered -F "\"service\":\"$svc\"" | fmt
    fi
    ;;
  trace)
    need_jq
    tid="${1:?usage: logq trace <trace_id>}"
    # shellcheck disable=SC2046  # files() emits a deliberately word-split list of log-file paths
    if vl_up; then vl_query "trace_id:$tid | sort by (_time)" 2000 | fmt
    # grep exits 1 when the trace id simply isn't present (a NORMAL outcome) — under pipefail that would
    # make logq die with exit 1 and no output, unlike the VL branch which returns empty+0. Treat exit 1
    # (no match) as success; a real grep error (≥2) still fails.
    else file_backend_or_die; { grep -hF "$tid" $(files) 2>/dev/null || [ $? -eq 1 ]; } | fmt
    fi
    ;;
  errors)
    need_jq
    since="$(since_of 1h "$@")"
    # shellcheck disable=SC2046  # files() emits a deliberately word-split list of log-file paths
    if vl_up; then vl_query "_time:$since level:(error OR warn OR warning) | sort by (_time desc)" 300 | fmt
    else
      file_backend_or_die
      # Glob/file order is NOT time order, so mirror the VL "_time desc" sort ourselves: prefix each
      # line with its _time/ts key (fromjson? keeps a non-JSON line alive, keyed ""), sort DESC, drop
      # the key, keep the newest 300. ISO-8601 UTC keys sort lexicographically == chronologically.
      { grep -hE '"level":[[:space:]]*"(error|warn|warning)"' $(files) 2>/dev/null || [ $? -eq 1 ]; } \
        | jq -rR '(fromjson? // {}) as $o | "\($o._time // $o.ts // "")\t\(.)"' \
        | sort -r | cut -f2- | head -n 300 | fmt
    fi
    ;;
  q)
    need_jq
    q="${1:?usage: logq q '<logsql>'}"
    vl_up || die "raw LogsQL needs VictoriaLogs (unreachable: $VL)"
    vl_query "$q" "${2:-1000}" | fmt
    ;;
  schema)
    cat <<'EOF'
Canonical log schema (every service, structlog/pino → JSON, one event per line):

  ts        ISO-8601 UTC timestamp            (VictoriaLogs indexes it as _time)
  level     debug|info|warn|error
  service   the emitting service name
  trace_id  per-request id, propagates across services (bind in app/middleware.py)
  msg       the event/message                 (VictoriaLogs indexes it as _msg)
  logger    module/logger name                (optional)
  exception [ {exc_type, exc_value, frames} ] full structured traceback (structlog dict_tracebacks) —
            present on log.exception(...); the fail-loud handler emits it on every unhandled error
  error     {type, msg}                        OPTIONAL error object a caller binds explicitly
  …         any extra key=value the caller binds

Query it: `logq trace <trace_id>` follows one request end-to-end; `logq q 'service:foo level:error'`
runs raw LogsQL (https://docs.victoriametrics.com/victorialogs/logsql/).
EOF
    ;;
  ""|-h|--help|help)
    sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *) die "unknown command: $cmd (try: logq help)";;
esac
