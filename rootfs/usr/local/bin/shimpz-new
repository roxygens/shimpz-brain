#!/opt/venv/bin/python
"""shimpz-new — scaffold a new project in the NON-NEGOTIABLE ecosystem shape, so the standard is GENERATED, not remembered.

One command produces a compliant skeleton that already passes shimpz-stdcheck:

  fullstack : backend/ (FastAPI + SQLAlchemy 2 + alembic + isolated Postgres) + frontend/ (SvelteKit 5
              + Tailwind v4, talking to the API at a RELATIVE /api/...) + a generated SECRET_KEY.
  api       : backend only.        web : SvelteKit frontend only (static landing, prerendered).
  script    : a minimal uv project (one main.py).

Design — two phases:
  • SOURCE phase (pure file writes): everything shimpz-stdcheck judges (backend/app/*.py, frontend/src/*)
    plus .gitignore/.env.example/README. No network.
  • TOOLCHAIN phase (real CLIs): `uv sync`, official `sv create`, `pnpm add` (tailwind + adapter-static),
    `shimpz-db create`, `alembic init`, secret generation into .env. Backend files are hand-written (small,
    stable); the FRONTEND scaffold uses the official `sv` CLI (guaranteed-building) and shimpz-new only
    OVERLAYS the compliant deltas (the /api dev proxy, an example page that fetches /api, Tailwind).

TESTING: there are NO mocks. The pure security/parse functions are tested directly; the toolchain runs
for real, in the shimpz-brain container, via tests/test-shimpz-new-live.py (it needs node/uv/pnpm/Postgres, which
exist only there). See [[shimpz-new-live-only-tests]].

FAIL-FAST: every toolchain step runs with check=True and surfaces loudly — no fallback that masks a
broken scaffold. Refuses to overwrite an existing project; validates the name against path traversal.
"""

import json
import os
import re
import secrets
import shutil
import subprocess
import sys
from pathlib import Path

KINDS = ("fullstack", "api", "web", "script")

# A project name is also a directory name and a Postgres db suffix — keep it a strict slug so it can
# never escape PROOT (path traversal) or break shimpz-db. Lowercase, dash-separated, ≤40 chars.
# \Z (end-of-STRING), NOT $ — `$` matches before a trailing "\n", so 'demo\n' would slip through and
# become a newline-bearing directory/db name. \Z forbids that.
NAME_RE = re.compile(r"[a-z][a-z0-9]*(-[a-z0-9]+)*\Z")


def validate_name(name):
    """Return the name if it is a safe slug, else raise ValueError.

    Security boundary: rejects '', '..', anything with a path separator, leading dot/dash, uppercase,
    spaces, or >40 chars.
    """
    if not name or len(name) > 40:
        raise ValueError("name must be 1–40 characters")
    if not NAME_RE.match(name):
        raise ValueError(f"name must be a lowercase slug [a-z0-9-], e.g. my-landing (got {name!r})")
    return name


def has_backend(kind):
    return kind in ("fullstack", "api", "script")


def has_frontend(kind):
    return kind in ("fullstack", "web")


def _write(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")


# ── source templates ─────────────────────────────────────────────────────────────────────────────
# Canonical files shipped in the image (/usr/local/share/shimpz-std) — ONE source of truth shared with
# the other consumers (shimpz-project-sync copies the same gitignore; shimpz-stdgate enforces the same
# ruff.toml), read at import so scaffold and gate can never drift. FAIL-LOUD if absent: an image
# without the standards files is broken — there is no embedded fallback to mask that.
_SHIMPZ_STD = Path(__file__).resolve().parent.parent / "share" / "shimpz-std"
GITIGNORE = (_SHIMPZ_STD / "gitignore").read_text(encoding="utf-8")

# shimpzbus source to VENDOR into every backend (see BACKEND_PYPROJECT). Resolved relative to this file
# so it works both in-container (/opt/shimpz-lib/shimpzbus) and on the repo checkout (rootfs/opt/shimpz-lib/
# shimpzbus) for the live tests. FAIL-LOUD at import if absent — an image without shimpzbus is broken.
_SHIMPZBUS_SRC = Path(__file__).resolve().parents[3] / "opt" / "shimpz-lib" / "shimpzbus"
if not (_SHIMPZBUS_SRC / "pyproject.toml").is_file():
    raise FileNotFoundError(f"shimpzbus source not found at {_SHIMPZBUS_SRC} — cannot scaffold backends")

ENV_EXAMPLE = """\
# Copy to .env (gitignored) and fill in. shimpz-new generates real values on a real machine.
DATABASE_URL=
SECRET_KEY=
# Logging is process env (NOT read from .env): LOG_FORMAT=console for human dev output (default json),
# LOG_LEVEL=DEBUG to see debug lines (default INFO). Set them in the shell, e.g. LOG_FORMAT=console uv run ...
"""

# uvicorn[standard] is REQUIRED (not plain uvicorn): it ships the `websockets` protocol backend —
# the most mature Python WebSocket implementation — which serves the project's ws gateway (app/ws.py).
# shimpzbus is the bus backbone (publish/stream/run_worker), VENDORED into backend/vendor/shimpzbus by
# write_backend: apps deploy as their OWN containers that mount ONLY the project read-only at /app
# (drivers/apps/manifests.py), so a brain-container path like /opt/shimpz-lib/shimpzbus can never resolve
# there — the project must be self-contained.
