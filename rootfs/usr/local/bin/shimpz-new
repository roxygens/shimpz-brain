# frontend deltas (overlay the official `sv` scaffold online; stand alone offline so shimpz-stdcheck can
# confirm the /api-relative wiring is clean).
# NOTE: the Svelte templates contain `{...}`/`${...}` braces → inject the name with .replace, never
# str.format. The fetch runs in onMount (browser only) so it never fires during SSR/prerender.
PAGE_SVELTE_API = """\
<script lang="ts">
  import { onMount } from "svelte";
  import { connect } from "$lib/ws";

  // Talk to the backend at a RELATIVE /api path — works in dev (vite proxy) and live (Caddy). NEVER a
  // hardcoded loopback host here: the visitor's browser would hit THEIR own machine once published.
  let status = $state("…");
  onMount(async () => {
    const res = await fetch("/api/health");
    status = (await res.json()).status;
  });

  // Realtime data arrives over the WebSocket (the house standard — never HTTP polling): the backend
  // publishes with app/events.py notify() and the ws gateway pushes it here. `live.last` is the
  // latest event; add an onEvent callback for granular handling.
  const live = connect();
</script>

<main class="mx-auto max-w-2xl p-8">
  <h1 class="text-3xl font-bold">__PROJECT_NAME__</h1>
  <p class="mt-2 text-gray-600">API health: {status}</p>
  <p class="mt-1 text-sm text-gray-400">live channel: {$live.status}</p>
</main>
"""

# The realtime CLIENT — the standard way the front receives backend data (never setInterval+fetch
# polling). Connects to the RELATIVE /ws (vite proxies it in dev; Caddy routes it live) and
# auto-reconnects with capped exponential backoff. SSR/prerender-safe: during SSR there is no
# WebSocket global, so the store just reports "closed" and does nothing.
WS_TS = """\
// Realtime events from the backend — subscribe, don't poll.
//   const live = connect();                          // $live.status / $live.last in a component
//   const live = connect("/ws", (e) => { ... });     // or handle each event as it arrives
// The backend side is app/events.py notify(kind, **data); the gateway is app/ws.py.
import { browser } from "$app/environment";
import { readable, type Readable } from "svelte/store";

export type WsEvent = Record<string, unknown> & { kind?: string };
export type WsState = { status: "connecting" | "open" | "closed"; last: WsEvent | null };

export function connect(path = "/ws", onEvent?: (e: WsEvent) => void): Readable<WsState> {
  return readable<WsState>({ status: "connecting", last: null }, (set) => {
    if (!browser) {
      // SSR/prerender: no socket to open (Node ships a global WebSocket but no page `location`,
      // so feature-sniffing is NOT enough); the browser hydration subscribes again for real.
      set({ status: "closed", last: null });
      return;
    }
    let ws: WebSocket | null = null;
    let last: WsEvent | null = null;
    let tries = 0;
    let stopped = false;
    let timer: ReturnType<typeof setTimeout> | undefined;
    const open = () => {
      const proto = location.protocol === "https:" ? "wss" : "ws";
      ws = new WebSocket(`${proto}://${location.host}${path}`);
      set({ status: "connecting", last });
      ws.onopen = () => {
        tries = 0;
        set({ status: "open", last });
      };
      ws.onmessage = (m) => {
        last = JSON.parse(m.data) as WsEvent;
        set({ status: "open", last });
        onEvent?.(last);
      };
      ws.onclose = () => {
        if (stopped) return;
        set({ status: "closed", last });
        timer = setTimeout(open, Math.min(500 * 2 ** tries++, 15_000)); // capped backoff
      };
    };
    open();
    return () => {
      stopped = true;
      clearTimeout(timer);
      ws?.close();
    };
  });
}
"""

PAGE_SVELTE_STATIC = """\
<main class="mx-auto max-w-2xl p-8">
  <h1 class="text-3xl font-bold">__PROJECT_NAME__</h1>
  <p class="mt-2 text-gray-600">A new SvelteKit + Tailwind landing.</p>
</main>
"""

LAYOUT_SVELTE = """\
<script lang="ts">
  import "../app.css";
  let { children } = $props();
</script>

{@render children()}
"""

SVELTE_CONFIG_STATIC = """\
import adapter from "@sveltejs/adapter-static";
import { vitePreprocess } from "@sveltejs/vite-plugin-svelte";

// Static landing: prerender every page to plain HTML (best SEO/GEO). See +layout.ts (prerender = true).
export default {
  preprocess: vitePreprocess(),
  kit: { adapter: adapter() },
};
"""

APP_CSS = '@import "tailwindcss";\n'

LAYOUT_TS = "export const prerender = true;\n"

VITE_CONFIG_TS = """\
import { sveltekit } from "@sveltejs/kit/vite";
import tailwindcss from "@tailwindcss/vite";
import { defineConfig } from "vite";

// Dev only: proxy the relative /api calls (and the /ws websocket) to the local backend so the SAME
// code runs in dev and live (in production Caddy routes /api/* and /ws). These loopbacks live in
// the dev config, NEVER in src/.
const apiPort = process.env.SHIMPZ_API_PORT || "8000";
const wsPort = process.env.SHIMPZ_WS_PORT || "8001";

export default defineConfig({
  plugins: [tailwindcss(), sveltekit()],
  server: {
    proxy: {
      "/api": { target: `http://127.0.0.1:${apiPort}`, changeOrigin: true },
      "/ws": { target: `ws://127.0.0.1:${wsPort}`, ws: true },
    },
  },
});
"""


# Test structure, scaffold-ready (BACKEND ONLY — the critical part is always testable). Every test runs
# inside a transaction that ROLLS BACK, so tests are isolated and leave the DB untouched; the client
# fixture routes HTTP through the same rolled-back session. The agent fills in tests for the CRITICAL
# paths (routes, business rules, auth) — the shimpz-logaudit judge flags critical paths left untested.
CONFTEST_PY = '''\
"""Test fixtures — each test runs inside a transaction ROLLED BACK at teardown, so tests are isolated and
leave the database untouched (no leaked rows, no ordering coupling). Survives the code under test calling
session.commit(): join_transaction_mode="create_savepoint" turns each commit into a SAVEPOINT release and
the outer rollback undoes everything."""
import pytest
from fastapi.testclient import TestClient
from sqlalchemy.orm import Session

from app.db import engine, get_db
from app.main import app


@pytest.fixture()
def db():
    connection = engine.connect()
    transaction = connection.begin()
    session = Session(bind=connection, join_transaction_mode="create_savepoint")
    try:
        yield session
    finally:
        session.close()
        transaction.rollback()
        connection.close()


@pytest.fixture()
def client(db: Session):
    # routes get the SAME rolled-back session, so HTTP tests are isolated too.
    app.dependency_overrides[get_db] = lambda: db
    with TestClient(app) as test_client:
        yield test_client
    app.dependency_overrides.clear()
'''

TEST_HEALTH_PY = """\
def test_health(client):
    resp = client.get("/api/health")
    assert resp.status_code == 200
    assert resp.json() == {"status": "ok"}
"""


def write_backend(target, name):
    _write(
        target / "backend" / "pyproject.toml",
        BACKEND_PYPROJECT.format(name=name),
    )
    # Vendor shimpzbus so the read-only /app mount carries it into the app's own container — the only
    # place the pyproject's relative path source can resolve at deploy time.
    shutil.copytree(
        _SHIMPZBUS_SRC,
        target / "backend" / "vendor" / "shimpzbus",
        ignore=shutil.ignore_patterns("__pycache__", "*.pyc"),
    )
    app = target / "backend" / "app"
    _write(app / "__init__.py", "")
    _write(app / "config.py", CONFIG_PY)
    _write(app / "db.py", DB_PY)
    _write(app / "logconf.py", LOGCONF_PY)
    _write(app / "middleware.py", MIDDLEWARE_PY)
    _write(app / "models.py", MODELS_PY)
    _write(app / "schemas.py", SCHEMAS_PY)
    busname = name.replace("-", "_")  # sanitize_proj: the bus ACL/topic prefix uses underscores
    _write(app / "main.py", MAIN_PY.replace("__NAME__", name))
    _write(app / "events.py", EVENTS_PY.replace("__BUSNAME__", busname).replace("__NAME__", name))
    _write(app / "ws.py", WS_PY.replace("__BUSNAME__", busname).replace("__NAME__", name))
    _write(app / "register.py", REGISTER_PY.replace("__BUSNAME__", busname).replace("__NAME__", name))
    _write(app / "routers" / "__init__.py", "")
    _write(app / "routers" / "health.py", HEALTH_ROUTER_PY)
    tests = target / "backend" / "tests"
    _write(tests / "__init__.py", "")
    _write(tests / "conftest.py", CONFTEST_PY)
    _write(tests / "test_health.py", TEST_HEALTH_PY)


def write_frontend_deltas(target, name, kind):
    """Overlay the compliant deltas onto the official `sv` scaffold (or stand alone offline).

    `with_api` kinds get the /api dev proxy + an onMount page that fetches /api; a `web` landing gets
    adapter-static + prerender + a plain page (no backend to call).
    """
    fe = target / "frontend"
    _write(fe / "vite.config.ts", VITE_CONFIG_TS)
    _write(fe / "src" / "app.css", APP_CSS)
    _write(fe / "src" / "routes" / "+layout.svelte", LAYOUT_SVELTE)
    # adapter-static + prerender for EVERY frontend: static HTML deploys with the playbook's
    # `shimpz_static build` (structured-log http.server replacement), best SEO/GEO, and a fullstack
    # page still fetches /api client-side (onMount).
    _write(fe / "src" / "routes" / "+layout.ts", LAYOUT_TS)
    _write(fe / "svelte.config.js", SVELTE_CONFIG_STATIC)
    page = PAGE_SVELTE_API if has_backend(kind) else PAGE_SVELTE_STATIC
    _write(
        fe / "src" / "routes" / "+page.svelte",
        page.replace("__PROJECT_NAME__", name),
    )
    if has_backend(kind):  # the realtime client pairs with the backend's ws gateway
        _write(fe / "src" / "lib" / "ws.ts", WS_TS)


def write_script(target, name):
    _write(target / "pyproject.toml", SCRIPT_PYPROJECT.format(name=name))
    _write(target / "main.py", SCRIPT_MAIN_PY.replace("__NAME__", name))


# The ONE declarative file every app ships (shimpzmanifest / docs/build-a-shimpz-app.md). Scaffolded with the
# app's identity + commented examples of the three dependency kinds, so declaring a dep is a one-liner.
MANIFEST_TOML = """\
# What this Shimpz app is and what it needs. The toolchain reads this: `shimpz-app deploy` resolves [needs]
# and the admin marketplace surfaces it. Full spec: docs/build-a-shimpz-app.md.
name = "{name}"
title = "{title}"
summary = ""

[needs]
# native = ["openai"]          # native integrations that must be ENABLED — see docs for the full list
# apps   = ["other-app"]       # other Shimpz apps this one needs — installed automatically so you REUSE them
# calls  = ["other-backend"]   # service APIs to reuse (sync) — wired as declared reach (--calls)
# egress = ["api.example.com"] # external hosts you may reach — apps have NO internet by default

{provides}# [grants]  — scoped permissions (ONLY ones the platform actually enforces; see docs).
# consume = ["other-app.topic"]   # READ another app's bus topic (a narrow, audited ACL)
# publish = "own"                  # may be published ONLY at {name}.grid.shimpz.com
# dns     = "own"                  # may manage DNS ONLY under {name}.grid.shimpz.com

# [billing]  — charge for this app (payment is locked to ShimpzPay; omit for a free app).
# pay = "shimpzpay"               # the ONLY accepted rail
# price = 9.90                     # per period, > 0
# period = "monthly"               # monthly | yearly | once

# [[run]]  — declare this to make `shimpz-app install {name}` deploy the whole app (+ its deps) in one command.
# name = "{name}-backend"
# port = 3101
# command = ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3101"]

[config]
# GREETING = {{ default = "Hi", help = "Shown to end users" }}   # your app's OWN settings (UPPER_SNAKE)
"""


def write_manifest(target, name, kind):
    """Emit the starter `shimpz.app.toml` — the single file that declares the app's identity + dependencies."""
    title = name.replace("-", " ").title()
    if kind in ("fullstack", "api"):  # apps with a backend the agent can orchestrate → ship a skill by default
        provides = '[provides]\nskill = "shimpz/SKILL.md"       # agent-facing skill this app ships (scaffolded)\n\n'
    else:
        provides = '# [provides]\n# skill = "shimpz/SKILL.md"     # ship a skill so the agent orchestrates this app\n\n'
    _write(target / "shimpz.app.toml", MANIFEST_TOML.format(name=name, title=title, provides=provides))


SKILL_MD = '''\
---
name: {name}
description: >-
  Operate the {title} app by calling its API — never reimplement its logic. Triggers on {name},
  {title}. AUTHOR: sharpen this so the agent knows exactly when to reach for this app.
---

# {title}

This app runs as the `{name}-backend` service. **Orchestrate it by calling its HTTP API** (reuse over
reimplementation) — the running app already guarantees the functionality and its business rules:

    from shimpzbus import call
    result = call("{name}-backend", "/your/route", "POST", json_body={{}})

## Operations

<!-- AUTHOR: list each named operation the agent should use, with inputs/outputs. e.g.
### Create a campaign
`POST /campaigns` {{name, budget}} -> {{id}} — creates a paused campaign; call /campaigns/{{id}}/launch to go live. -->

## Business rules

<!-- AUTHOR: the rules the agent MUST respect when orchestrating this app (limits, approvals, ordering). -->
'''


def write_skill(target, name, kind):
    """Scaffold a starter agent-facing skill (`shimpz/SKILL.md`) for apps with a backend.

    The author fills its named operations + business rules so the agent orchestrates this app via
    `shimpzbus.call` instead of ad-hoc code — installed into the brain on `shimpz-app deploy` ([provides]).
    """
    if kind not in ("fullstack", "api"):
        return
    title = name.replace("-", " ").title()
    _write(target / "shimpz" / "SKILL.md", SKILL_MD.format(name=name, title=title))


def write_sources(target, name, kind):
    """Write the files shimpz-new fully owns (common + backend).

    PURE: no network. The FRONTEND deltas are written separately — AFTER the official `sv create`
    online (so it gets an empty dir), or directly in the offline branch — because pre-populating
    frontend/ would make `sv create` prompt on a non-empty dir.
    """
    _write(target / ".gitignore", GITIGNORE)
    _write(target / ".env.example", ENV_EXAMPLE)
    _write(
        target / "README.md",
        f"# {name}\n\nScaffolded by shimpz-new ({kind}).\n",
    )
    if has_backend(kind):  # any Python project → the standards gate config
        _write(target / "ruff.toml", RUFF_TOML)
    if kind == "script":
        write_script(target, name)
        return
    if has_backend(kind):
        write_backend(target, name)


# ── toolchain phase (container only) ─────────────────────────────────────────────────────────────
def _run(cmd, cwd):
    """Fail-fast: surface the command and crash on non-zero (no fallback that hides a broken scaffold)."""
    print("· {}".format(" ".join(cmd)))
    subprocess.run(cmd, cwd=cwd, check=True)


def _extract_dsn(out):
    """Pull the DSN from `shimpz-db create` output.

    The ONLY producer is shimpz-db, which prints exactly `DATABASE_URL=<dsn>` — so this is a strict
    prefix match, not a speculative URL scan (fail-fast doctrine: parse the contract; if the
    contract breaks, return None so the caller raises loudly instead of guessing at a URL).
    """
    for ln in out.splitlines():
        if ln.startswith("DATABASE_URL="):
            return ln.removeprefix("DATABASE_URL=")
    return None


def _extract_bus_creds(out):
    """Pull the SASL identity from `shimpz-bus provision` output.

    The ONLY producer is shimpz-bus, which prints exactly the 3 `SHIMPZ_BUS_SASL_*=` lines documented in
    its own `cmd_provision` — same narrow-contract, fail-fast doctrine as `_extract_dsn`: anything
    less than all 3 keys returns None so the caller raises instead of deploying with a partial/no
    identity (shimpz-app's own deploy-time allowlist expects exactly these 3 keys, see shimpz-app's
    `_deploy_envjson`).
    """
    keys = ("SHIMPZ_BUS_SASL_USERNAME", "SHIMPZ_BUS_SASL_PASSWORD", "SHIMPZ_BUS_SASL_MECHANISM")
    creds = {}
    for ln in out.splitlines():
        for k in keys:
            if ln.startswith(k + "="):
                creds[k] = ln.removeprefix(k + "=")
    return creds if all(k in creds for k in keys) else None


def _strip_nested_git(fe):
    """The official scaffold may drop its own .git — there must be exactly ONE repo, at the project root.

    Remove a nested one; a removal failure raises loudly (fail-fast, never a soft path).
    """
    nested = Path(fe) / ".git"
    if nested.is_dir():
        shutil.rmtree(nested)


def toolchain(target, name, kind):
    # Real external execution: node/uv/pnpm/`sv`/Postgres. There are NO mocks anywhere — this is
    # exercised for real by tests/test-shimpz-new-live.py (SHIMPZ_NEW_LIVE=1) inside the shimpz-brain container,
    # which is the ONLY place these tools exist. No fakes ever stand in for these CLIs.
    if has_backend(kind):
        be = target / "backend" if kind != "script" else target
        _run(["uv", "sync"], be)
        if kind != "script":
            _run(["uv", "run", "alembic", "init", "alembic"], be)
    if has_frontend(kind):
        fe = target / "frontend"
        fe.mkdir(parents=True, exist_ok=True)  # empty dir → sv create won't prompt
        # official scaffold (guaranteed-building package.json/config), fully non-interactive
        _run(
            [
                "pnpm",
                "dlx",
                "sv",
                "create",
                ".",
                "--template",
                "minimal",
                "--types",
                "ts",
                "--no-add-ons",
                "--no-dir-check",
                "--no-download-check",
                "--install",
                "pnpm",
            ],
            fe,
        )
        # Tailwind v4 + static adapter deps directly (deterministic — no `sv add` prompts); deltas wire them
        _run(
            [
                "pnpm",
                "add",
                "-D",
                "tailwindcss",
                "@tailwindcss/vite",
                "@sveltejs/adapter-static",
            ],
            fe,
        )
        write_frontend_deltas(target, name, kind)  # overlay AFTER sv create
        _strip_nested_git(fe)
    # generated secret + (for backend-with-DB kinds) an isolated Postgres DB → .env (gitignored). Only a
    # real backend-with-persistence (fullstack/api) gets a DB — a frontend-only landing (web) or a
    # throwaway script does NOT (the playbook: "No DB unless it persists"; SQLite for throwaway).
    secret = secrets.token_urlsafe(48)
    if kind in ("fullstack", "api"):
        out = subprocess.run(["shimpz-db", "create", name], capture_output=True, text=True, check=True).stdout
        dsn = _extract_dsn(out)
        if not dsn:
            raise RuntimeError(f"shimpz-db create returned no DSN (got {out!r})")
        # every fullstack/api scaffold's app/events.py imports shimpzbus (write_backend, unconditional
        # for these two kinds) — without a provisioned SASL identity here, notify()/shimpzbus.stream()
        # fail loudly against the real SASL-enabled broker the moment the app actually runs.
        bus_out = subprocess.run(["shimpz-bus", "provision", name], capture_output=True, text=True, check=True).stdout
        bus_creds = _extract_bus_creds(bus_out)
        if not bus_creds:
            raise RuntimeError(f"shimpz-bus provision returned no SASL creds (got {bus_out!r})")
        write_env(target, secret, dsn, bus_creds)
    else:
        write_env(target, secret)


def write_env(target, secret, db_url=None, bus_creds=None):
    lines = [f"DATABASE_URL={db_url}"] if db_url else []
    if bus_creds:
        lines += [f"{k}={v}" for k, v in bus_creds.items()]
    lines += [f"SECRET_KEY={secret}"]
    _write(target / ".env", "\n".join(lines) + "\n")


def main(argv):
    if not argv or argv[0] in ("-h", "--help"):
        print("usage: shimpz-new <name> [{}]   (default: fullstack)".format("|".join(KINDS)))
        return 0
    proot = os.environ.get("SHIMPZ_PROJECTS_DIR", "/config/workspace/projects")
    name = validate_name(argv[0])  # raises → caught in __main__ → exit 2
    kind = argv[1] if len(argv) > 1 else "fullstack"
    if kind not in KINDS:
        raise ValueError("kind must be one of {} (got {!r})".format(", ".join(KINDS), kind))

    # `name` is the sole, fully-tested safety boundary: a strict slug (NAME_RE) cannot contain '/',
    # '.', '..' or a newline, so Path(proot) / name provably stays inside proot.
    target = Path(proot) / name
    if target.exists():
        raise FileExistsError(f"project already exists: {target} (refusing to overwrite)")

    target.mkdir(parents=True)
    try:
        write_sources(target, name, kind)
        write_manifest(target, name, kind)  # the shimpz.app.toml standard — every app ships one
        write_skill(target, name, kind)  # a starter agent-facing skill (shimpz/SKILL.md) for backend apps ([provides])
        toolchain(target, name, kind)  # real CLIs only — never mocked (live test covers it)
    except BaseException:
        # a half-built dir would wedge every re-run on FileExistsError. We created `target` fresh this
        # run, so remove it on ANY failure → a transient uv/pnpm hiccup stays retryable. Then re-raise.
        shutil.rmtree(target, ignore_errors=True)
        raise
    print(f"✅ {name} ({kind}) scaffolded at {target}")
    _print_registry_nudge()
    return 0


def _print_registry_nudge():
    """List registered services at scaffold time — the reuse decision happens NOW, not at deploy.

    Consume-don't-rebuild is the enforced law (deploy judge criterion 4b): surfacing what already
    exists at the exact moment a new project is born is the cheapest way to make reuse the path
    of least resistance. Unreadable manifests are surfaced, never skipped silently.
    """
    reg = Path(os.environ.get("SHIMPZ_REGISTRY", "/config/workspace/registry"))
    manifests = sorted(reg.glob("*.json")) if reg.is_dir() else []
    if not manifests:
        return
    print("ℹ️  registered services — CONSUME these, don't rebuild them (details: shimpz-bus discover <kw>):")
    for m in manifests:
        try:
            d = json.loads(m.read_text())
        except ValueError as e:
            print(f"   • {m.name}: UNREADABLE manifest ({e}) — fix the registry entry")
            continue
        tag = " [internal]" if d.get("internal") else ""
        topics = ",".join(d.get("publishes") or []) or "-"
        print(f"   • {d.get('name')}{tag} — {d.get('description', '')} (publishes: {topics})")


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except (ValueError, FileExistsError) as e:
        sys.stderr.write(f"shimpz-new: {e}\n")
        sys.exit(2)
    except subprocess.CalledProcessError as e:
        sys.stderr.write(f"shimpz-new: toolchain step failed ({e}) — scaffold is incomplete, not masking it\n")
        sys.exit(1)
    except RuntimeError as e:  # e.g. shimpz-db returned no DSN — surface, don't mask
        sys.stderr.write(f"shimpz-new: {e} — scaffold is incomplete, not masking it\n")
        sys.exit(1)
