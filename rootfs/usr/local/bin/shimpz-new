from app.routers import health

setup("__NAME__")
log = structlog.get_logger()

# Same-origin: the frontend calls /api/... and Caddy (shimpz-publish) routes it here — so NO CORS needed.
app = FastAPI(title="__NAME__")
app.add_middleware(TraceIdMiddleware)
app.include_router(health.router, prefix="/api")
log.info("startup", title="__NAME__")


@app.exception_handler(Exception)
async def unhandled_exception(request: Request, exc: Exception) -> JSONResponse:
    # Fail-loud: log the FULL structured stack trace (dict_tracebacks); never swallow. The caller gets a
    # generic 500 — details live in the logs, not the response body.
    log.exception("unhandled_exception", path=request.url.path, method=request.method)
    return JSONResponse(status_code=500, content={"detail": "internal server error"})
"""

SCRIPT_MAIN_PY = """\
