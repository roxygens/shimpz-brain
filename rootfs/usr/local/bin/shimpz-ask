#!/opt/venv/bin/python
"""shimpz-ask — ask Juliano a question with preset choices (Telegram buttons) + a "type your own" option.

BLOCKS until he answers. Returns the chosen/typed answer on stdout.

  ans=$(shimpz-ask "Public or private?" "🌐 Public" "🔒 Private")
  ans=$(shimpz-ask --default 1 "Which tone?" "Direct" "Playful")   # timeout → picks option 1

Use this whenever there's a REAL decision (scope, public/private, which domain, which port,
deploy, spend) — ask first, don't assume. Put your RECOMMENDED option FIRST: the gateway stars it
(⭐) so it can be tapped without reading twice. `--default N` (1-based) makes a timeout PICK that
option instead of failing, so a good question never strands the task — NEVER use it for
spend/publish/outward decisions (those must wait for a real answer).
exit 2 = timeout with no default (then DON'T proceed).
"""

import argparse
import os
import sys

sys.path.insert(0, "/opt/shimpz-lib")
import shimpzipc  # single source of truth for the $SHIMPZ_HOME/ipc request/response protocol

ap = argparse.ArgumentParser(prog="shimpz-ask", description="ask Juliano a question via Telegram buttons")
ap.add_argument("question")
ap.add_argument("options", nargs="*")
ap.add_argument(
    "--default",
    type=int,
    default=None,
    metavar="N",
    help="1-based option returned when the question times out (never for spend/publish decisions)",
)
a = ap.parse_args()
# The gateway renders at most 8 buttons (and stars/discloses the default only within them), so a
# default pointing past that cap would be auto-committed WITHOUT ever being shown or announced on
# the card — reject it here, mirroring the gateway's own truncation guard.
RENDER_CAP = 8
if a.default is not None and not (a.options and 1 <= a.default <= min(len(a.options), RENDER_CAP)):
    print(
        f"--default must be the 1-based index of a RENDERED option (first {RENDER_CAP}; the "
        "Telegram card shows at most that many buttons)",
        file=sys.stderr,
    )
    sys.exit(2)
timeout = int(os.environ.get("SHIMPZ_ASK_TIMEOUT", "600"))

# `timeout` rides along so the gateway card can say when the ⭐ default kicks in.
payload = {"type": "ask", "text": a.question, "options": a.options, "timeout": timeout}
if a.default is not None:
    payload["default"] = a.default
_, ans = shimpzipc.request(payload, timeout, "answer")
if ans is not None:
    print(ans)
    sys.exit(0)
if a.default is not None:
    print(f"(no answer in {timeout}s — proceeding with the starred default)", file=sys.stderr)
    print(a.options[a.default - 1])
    sys.exit(0)
print("NO ANSWER (timeout) — do NOT proceed; ask again.", file=sys.stderr)
sys.exit(2)
