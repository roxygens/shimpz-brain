#!/opt/venv/bin/python
"""UserPromptSubmit hook — MANDATORY memory recall, INDEX-FIRST (scales for years).

Claude Code runs this before it sees the prompt; what we emit is injected deterministically.
Long-term design: the memory INDEX is generated from the filesystem (filenames + frontmatter
`triggers`), NOT a hand-maintained MEMORY.md that bloats. We inject:
  1) a compact CATALOG (one line per playbook/fact) so the brain SEES what already exists and
     REFINES instead of duplicating — even for slugs it didn't match;
  2) an excerpt of only the top few matches (cheap: metadata scan, then load winners).
Ranking is HYBRID (R121): keyword counts (exact names/commands) fused with LOCAL semantic
similarity via shimpz-lib/shimpzemb (paraphrase + cross-language, where substring counting misses —
the store is PT/EN mixed). Files stay the truth; embeddings only rank. A semantic failure
degrades to keyword-only, loudly. This stays bounded no matter how many files accumulate.

Fires only on a FRESH session (gateway sets SHIMPZ_SESSION_FRESH); resumed turns skip it.
"""

import json
import logging
import os
import re
import sys
import time
from pathlib import Path

sys.path.insert(0, "/opt/shimpz-lib")
import shimpzemb  # heavy deps (numpy/model2vec) load lazily INSIDE it — import is host-safe

log = logging.getLogger("shimpz-recall")

# MEM stays a str on purpose: it is injected verbatim into the emitted guidance text,
# and the test harness reassigns it with a str at runtime.
MEM = os.environ.get("SHIMPZ_MEMORY_DIR", "/config/.shimpz/memory")
MAX_BODIES = int(os.environ.get("SHIMPZ_RECALL_HITS", "3"))  # winning files to load
CATALOG_MAX = int(os.environ.get("SHIMPZ_CATALOG_MAX", "120"))  # catalog lines injected
CATALOG_MAX_CHARS = 2500  # char budget for the catalog section (so bodies always get their share)
MAX_TOTAL = 8000  # hard cap on injected memory (bodies)
# Cosine floor for a semantic hit — calibrated on THIS store (R121 spike): irrelevant chatter
# peaks ~0.37, real matches sit 0.45+. Below the floor, semantic contributes nothing (keyword
# can still hit) — cosine is never zero, so an unfloored ranking would inject noise on every turn.
SEM_FLOOR = float(os.environ.get("SHIMPZ_SEM_FLOOR", "0.40"))
HIT_FULL = 2500  # a winning file this small is injected WHOLE
HEAD_CAP = 900  # otherwise: this much of its head (title/frontmatter orientation)…
SECTION_CAP = 1600  # …plus this much of the section the query actually matched

# Per-project memory: ONE file per project (memory/projects/<slug>.md), resolved DETERMINISTICALLY
# by matching the prompt against known project dirs — never ranked/guessed like the global pool
# below, because there's exactly one legal file per project (see memory/MEMORY.md).
PROJECTS_DIR = Path(os.environ.get("SHIMPZ_PROJECTS_DIR", "/config/workspace/projects"))
PROJECT_MAX_CHARS = 4000  # safety cap on one project's body — not a tuned budget, just a ceiling
# The unnamed-prompt fallback (inject the LAST project touched) only fires for a genuine follow-up —
# a marker older than this is a stale project that must not be dumped into every quick question.
LAST_PROJECT_TTL = int(os.environ.get("SHIMPZ_LAST_PROJECT_TTL", "1800"))  # seconds

STOP = {
    "a",
    "o",
    "os",
    "as",
    "um",
    "uma",
    "de",
    "do",
    "da",
    "das",
    "dos",
    "no",
    "na",
    "nos",
    "nas",
    "em",
    "e",
    "ou",
    "que",
    "se",
    "por",
    "para",
    "com",
    "sem",
    "ao",
    "aos",
    "à",
    "às",
    "pra",
    "pro",
    "como",
    "qual",
    "quais",
    "quando",
    "onde",
    "isso",
    "isto",
    "esse",
    "essa",
    "este",
    "esta",
    "the",
    "and",
    "for",
    "you",
    "your",
    "please",
    "me",
    "my",
    "i",
    "it",
    "is",
    "to",
    "of",
    "in",
    "on",
    "at",
    "does",
    "can",
    "could",
    "would",
    "should",
}


def emit(ctx):
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "UserPromptSubmit",
                    # room for the header/footer + the budgeted catalog + the bodies (MAX_TOTAL) + one
                    # project file — so the final slice never silently eats content earlier sections protected.
                    "additionalContext": ctx[: MAX_TOTAL + CATALOG_MAX_CHARS + PROJECT_MAX_CHARS + 1500],
                }
            }
        )
    )
    sys.exit(0)


def _files():
    return sorted([*Path(MEM, "playbooks").glob("*.md"), *Path(MEM, "facts").glob("*.md")])


def _project_slugs():
    """Known project names — from the actual workspace dirs, never guessed."""
    if not PROJECTS_DIR.is_dir():
        return []
    return sorted(d.name for d in PROJECTS_DIR.iterdir() if d.is_dir() and not d.name.startswith("."))


def _match_projects(kw, slugs):
    """Slugs whose dash/underscore-split words ALL appear among the prompt's keywords.

    A closed, small vocabulary (the actual project dirs) beats fuzzy scoring here — no tokenizer
    tuning, no ties to break, just an exact membership check per slug.
    """
    kwset = set(kw)
    hits = []
    for slug in slugs:
        parts = [p for p in re.split(r"[-_]+", slug.lower()) if len(p) >= 3]
        if parts and all(p in kwset for p in parts):
            hits.append(slug)
    return hits


def _last_project(slugs):
    """Fallback when the prompt doesn't name a project: the last one shimpz-project-sync touched.

    Covers the common case a session rotation loses otherwise — a follow-up message ("continua o
    deploy") that doesn't restate the project name, right after the conversation went fresh. Gated on
    RECENCY: only a marker touched within LAST_PROJECT_TTL is trusted as a real follow-up. A stale one
    (hours/days old) must NOT inject an unrelated project dossier into every quick question — that's
    pure noise; past the TTL the fallback goes quiet and recall relies on naming + the catalog.
    """
    marker = Path(MEM) / ".last-project"
    try:
        slug = marker.read_text(encoding="utf-8").strip()
        age = time.time() - marker.stat().st_mtime
    except OSError:
        return None
    if age > LAST_PROJECT_TTL:
        return None
    return slug if slug in slugs else None


def resolve_projects(kw):
    """Which project file(s) (if any) this turn's memory should include, in full."""
    slugs = _project_slugs()
    if not slugs:
        return []
    hits = _match_projects(kw, slugs)
    if hits:
        return hits
    last = _last_project(slugs)
    return [last] if last else []


def _project_sections(kw):
    """One '## Project memory: <slug>' chunk per resolved project, full body.

    Only bounded by the PROJECT_MAX_CHARS safety cap, never truncated by a ranking budget — there's
    exactly one legal file per project to load.
    """
    sections = []
    for slug in resolve_projects(kw):
        try:
            body = (Path(MEM) / "projects" / f"{slug}.md").read_text(encoding="utf-8", errors="ignore").strip()
        except OSError:
            continue
        if body:
            sections.append(f"\n## Project memory: {slug}\n{body[:PROJECT_MAX_CHARS]}")
    return sections


def _meta(path):
    """(triggers, one-line summary) from a topic file's head — cheap, reads ~1.6KB."""
    try:
        with Path(path).open(encoding="utf-8", errors="ignore") as fh:
            head = fh.read(1600)
    except OSError:
        return "", ""
    fm, body = "", head
    if head.startswith("---"):
        parts = head.split("---", 2)
        if len(parts) >= 3:
            fm, body = parts[1], parts[2]
    trig = ""
    for ln in fm.splitlines():
        if ln.lower().strip().startswith("triggers:"):
            trig = ln.split(":", 1)[1].strip()
    summ = ""
    for ln in body.splitlines():
        s = ln.strip().lstrip("#").strip()
        if s:
            summ = s[:110]
            break
    return trig, summ


def get_catalog():
    """[(relpath, triggers, summary)] — scanned fresh every run (≤~120 small files: milliseconds, no cache)."""
    return [(str(f.relative_to(MEM)), *_meta(f)) for f in _files()]


def _keywords(prompt):
    r"""Distinct, deduped keywords from the prompt, tokenized with \w (Unicode-aware for str patterns).

    That means this tokenizes ANY language (café, niño, über, domínio) — the old hand-listed
    Portuguese accent class over-split every OTHER accented word (niño→ni,o). Drops STOP words and
    tokens under 3 chars, caps 25.
    """
    return list(dict.fromkeys(w for w in re.findall(r"\w+", (prompt or "").lower()) if len(w) >= 3 and w not in STOP))[
        :25
    ]


def _rank(rows, kw, sem):
    """Fuse the keyword ranking with the semantic one (RRF) and return (ranked, hits).

    Keyword score = substring count over relpath+triggers+summary (exact names/commands; the sort
    key is the score ALONE, so a tie keeps the rows' original order — stable sort). Semantic =
    best-section cosine ≥ SEM_FLOOR (paraphrase/cross-language, where counting misses). RRF is
    scale-free, so neither ranker needs weight tuning and a file ranked by BOTH beats a single-list
    topper. hits = top MAX_BODIES fused rows; rows matched by NEITHER ranker are never hits but
    stay in the returned catalog order.
    """

    def score(row):
        hay = (row[0] + " " + row[1] + " " + row[2]).lower()
        return sum(hay.count(w) for w in kw)

    scored = sorted(((score(r), r) for r in rows), key=lambda t: t[0], reverse=True)
    kw_ranked = [r[0] for sc, r in scored if sc > 0]
    by_cos = sorted(sem.items(), key=lambda t: t[1][0], reverse=True)
    sem_ranked = [rel for rel, (sc, _sec) in by_cos if sc >= SEM_FLOOR]
    fused = shimpzemb.rrf_fuse([kw_ranked, sem_ranked])
    by_rel = {r[0]: r for r in rows}
    hit_rels = [rel for rel in sorted(fused, key=fused.get, reverse=True) if rel in by_rel][:MAX_BODIES]
    hits = [by_rel[rel] for rel in hit_rels]
    ranked = hits + [r for _sc, r in scored if r[0] not in set(hit_rels)]
    return ranked, hits


def _semantic(kw):
    """Semantic scores for the store files, or {} when the layer can't run (keyword-only turn).

    Embeds the CONTENT WORDS (the _keywords list), not the raw sentence: the model is a mean-pooled
    static embedding, so stopword-heavy conversational phrasing drifts toward a generic-prose
    centroid and inflates noise similarities (measured live: ~0.44 raw vs ~0.38 keyword-stripped on
    the same off-topic query, while real matches stay put — that gap is what keeps SEM_FLOOR honest).
    Failure is non-fatal by contract (recall must never block the prompt) but LOUD: a silently
    dead semantic layer would quietly regress recall to substring matching.
    """
    if not kw:
        return {}
    try:
        rels = [str(f.relative_to(MEM)) for f in _files()]
        return shimpzemb.semantic_scores(" ".join(kw), MEM, rels)
    except Exception:  # fail-open: ranking must never kill the hook (logged, not silent)
        log.exception("semantic recall unavailable — keyword-only this turn")
        return {}


def _excerpt(rel, body, sem):
    """The injected view of ONE winning file: head + best-matching section + a Read pointer.

    Replaces the old flat body[:1100], which handed the model 2% of a long playbook under a
    'FOLLOW this' header. A file that fits goes in whole; a long one gets oriented (its head),
    targeted (the section the query actually matched), and told where the rest lives — the model
    Reads the full file when it's about to execute the procedure.
    """
    if len(body) <= HIT_FULL:
        return body
    sections = shimpzemb.chunk_sections(body)
    sec_i = sem.get(rel, (0.0, 0))[1]
    parts = [sections[0][:HEAD_CAP] if sections else body[:HEAD_CAP]]
    if 0 < sec_i < len(sections):
        parts.append(sections[sec_i][:SECTION_CAP])
    return "\n[…]\n".join(parts) + f"\n(→ full playbook: Read {MEM}/{rel})"


def main():
    if os.environ.get("SHIMPZ_SESSION_FRESH", "1") == "0":
        sys.exit(0)
    try:
        data = json.load(sys.stdin)
    except json.JSONDecodeError, OSError:
        data = {}
    kw = _keywords(data.get("user_input") or data.get("prompt") or "")
    rows = get_catalog()
    sem = _semantic(kw)
    ranked, hits = _rank(rows, kw, sem)

    parts = [
        "📓 Memory (consult BEFORE acting; if a playbook exists, FOLLOW/REFINE it — don't duplicate):",
        "",
    ]

    # 0) project memory FIRST — the single most relevant thing recall can hand back, so it goes
    #    before the global catalog and is never the part that gets truncated. Deterministic (which
    #    project this is), not ranked (there's exactly one legal file — see memory/MEMORY.md).
    parts.extend(_project_sections(kw))

    # 1) catalog — bounded by BOTH a line cap (CATALOG_MAX) AND a char budget (CATALOG_MAX_CHARS). The
    #    char budget is load-bearing: without it, at ~30+ memory files the catalog alone exceeds the
    #    emit() truncation window and the top-match BODIES below (the whole point of index-first recall)
    #    get sliced off the end. Budgeting the catalog guarantees the bodies always get their share.
    if rows:
        shown = ranked[:CATALOG_MAX] if len(rows) > CATALOG_MAX else sorted(rows)
        parts.append("## Catalog of what already exists")
        cat_used, cat_shown = 0, 0
        for rel, tr, summ in shown:
            line = f"- {rel}"
            if tr:
                line += f" — triggers: {tr}"
            if summ:
                line += f" — {summ}"
            if cat_used + len(line) > CATALOG_MAX_CHARS:
                break
            parts.append(line)
            cat_used += len(line) + 1  # +1 for the join newline
            cat_shown += 1
        omitted = len(rows) - cat_shown
        if omitted > 0:
            parts.append(f"(+{omitted} more; when saving, REFINE the existing one instead of creating new)")
    else:
        parts.append("(memory empty — if you learn something reusable, save it when done)")

    # 2) full bodies of only the top matches (index-first: load just the winners) — hits from _rank()
    acc = []
    if hits:
        parts.append("\n## Most relevant to this task")
        used = 0
        for rel, _tr, _summ in hits:
            f = Path(MEM) / rel
            try:
                body = f.read_text(encoding="utf-8", errors="ignore").strip()
            except OSError:
                continue
            chunk = f"\n### {rel}\n{_excerpt(rel, body, sem)}"
            if used + len(chunk) > MAX_TOTAL:
                break
            parts.append(chunk)
            used += len(chunk)
            acc.append(rel)
        try:
            with (Path(MEM) / ".access.log").open("a", encoding="utf-8") as a:
                ts = int(time.time())
                for rel in acc:
                    a.write(f"{ts}\t{rel}\n")
        except OSError as e:
            log.warning("could not append to access log: %s", e)

    parts.append(
        f'\n— Need more? `grep -ril "<word>" {MEM}` then Read. '
        "Project-specific learning → ONE file, projects/<slug>.md (refine it, never a second one). "
        "Cross-project convention → refine the existing playbook/fact above, don't duplicate."
    )
    emit("\n".join(parts))


if __name__ == "__main__":
    try:
        main()
    except Exception:  # fail-open: UserPromptSubmit hook must never block the prompt (logged, not silent)
        log.exception("shimpz-recall failed; injecting no memory this turn")
        sys.exit(0)
