#!/opt/venv/bin/python
"""shimpz-installer — install Shimpz store apps on request, owner-approved (the store→brain bridge).

The store (shimpz.com) is a PUBLIC, isolated app: when someone clicks Install it publishes {app} to the
`shimpz.install` bus topic. This worker runs in the BRAIN — the only place with `shimpz-app` + the
driver token — consumes each request, and because the store is public it asks the OWNER to approve
via Telegram (the auth gate: a stranger's click just prompts a deny), then runs `shimpz-app install <app>`
(further gated by the deploy security chain). The result goes to `shimpz.install.done` so the store can
show status. Supervised respawn from the brain's autostart (never cron).
"""

import os
import re
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, "/opt/shimpz-lib")
import shimpzbus

SLUG_RE = re.compile(r"[a-z][a-z0-9]*(-[a-z0-9]+)*\Z")
PROJECTS = Path(os.environ.get("SHIMPZ_PROJECTS_DIR", "/config/workspace/projects"))


def _installable(app: str) -> bool:
    """A real, installable workspace app: a valid slug with a `shimpz.app.toml` (never an arbitrary name)."""
    return bool(SLUG_RE.match(app)) and (PROJECTS / app / "shimpz.app.toml").is_file()


def handle_install(event, run=subprocess.run, approve=None, publish=shimpzbus.publish):
    """Approve + install ONE request; report to shimpz.install.done.

    `run`/`approve`/`publish` are injected so tests never shell out or spawn a real approval/model.
    """
    app = str(event.get("app", ""))

    def done(status, **extra):
        publish("shimpz.install.done", {"app": app, "status": status, **extra})

    if not _installable(app):
        done("rejected", reason="unknown or non-installable app")
        return
    approve = approve or (lambda msg: run(["shimpz-approve", msg]).returncode == 0)
    if not approve(f"Shimpz: install '{app}' into your Shimpz?"):
        done("denied")
        return
    r = run(["shimpz-app", "install", app], capture_output=True, text=True)
    if getattr(r, "returncode", 1) == 0:
        done("installed", domain=f"{app}.grid.shimpz.com")
    else:
        done("failed", detail=(getattr(r, "stderr", "") or getattr(r, "stdout", ""))[-400:])


def main():
    shimpzbus.run_worker(
        "shimpz.install", handle_install, group="shimpz-installer", publishes=["shimpz.install.done"]
    )


if __name__ == "__main__":
    main()
