#!/opt/venv/bin/python
"""uiupload <absolute-path> [title-regex] — completes a NATIVE file dialog over browser-agent.

Completes a NATIVE file dialog (GTK/Qt: "Open File", "Save File", etc.) with REAL EVENTS via
XTEST. The dialog itself and the file live in the `shimpz-browser` container now — this sends the
file's BYTES to browser-agent's /v1/browser/upload (mode=native), which writes them to an
ephemeral temp path there, completes the dialog, and discards the temp file.

Usage: the site opens the picker; run `uiupload /config/workspace/logo.png`.
"""

import os
import sys
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzbrowser  # shared browser-agent HTTP client (see /opt/shimpz-lib/shimpzbrowser.py)


def main() -> None:
    if len(sys.argv) < 2:
        sys.exit("usage: uiupload <absolute-path> [title-regex]")
    path = sys.argv[1]
    title_regex = sys.argv[2] if len(sys.argv) > 2 else None
    if not Path(path).exists():
        sys.exit(f"ERROR: file does not exist: {path}")

    body = {"mode": "native", "filename": Path(path).name, "file_bytes": shimpzbrowser.b64_file(path)}
    if title_regex:
        body["title_regex"] = title_regex
    try:
        result = shimpzbrowser.call_json("POST", "/v1/browser/upload", body)
    except shimpzbrowser.BrowserAgentError as exc:
        sys.exit(
            f"ERROR: {exc}\nIf the dialog is still open, take a shimpz-shot to see the Open button "
            "and click with 'uiclick <x> <y>'."
        )
    print(f"OK: {result['detail']}.")


if __name__ == "__main__":
    main()
