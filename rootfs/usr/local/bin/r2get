#!/opt/venv/bin/python
"""r2get <key> [dest] — download an object from R2 for local use.

  r2get uploads/2026/07/04/report.pdf
  r2get backup/data.csv /config/workspace/data.csv

Without a dest, it lands in /config/workspace/downloads/<name>.

SECURITY_ENGINEERING_PLAN.md item 7: the download runs in the `r2-driver` container (which holds
the R2 secret); this streams the bytes back from its restricted API (shimpzr2) and writes them locally.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzr2  # shared r2-driver HTTP client (see /opt/shimpz-lib/shimpzr2.py)


def _human(n: int) -> str:
    size = float(n)
    for unit in ("B", "K", "M", "G"):
        if size < 1024 or unit == "G":
            return f"{size:.0f}{unit}" if unit == "B" else f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}G"


def main() -> None:
    if len(sys.argv) < 2:
        sys.exit("usage: r2get <key-in-bucket> [dest]")
    key = sys.argv[1]
    dest = Path(sys.argv[2]) if len(sys.argv) > 2 else Path("/config/workspace/downloads") / Path(key).name
    dest.parent.mkdir(parents=True, exist_ok=True)
    try:
        n = shimpzr2.download(key, str(dest))
    except shimpzr2.R2DriverError as exc:
        sys.exit(f"ERROR on download: {exc}")
    print(f"downloaded: {dest}  ({_human(n)})")


if __name__ == "__main__":
    main()
