#!/opt/venv/bin/python
"""shimpz-stdcheck — deterministic ecosystem-standard validator for a Shimpz project.

Greps a project under /config/workspace/projects/<name> for HIGH-CONFIDENCE violations of the
NON-NEGOTIABLE stack rules — specifically the ones a scaffolder lays down correctly but that can
silently rot as the agent edits: a frontend that hardcodes the backend host (works in dev, BREAKS
the instant it's published), a credential-leaking CORS config, a committed .env, a placeholder
secret literal, a raw psycopg.connect bypassing SQLAlchemy, a connection hardcoded to the shared
infra DB, a competing queue/broker client instead of the bus, SQLite/shelve as a service's datastore
(the standard is one isolated Postgres DB per project), a backend calling another service directly by
its loopback app-port instead of the bus, create_all in a project that already runs alembic (a
schema-drift bug), and a standalone script written in bash/sh instead of Python.

Two tiers:
  BLOCK — a real defect or secret leak. exit code 2. The Stop gate (shimpz-stdgate) refuses to end the
          turn until it's gone.
  WARN  — a smell worth fixing but not worth blocking on. printed; does NOT affect the exit code.

DESIGN: pure + deterministic + fail-LOUD. No network, no model, no config. Every rule is a regex over
file text, so the verdict is reproducible and unit-testable (see tests/test-shimpz-stdcheck.py). The
rule set is deliberately TIGHT — a BLOCK must be a true violation, because a BLOCK stops the agent and
a gate that cries wolf is a gate that gets switched off. When unsure, a rule is WARN, not BLOCK.

Usage:
  shimpz-stdcheck <project-dir>     human report; exit 2 if any BLOCK, else 0
  shimpz-stdcheck --json <dir>      machine report: {"blocks":[...],"warns":[...]} ; same exit code
                                 (this is what shimpz-stdgate consumes each turn)
"""

import ast
import functools
import json
import os
import re
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
# /opt/shimpz-lib in-container; <repo>/rootfs/opt/shimpz-lib when the host suite loads this file.
sys.path.insert(0, str(HERE.parents[2] / "opt" / "shimpz-lib"))
import shimpzaudit

# Directories that are never our code (deps, build output, vcs) — skip them wholesale so a vendored
# file can't trip a rule and a huge node_modules can't slow the walk. Shared with shimpz-stdgate.
SKIP_DIRS = shimpzaudit.PROJECT_SKIP_DIRS

# The ONE sanctioned vendored source: scaffolds copy the shimpzbus lib into backend/vendor/shimpzbus so it
# resolves inside the app's own container (a brain path can't — apps mount only the project). The lib
# itself talks to Kafka, so scanning its internals would spray custom-broker/oversized-file findings.
# The dir is therefore ALWAYS pruned from the content walks, and instead verified WHOLESALE against
# the canonical in-image source: any divergence (a modified file, an extra file, a stale copy after a
# shimpzbus upgrade) is ONE dedicated BLOCK whose fix — re-vendor from the canonical path — also erases
# anything smuggled in there. No blanket trust: exemption is byte-identity or a BLOCK, never a shrug.
_SHIMPZBUS_CANON = HERE.parents[2] / "opt" / "shimpz-lib" / "shimpzbus"


def _is_vendored_shimpzbus(d):
    return d.name == "shimpzbus" and d.parent.name == "vendor" and d.is_dir()


@functools.cache
def _is_canonical_shimpzbus(d):
    """True iff every file under `d` byte-matches its counterpart in the canonical source (≥1 file)."""
    files = [p for p in d.rglob("*") if p.is_file()]
    if not files:
        return False
    for p in files:
        canon = _SHIMPZBUS_CANON / p.relative_to(d)
        try:
            if p.read_bytes() != canon.read_bytes():
                return False
        except OSError:  # no canonical counterpart (or unreadable) → NOT canonical
            return False
    return True


def _prune_dirs(dirpath, dirnames):
    """In-place os.walk prune: SKIP_DIRS by name + vendor/shimpzbus (verified separately by scan_vendored_shimpzbus)."""
    dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS and not _is_vendored_shimpzbus(Path(dirpath) / d)]


def scan_vendored_shimpzbus(root):
    """BLOCK: a vendor/shimpzbus tree that is NOT byte-identical to the canonical in-image source.

    The content walks never descend vendor/shimpzbus (see _prune_dirs) — this is the verification that
    makes that safe. One actionable finding instead of spraying the lib's internals with
    custom-broker findings; the fix command overwrites whatever diverged, malicious or stale.
    """
    root = Path(root)
    out = []
    for dirpath, dirnames, _files in os.walk(root):
        for d in list(dirnames):
            ap = Path(dirpath) / d
            if _is_vendored_shimpzbus(ap) and not _is_canonical_shimpzbus(ap):
                rel = os.path.relpath(ap, root)
                out.append(
                    (
                        "BLOCK",
                        "vendored-shimpzbus-divergent",
                        rel,
                        1,
                        "vendored shimpzbus differs from the canonical /opt/shimpz-lib/shimpzbus source "
                        "(modified, extra file, or stale after a shimpzbus upgrade)",
                        f"re-vendor it: rm -rf {rel} && cp -r /opt/shimpz-lib/shimpzbus {rel} "
                        "(then `uv lock` in that backend if the version changed) — never fork the lib in-project",
                    )
                )
        _prune_dirs(dirpath, dirnames)
    return out


FRONT_EXT = {".svelte", ".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"}
PY_EXT = {".py"}

# Max lines per file — forces the agent to MODULARIZE instead of dumping a giant do-everything file. No
# ruff or eslint rule covers module line-count (Pylint C0302 / ESLint max-lines exist but neither runs in
# this gate for both stacks), so this is the deterministic file-size enforcement for backend AND frontend.
MAX_FILE_LINES = 400

# A test file is allowed to do things app code must not: a throwaway schema (create_all), but ALSO a
# dummy password / a raw psycopg.connect / a localhost URL in a fixture or a CORS unit test. So a test
# file is exempt from EVERY content rule (see the guards in scan_*_text) — flagging a fixture's dummy
# secret would BLOCK the turn and drop the commit, the exact 'cry wolf' the gate must avoid. Matches
# the usual pytest/uv conventions plus JS/TS `*.test.ts` / `*.spec.ts` and e2e dirs.
TEST_RE = re.compile(
    r"(^|/)(tests?/|e2e/|__tests__/|test_[^/]*\.py$|[^/]*_test\.py$|conftest\.py$"
    r"|[^/]*\.(test|spec)\.[cm]?[tj]sx?$)"
)


def _is_test(rel):
    return bool(TEST_RE.search(rel))


# ── BLOCK rules ────────────────────────────────────────────────────────────────────────────────
# Each rule: a compiled regex + the file predicate it applies to + a one-line message and fix. We
# keep them as small pure helpers so every one is exercised by a unit test in isolation.

# Absolute localhost/loopback URL in FRONTEND code. A shipped frontend must call the API at a
# RELATIVE /api/... path; a hardcoded http://127.0.0.1:PORT (or localhost / 0.0.0.0 / IPv6 [::1])
# means the visitor's browser hits THEIR own machine once published. We match only loopback hosts on
# purpose: a genuine third-party absolute URL (Stripe.js, an external API) is legitimate and must NOT
# trip. IPv6 loopback in a URL is bracketed: http://[::1]:8000. The `localhost` label carries a
# right-boundary (?![\w.-]) so a real domain that merely STARTS with it — localhost.mycompany.internal,
# localhosting.dev — does NOT trip (a cry-wolf BLOCK). The IP branches need no such guard: 127.0.0.1 as a
# prefix of 127.0.0.100 is still loopback, so matching it is a true positive, not a false one.
HARDCODED_HOST_RE = re.compile(
    r"https?://(?:127\.0\.0\.1|0\.0\.0\.0|localhost(?![\w.-])|\[::1\])(?::\d+)?",
    re.IGNORECASE,
)

# allow_origins=[... "*" ...] (OR an allow_origin_regex that matches EVERYTHING) together with
# allow_credentials=True in the SAME file = a credential-leaking CORS config (the browser will send
# cookies/Authorization to any origin). Either alone is fine; a SPECIFIC origin regex is fine too.
# Starlette sets allow_all_origins = ("*" in allow_origins), so a "*" ANYWHERE in the list leaks —
# match a quoted "*" element anywhere inside the [...] (not just as the first element).
CORS_STAR_RE = re.compile(r"""allow_origins\s*=\s*\[[^\]]*['"]\*['"][^\]]*\]""")
CORS_CREDS_RE = re.compile(r"allow_credentials\s*=\s*True")
CORS_REGEX_RE = re.compile(r"""allow_origin_regex\s*=\s*(['"])(.*?)\1""")


def _regex_matches_all(val):
    r"""True for an allow_origin_regex that admits an OVER-BROAD set of origins — the genuine credential leak.

    Starlette fullmatches the pattern against the Origin. We look at the literal TAIL after the
    LAST unbounded wildcard (.* / .+):
      • empty tail   → '.*' / 'https://.*' / '.*\..*'  → admits every origin            → LEAK
      • glued label  → '.*example\.com' (no '\.' gap)  → admits evilEXAMPLE.com          → LEAK
      • single label → '.*\.com' (a bare TLD)          → admits every domain on that TLD → LEAK
      • ≥2 labels    → '.*\.example\.com'             → bounded to a trusted domain     → intentional
    The single-label TLD bound is the subtle one: 'https://.*\.com' still lets any attacker's .com
    origin through with credentials, so it is flagged; a specific-domain bound is not. The glued case
    is subtler still: '.*example\.com' has a bounded TAIL yet the wildcard runs straight into the
    label with no '\.' separator, so it fullmatches 'evilexample.com' — a leak, not a bound.
    """
    v = val.strip()
    v = v.removeprefix("^")
    v = v.removesuffix("$")
    v = v.rstrip("?")  # '.*?' (lazy) → treat like '.*'
    idx = max(v.rfind(".*"), v.rfind(".+"))
    if idx == -1:
        return False  # no unbounded wildcard at all
    tail = v[idx + 2 :].strip(")")  # literal after the last wildcard (drop a group ')')
    if tail == "":
        return True  # ends in an unbounded wildcard
    if tail[0].isalnum() or tail[0] in "-_":
        return True  # wildcard glued to a label ('.*example', '.*-example') — matches evil<label>/
        # evil-example → over-broad ('-'/'_' are valid host chars, so 'evil-example.com' is registrable)
    return bool(re.fullmatch(r"\\?\.[A-Za-z0-9-]+", tail))  # a lone TLD label like '\.com' / '.io'


# A secret-shaped identifier assigned a well-known PLACEHOLDER literal. Anchored on BOTH sides
# (secret-ish name AND a known dummy value) so it fires on `SECRET_KEY = "changeme"` but not on an
# innocuous `name = "secret santa"`. Real secrets come from settings/env, never a source literal.
# The middle `(?:['"]?\s*(?::\s*[A-Za-z_][\w\[\]\., ]*)?\s*)` tolerates the common variants:
#   SECRET_KEY = "changeme"   ·   SECRET_KEY: str = "changeme"  (pydantic annotated default)
#   secret_key: "changeme"    (yaml/dict)   ·   "secret_key": "changeme"  (quoted key)
SECRET_NAME = r"(?:secret(?:_?key)?|jwt_secret|api[_-]?key|access[_-]?token|password|passwd)"
SECRET_PLACEHOLDER = (
    r"changeme|change-me|change_me|changethis|change_this|placeholder|"
    r"your[-_a-z0-9]*|supersecret|topsecret|secret|password|passwd|"
    r"123456|admin|test123|dummy|example"
)
# The trailing `(?:CALL\(\s*(?:kwarg=)?)?` tolerates a wrapper around the literal — the CANONICAL
# pydantic-settings form `SECRET_KEY: str = Field("changeme")` / `Field(default="changeme")`, plus
# SecretStr("…") etc. — so a placeholder secret can't hide behind Field().
SECRET_LITERAL_RE = re.compile(
    rf"""(?i)\b(?:{SECRET_NAME})\b['"]?\s*(?::\s*[A-Za-z_][\w\[\]\., ]*)?\s*[:=]\s*"""
    rf"""(?:[A-Za-z_][\w.]*\s*\(\s*(?:[A-Za-z_]\w*\s*=\s*)?)?['"](?:{SECRET_PLACEHOLDER})['"]"""
)

# Raw psycopg connection in app code — the playbook forbids it (use the SQLAlchemy engine/Session so
# pooling, scoping and the project's least-privilege role are honored).
RAW_PSYCOPG_RE = re.compile(r"\bpsycopg2?\.connect\s*\(")

# A Postgres URL hardcoded to the SHARED INFRA database `shimpz-brain`. The standard is one ISOLATED DB per
# project (`proj_<name>`, from `shimpz-db create`) read from .env via pydantic-settings — so a literal
# `.../shimpz-brain` dbname in committed source is the explicit "NEVER use the infra `shimpz-brain` database" violation.
# We match ONLY a bare `shimpz-brain` dbname (boundary-anchored: end / `?query` / quote / space) so a real
# `proj_shimpz`, `shimpzshop`, `proj_<x>` dbname does NOT trip, and the URL must be a literal in source —
# .env itself is gitignored and never scanned, so a compliant `settings.database_url` never fires.
INFRA_DB_URL_RE = re.compile(r"""postgres(?:ql)?(?:\+\w+)?://[^\s'"]*/shimpz-brain(?:[?\s'"]|$)""", re.IGNORECASE)

# A queue / broker / task-queue client OTHER than the bus. Redpanda + the `shimpzbus` lib is the ONLY
# integration backbone (publish/run_worker, call, register) — a direct import of a broker client or a
# task-queue framework means a parallel, unsupervised queue outside the bus. The list covers the real
# ecosystem (R89 closed the gap: `aiokafka`/`faststream` — the most common async Kafka stacks — plus
# rq/dramatiq/arq/huey/taskiq/apscheduler sailed through the old six-name list; R90 added the
# messaging clients OUTSIDE the Kafka/AMQP families: nats, paho (MQTT), zmq, pulsar). Anchored to an
# import statement so a comment or a local `app.kafka_helpers` module never trips; `redis` is
# deliberately absent (a legitimate cache, not necessarily a broker — but `rq`, the redis QUEUE, is
# listed). The \b keeps look-alikes silent (natsort, zmqhelpers).
CUSTOM_BROKER_RE = re.compile(
    r"^\s*(?:import|from)\s+(?:pika|aio_pika|kombu|celery|kafka|confluent_kafka"
    r"|aiokafka|faststream|rq|dramatiq|arq|huey|taskiq|apscheduler"
    r"|nats|paho|zmq|pulsar)\b"
)

# A NON-POSTGRES datastore. The standard is an isolated PostgreSQL DB per project (`shimpz-db create` →
# DATABASE_URL in .env, SQLAlchemy+psycopg); CLAUDE.md allows "SQLite only for throwaway" — so in a
# SERVICE-shaped context (a backend/ dir, alembic migrations, or a file inside an app/ package) this
# is a BLOCK, and in a bare script project it stays a WARN (allowed, but flagged so a "throwaway"
# that grew into a service can't keep its file DB silently). Import-anchored + DSN form. R90 extended
# the family beyond sqlite/shelve: dbm (stdlib file store), tinydb/duckdb (embedded file DBs),
# pymongo/motor (Mongo — a parallel, unprovisioned datastore outside shimpz-db's isolation). The \b keeps
# look-alikes silent (motors, dbmodels); json/pickle-on-disk stays out (too FP-prone to gate on).
SQLITE_IMPORT_RE = re.compile(r"^\s*(?:import|from)\s+(?:sqlite3|aiosqlite|shelve|dbm|tinydb|duckdb|pymongo|motor)\b")
SQLITE_URL_RE = re.compile(r"\b(?:sqlite(?:\+aiosqlite)?|mongodb(?:\+srv)?)://", re.IGNORECASE)

# A backend that calls ANOTHER local service directly by its loopback APP-port (3100–3999). Service-to-
# service integration goes through the bus (`shimpzbus.call` for request/reply, publish/run_worker for
# events) — a hardcoded http://127.0.0.1:3xxx call is an undiscoverable, unretried dependency that
# breaks the moment the target redeploys on another port. Scoped to the deployed-app port range ON
# PURPOSE: loopback ports OUTSIDE it (CDP 9222, postgres 5432, redpanda 9092, a dev uvicorn 8000) are
# legitimate infra endpoints and must NOT trip (the cry-wolf guard).
LOOPBACK_CALL_RE = re.compile(
    r"(?:https?|wss?)://(?:127\.0\.0\.1|0\.0\.0\.0|localhost(?![\w.-])|\[::1\]):3[1-9]\d\d\b",
    re.IGNORECASE,
)

# The logging house-standard rules (swallowed-exception, print-in-service) are detected via the AST, NOT
# regex — see _logging_ast_findings. Regex over text can't tell a real `print(` call from the word "print("
# inside a docstring/comment (a false BLOCK = the exact cry-wolf that gets the gate switched off), so we
# parse the module and inspect real Call / ExceptHandler nodes. Ruff's own T201 uses the AST for the same
# reason. missing-log-setup stays a cheap substring check (below, in scan_backend_text).

# ── WARN rules ─────────────────────────────────────────────────────────────────────────────────
# Base.metadata.create_all(...) — schema must be alembic migrations, not create_all (which is
# dev-only and drifts from the real schema). WARN, not BLOCK: it's legitimate for a throwaway.
CREATE_ALL_RE = re.compile(r"\.metadata\.create_all\s*\(")
# debug=True / FastAPI(debug=True) / uvicorn reload in committed code — prod hygiene smell.
DEBUG_TRUE_RE = re.compile(r"\bdebug\s*=\s*True\b")
# setInterval(... fetch( ... on ONE line — the classic HTTP-polling idiom in a frontend. The standard
# for realtime backend→frontend data is the WebSocket (the scaffolded ws gateway + src/lib/ws.ts);
# polling is a rare, justified exception. WARN not BLOCK on purpose: a multi-line poller escapes this
# regex anyway and a legitimate one-shot delayed fetch exists — this is the nudge, the judge and the
# scaffold carry the standard.
HTTP_POLLING_RE = re.compile(r"setInterval\s*\(.*\bfetch\s*\(")


def _frontend_roots(root):
    """Where the frontend source lives: frontend/src, or a top-level src/ when there's no frontend/.

    frontend/src is the fullstack layout; the top-level src/ fallback only applies when there's
    no frontend/ dir (frontend-only project). Returned as absolute dirs that exist.
    """
    out = []
    root = Path(root)
    fe = root / "frontend"
    if fe.is_dir():
        src = fe / "src"
        out.append(src if src.is_dir() else fe)
    elif (root / "src").is_dir():
        out.append(root / "src")
    return out


def _has_alembic(root):
    """True if the project already runs alembic migrations.

    Detected via alembic.ini or an alembic/ dir, at the project root or under backend/. When
    alembic IS set up, a stray metadata.create_all is no longer a 'throwaway dev shortcut' —
    it's a schema-drift bug, so create_all is promoted from WARN to BLOCK.
    """
    for base in (Path(root), Path(root) / "backend"):
        if (base / "alembic.ini").is_file() or (base / "alembic").is_dir():
            return True
    return False


# A full HTML *page* (doctype or <html>), not a fragment/snippet — the signal of a hand-written site.
FULL_HTML_RE = re.compile(r"<!doctype html|<html[\s>]", re.IGNORECASE)


def _walk(root, exts, project_root):
    """Yield (relpath_from_project_root, abspath) for files with the given extensions.

    Skips SKIP_DIRS anywhere in the tree.
    """
    for dirpath, dirnames, filenames in os.walk(root):
        _prune_dirs(dirpath, dirnames)
        for fn in filenames:
            if Path(fn).suffix in exts:
                ap = Path(dirpath) / fn
                yield os.path.relpath(ap, project_root), ap


def _read(path):
    # errors="replace" means a decode never raises (binary blobs become harmless replacement chars);
    # only a real I/O/permission error reaches here — surface it LOUDLY (fail-fast) rather than let an
    # unreadable source file silently scan as empty (= no findings).
    try:
        return Path(path).read_text(encoding="utf-8", errors="replace")
    except OSError as e:
        sys.stderr.write(f"shimpz-stdcheck: cannot read {path}: {e!r}\n")
        return ""


def _hits(text, regex):
    """Line numbers (1-based) of every regex match in text — so a finding points at a real line."""
    out = []
    for i, line in enumerate(text.splitlines(), 1):
        if regex.search(line):
            out.append(i)
    return out


def _is_suppress(func):
    """True if `func` is a call to `suppress` or `contextlib.suppress` (the broad-suppress detector)."""
    return (isinstance(func, ast.Name) and func.id == "suppress") or (
        isinstance(func, ast.Attribute) and func.attr == "suppress"
    )


def _exc_names(handler):
    """The exception class names an `except` clause catches ([] for a bare `except:`).

    Used to EXEMPT the legitimate optional-import guard `except ImportError: pass` from the
    swallowed-exception rule.
    """
    t = handler.type
    if t is None:
        return []
    if isinstance(t, ast.Name):
        return [t.id]
    if isinstance(t, ast.Tuple):
        return [e.id for e in t.elts if isinstance(e, ast.Name)]
    return []


def _logging_ast_findings(rel, text, in_service_pkg):
    """PURE + PRECISE: the print-in-service and swallowed-exception BLOCKs via the AST.

    Uses the AST so a `print(` in a docstring/comment or a method `.print()` never trips, and
    an example in prose can't cry wolf. A file that doesn't parse (mid-edit syntax error) yields
    nothing here — it won't run anyway and the regex rules still apply. Test files are already
    filtered out by the caller.
    """
    try:
        tree = ast.parse(text)
    except SyntaxError:
        return []

    def _is_noop(stmt):
        # a statement that does NOTHING: `pass`, `...`, or a bare constant expression (a string "ignore",
        # a number) — all silent swallows. A body made ENTIRELY of these catches the error and drops it.
        return isinstance(stmt, ast.Pass) or (isinstance(stmt, ast.Expr) and isinstance(stmt.value, ast.Constant))

    out = []
    for node in ast.walk(tree):
        if isinstance(node, ast.ExceptHandler):
            body = node.body
            only_noop = len(body) >= 1 and all(_is_noop(s) for s in body)
            names = _exc_names(node)
            optional_import = bool(names) and set(names) <= {
                "ImportError",
                "ModuleNotFoundError",
            }
            if only_noop and not optional_import:
                out.append(
                    (
                        "BLOCK",
                        "swallowed-exception",
                        rel,
                        node.lineno,
                        "an except body is only pass/... — the error is silently swallowed",
                        "log.exception(...) and/or re-raise; never swallow (fail-fast, no silent fallback)",
                    )
                )
        elif isinstance(node, ast.With | ast.AsyncWith):
            # `with [contextlib.]suppress(Exception|BaseException):` is a silent Pokémon handler that
            # ruff can't see (it's not an `except` clause) — the same sin as `except Exception: pass`,
            # just spelled with a context manager. Narrow suppression (suppress(OSError)) is fine.
            for it in node.items:
                ce = it.context_expr
                if (
                    isinstance(ce, ast.Call)
                    and _is_suppress(ce.func)
                    and any(isinstance(a, ast.Name) and a.id in ("Exception", "BaseException") for a in ce.args)
                ):
                    out.append(
                        (
                            "BLOCK",
                            "broad-suppress",
                            rel,
                            ce.lineno,
                            "contextlib.suppress(Exception) silently swallows EVERY error (a Pokémon handler)",
                            "suppress the SPECIFIC exception (OSError/TelegramError/…), never the base class",
                        )
                    )
        elif (
            in_service_pkg
            and isinstance(node, ast.Call)
            and isinstance(node.func, ast.Name)
            and node.func.id == "print"
        ):
            out.append(
                (
                    "BLOCK",
                    "print-in-service",
                    rel,
                    node.lineno,
                    "print() in a service package — output must go through structlog, not print",
                    "use structlog.get_logger() (app/logconf.py configures it); never print()",
                )
            )
    return out


def scan_frontend_text(rel, text):
    """PURE: BLOCK + WARN findings for one frontend file's text. Unit-testable without touching disk.

    Test/spec files are exempt (a fixture may legitimately reference a localhost URL).
    """
    if _is_test(rel):
        return []
    f = [
        (
            "BLOCK",
            "frontend-hardcoded-host",
            rel,
            ln,
            "frontend hardcodes a loopback backend URL — breaks once published",
            "call the API at a RELATIVE path '/api/...'; never http://127.0.0.1:<port>",
        )
        for ln in _hits(text, HARDCODED_HOST_RE)
    ]
    f += [
        (
            "WARN",
            "http-polling",
            rel,
            ln,
            "setInterval+fetch polling — realtime data is a WebSocket subscription, not a poll",
            "subscribe via src/lib/ws.ts connect() (/ws); backend publishes with app/events.py notify()",
        )
        for ln in _hits(text, HTTP_POLLING_RE)
    ]
    return f


def scan_backend_text(rel, text, alembic=False, service=False):
    """PURE: BLOCK + WARN findings for one backend file's text.

    Test files are exempt from ALL rules — a fixture's dummy password / raw connect / CORS test is not
    a production violation, and BLOCKing it would wedge the turn and withhold the commit (the gate must
    not cry wolf). `alembic` (a project-level fact passed down by scan_project) promotes create_all from
    WARN to BLOCK when migrations exist; `service` (backend/ dir or alembic anywhere in the project)
    promotes sqlite-datastore from WARN to BLOCK — a service persists in its isolated Postgres, period.
    """
    if _is_test(rel):
        return []
    rel_norm = rel.replace(os.sep, "/")
    in_service_pkg = "/app/" in ("/" + rel_norm)  # a file inside a FastAPI service package
    f = [
        (
            "BLOCK",
            "db-infra-shared",
            rel,
            ln,
            "hardcoded connection to the shared infra database `shimpz-brain`",
            "give the project its own DB (shimpz-db create <name> → proj_<name>); read DATABASE_URL from .env",
        )
        for ln in _hits(text, INFRA_DB_URL_RE)
    ]
    f += [
        (
            "BLOCK",
            "custom-broker",
            rel,
            ln,
            "a queue/broker client outside the bus (pika/kafka/celery/…) — the bus is the only backbone",
            "use shimpzbus (uv add shimpzbus): publish/run_worker, call, register; shimpz-bus discover first",
        )
        for ln in _hits(text, CUSTOM_BROKER_RE)
    ]
    sqlite_sev = "BLOCK" if (service or in_service_pkg) else "WARN"
    f += [
        (
            sqlite_sev,
            "sqlite-datastore",
            rel,
            ln,
            "a non-PostgreSQL datastore (sqlite/shelve/dbm/tinydb/duckdb/mongo) — the standard is an "
            "isolated PostgreSQL DB per project"
            + (" (this project is a service, not a throwaway)" if sqlite_sev == "BLOCK" else ""),
            "shimpz-db create <name> → DATABASE_URL in .env (SQLAlchemy 2 + psycopg); file DBs only in a throwaway",
        )
        for ln in sorted(set(_hits(text, SQLITE_IMPORT_RE)) | set(_hits(text, SQLITE_URL_RE)))
    ]
    f += [
        (
            "BLOCK",
            "loopback-service-call",
            rel,
            ln,
            "backend calls another local service directly by its loopback app-port — bypasses the bus",
            "shimpzbus.call('svc','/route',...) request/reply, or publish/run_worker events; shimpz-bus discover first",
        )
        for ln in _hits(text, LOOPBACK_CALL_RE)
    ]
    if CORS_CREDS_RE.search(text):
        m = CORS_REGEX_RE.search(text)
        open_regex = bool(m and _regex_matches_all(m.group(2)))
        if CORS_STAR_RE.search(text) or open_regex:
            ln = (_hits(text, CORS_STAR_RE) or _hits(text, CORS_REGEX_RE) or [1])[0]
            f.append(
                (
                    "BLOCK",
                    "cors-star-credentials",
                    rel,
                    ln,
                    "CORS allows every origin (allow_origins=['*'] or a .* regex) WITH "
                    "allow_credentials=True — leaks credentials",
                    "list explicit origins, or drop credentials; same-origin /api needs no CORS",
                )
            )
    f += [
        (
            "BLOCK",
            "placeholder-secret",
            rel,
            ln,
            "a secret is hardcoded to a placeholder literal",
            "generate it (secrets.token_urlsafe) into .env; read via pydantic-settings",
        )
        for ln in _hits(text, SECRET_LITERAL_RE)
    ]
    f += [
        (
            "BLOCK",
            "raw-psycopg-connect",
            rel,
            ln,
            "raw psycopg.connect() bypasses the SQLAlchemy engine / scoped role",
            "use the SQLAlchemy 2.0 engine + Session (app/db.py)",
        )
        for ln in _hits(text, RAW_PSYCOPG_RE)
    ]
    # ── logging house-standard (see [[shimpz-new]] scaffold) — print/swallow via AST, setup via substring ──
    f += _logging_ast_findings(rel, text, in_service_pkg)
    if in_service_pkg and rel_norm.endswith("app/main.py") and "FastAPI(" in text and "setup(" not in text:
        f.append(
            (
                "BLOCK",
                "missing-log-setup",
                rel,
                1,
                "the FastAPI entrypoint never calls the logging setup() — logs won't be structured",
                'call setup("<service>") from app.logconf at boot (shimpz-new wires this by default)',
            )
        )
    ca_sev = "BLOCK" if alembic else "WARN"
    ca_msg = (
        "schema via metadata.create_all while the project runs alembic — migrations and create_all diverge (drift bug)"
        if alembic
        else "schema via metadata.create_all — should be alembic migrations"
    )
    for ln in _hits(text, CREATE_ALL_RE):
        f.append(
            (
                ca_sev,
                "create-all-instead-of-alembic",
                rel,
                ln,
                ca_msg,
                "alembic revision --autogenerate; create_all is dev-only and drifts",
            )
        )
    for ln in _hits(text, DEBUG_TRUE_RE):
        f.append(
            (
                "WARN",
                "debug-true",
                rel,
                ln,
                "debug=True in committed code — prod hygiene smell",
                "drive debug from config/env, default False",
            )
        )
    return f


def scan_committed_env(root, run=subprocess.run):
    """BLOCK: any tracked .env (real secret in git history).

    .env.example/.sample are fine. Only meaningful when the project is a git repo; a non-repo can't
    have 'committed' files. `run` is injectable for tests. A git failure is surfaced LOUDLY (fail-fast)
    — we don't silently report 'no committed secrets' when we simply couldn't ask git.
    """
    if not (Path(root) / ".git").is_dir():
        return []
    try:
        r = run(["git", "-C", root, "ls-files"], capture_output=True, text=True, timeout=20)
    except (OSError, subprocess.SubprocessError) as e:
        sys.stderr.write(f"shimpz-stdcheck: git ls-files failed in {root}: {e!r}\n")
        return []
    if r.returncode != 0:
        # A non-zero exit (dubious ownership, corrupt index, …) prints NOTHING to stdout, so the scan
        # below would report 'no committed secrets' over an unreadable repo — the exact silent-clean the
        # docstring forbids. Surface it loudly; the caller decides, but we never fake a clean result.
        sys.stderr.write(
            f"shimpz-stdcheck: git ls-files exited {r.returncode} in {root}: {(r.stderr or '').strip()[-300:]}\n"
        )
        return []
    tracked = r.stdout.splitlines()
    out = []
    for p in tracked:
        base = Path(p).name
        if base == ".env" or (base.startswith(".env.") and base not in (".env.example", ".env.sample")):
            out.append(
                (
                    "BLOCK",
                    "committed-env",
                    p,
                    1,
                    "a .env with secrets is tracked in git",
                    "git rm --cached it and add to .gitignore; commit only .env.example",
                )
            )
    return out


SHEBANG_SHELL_RE = re.compile(r"^#!\s*(?:/usr/bin/env\s+)?(?:/bin/|/usr/bin/)?(bash|sh|dash|ksh|zsh)\b")


def _first_line(path, cap=256):
    """The file's first ~`cap` bytes as text — enough for a shebang, never a whole file.

    Same fail-LOUD contract as `_read`: an unreadable file must not silently scan as
    shebang-free (a permission error masquerading as "no finding" would make this BLOCK gate
    fail-open with zero visibility — exactly the swallowed-error defect the project forbids).
    """
    try:
        with Path(path).open("rb") as fh:
            raw = fh.readline(cap)
    except OSError as e:
        sys.stderr.write(f"shimpz-stdcheck: cannot read {path}: {e!r}\n")
        return ""
    return raw.decode("utf-8", errors="replace")


def scan_shell_scripts(root):
    """BLOCK: a NEW standalone script with a bash/sh shebang — scripts are Python 3.14 only (owner directive).

    Neither ruff nor any stack lint catches "wrong scripting language" (there's no Python source to
    lint against), so this is a first-line/shebang check across the WHOLE tree — same "any file, any
    extension" shape as scan_nested_git. Zero false-positive surface (unlike raw-HTML content
    matching): a shebang line IS the declaration of intent, nothing else looks like one. Test
    fixtures are exempt (a test may legitimately drive a real shell script as a fixture).
    """
    out = []
    for dirpath, dirnames, filenames in os.walk(root):
        _prune_dirs(dirpath, dirnames)
        for fn in filenames:
            ap = Path(dirpath) / fn
            rel = os.path.relpath(ap, root)
            if _is_test(rel):
                continue
            if SHEBANG_SHELL_RE.match(_first_line(ap)):
                out.append(
                    (
                        "BLOCK",
                        "shell-shebang",
                        rel,
                        1,
                        "a bash/sh script — new standalone scripts are Python 3.14 only",
                        "rewrite in Python (shebang /usr/bin/env python3): subprocess.run([...]) with an "
                        "argument list (never shell=True), pathlib (never os.path), real exceptions "
                        "(never a silent except: pass)",
                    )
                )
    return out


def scan_nested_git(root):
    """BLOCK: a nested git repo inside the project (the rule is ONE repo per project).

    A sub-repo (e.g. frontend/.git) turns that subtree into an embedded gitlink for the outer repo:
    new files under it silently stop being versioned by the project repo, defeating the auto-sync
    "nothing is lost" guarantee. Dep/build trees are pruned (and .git itself is never descended).
    """
    root = Path(root)
    out = []
    for dirpath, dirnames, _files in os.walk(root):
        if dirpath != str(root) and ".git" in dirnames and (Path(dirpath) / ".git").is_dir():
            rel = os.path.relpath(Path(dirpath) / ".git", root)
            out.append(
                (
                    "BLOCK",
                    "nested-git",
                    rel,
                    1,
                    "a nested git repo — its tree silently stops being versioned by the project repo",
                    f"rm -rf {rel} (one repo per project; the project repo already versions this tree)",
                )
            )
        _prune_dirs(dirpath, dirnames)
    return out


def scan_raw_html(root):
    """WARN: a hand-written full HTML page in a project with NO SvelteKit config (the front must ALWAYS be SvelteKit).

    A SvelteKit project is exempt wholesale (its app.html / static assets are legitimate — a
    svelte.config.{js,ts} anywhere means the frontend IS SvelteKit). WARN not BLOCK on purpose:
    the false-positive surface (email templates, generated pages) is too wide to STOP a turn over,
    but a bare hand-written site is worth flagging. Test files are exempt. ONE walk collects the
    .html candidates AND detects the SvelteKit config that voids them all.
    """
    out = []
    for dirpath, dirnames, filenames in os.walk(root):
        _prune_dirs(dirpath, dirnames)
        if "svelte.config.js" in filenames or "svelte.config.ts" in filenames:
            return []
        for fn in filenames:
            if not fn.endswith(".html"):
                continue
            ap = Path(dirpath) / fn
            rel = os.path.relpath(ap, root)
            if _is_test(rel):
                continue
            if FULL_HTML_RE.search(_read(ap)):
                out.append(
                    (
                        "WARN",
                        "raw-html-no-sveltekit",
                        rel,
                        1,
                        "a hand-written HTML page and no SvelteKit — the front must be SvelteKit",
                        "scaffold the UI with shimpz-new (SvelteKit + Tailwind); never serve raw HTML",
                    )
                )
    return out


def scan_oversized(root):
    """BLOCK a file that's grown too big (> MAX_FILE_LINES): backend .py AND frontend src (.svelte/.ts/…).

    The deterministic 'no giant do-everything file' rule. Exempts tests (a long test file is
    fine) and alembic (generated). No lint rule covers this in-gate, so it lives here. One walk of
    the WHOLE tree: it already covers every frontend root (they live under the project root), and
    a big code file outside them is just as much a violation.
    """
    out = []
    for rel, ap in _walk(root, FRONT_EXT | PY_EXT, root):
        if _is_test(rel) or "/alembic/" in "/" + rel.replace(os.sep, "/"):
            continue
        n = len(_read(ap).splitlines())
        if n > MAX_FILE_LINES:
            out.append(
                (
                    "BLOCK",
                    "oversized-file",
                    rel,
                    1,
                    f"file is {n} lines (> {MAX_FILE_LINES}) — split it into focused modules/components",
                    "extract cohesive pieces into their own files; a file should do one thing",
                )
            )
    return out


def scan_project(root):
    """Run every rule over a project dir → flat list of findings (severity, rule, file, line, msg, fix)."""
    root = Path(root).resolve()
    if not root.is_dir():
        raise NotADirectoryError(root)
    alembic = _has_alembic(root)
    # service-shaped = a backend/ dir or alembic migrations anywhere: this project persists real data,
    # so sqlite-datastore is a BLOCK for it (a bare script project only WARNs — throwaway is allowed).
    service = alembic or (root / "backend").is_dir()
    findings = []
    for fr in _frontend_roots(root):
        for rel, ap in _walk(fr, FRONT_EXT, root):
            findings += scan_frontend_text(rel, _read(ap))
    # Backend scan = the WHOLE tree (R90): scanning backend/ alone left every .py outside it (a
    # root-level jobs/ or worker/, a loose script) exempt from ALL architecture rules — a CONFIRMED
    # bypass. Python is Python wherever it sits; SKIP_DIRS prunes deps, tests are exempt by path.
    for rel, ap in _walk(root, PY_EXT, root):
        findings += scan_backend_text(rel, _read(ap), alembic=alembic, service=service)
    findings += scan_oversized(root)
    findings += scan_committed_env(root)
    findings += scan_raw_html(root)
    findings += scan_nested_git(root)
    findings += scan_shell_scripts(root)
    findings += scan_vendored_shimpzbus(root)
    return findings


def _fmt(f):
    _sev, rule, path, line, msg, fix = f
    return f"  {path}:{line}  [{rule}] {msg}\n      → fix: {fix}"


def main(argv):
    if argv and argv[0] == "--lang":
        # HOST language-obligation mode: the fail-fast exception rules (swallowed-exception +
        # broad-suppress) over an EXPLICIT list of files — so the host reuses this ONE canonical
        # detector (the sync gate passes the production host sources). in_service_pkg=False → the
        # print-in-service rule (a Shimpz-backend concept) doesn't apply here.
        files = argv[1:]
        if not files:
            sys.stderr.write("usage: shimpz-stdcheck --lang <file> [file ...]\n")
            return 64
        blocks = []
        for f in files:
            blocks += [b for b in _logging_ast_findings(f, _read(f), False) if b[0] == "BLOCK"]
        for b in blocks:
            print(_fmt(b))
        if blocks:
            print(
                f"🔴 fail-fast BLOCK ({len(blocks)}): swallowed / broad-suppress — "
                "log.exception()/re-raise, or narrow to the specific exception"
            )
        return 2 if blocks else 0
    root, as_json = shimpzaudit.cli_arg(argv, "usage: shimpz-stdcheck [--json] <project-dir>")
    if root is None:
        return 64
    findings = scan_project(root)  # may raise NotADirectoryError → loud, non-zero
    blocks = [f for f in findings if f[0] == "BLOCK"]
    warns = [f for f in findings if f[0] == "WARN"]
    if as_json:
        keys = ("severity", "rule", "file", "line", "message", "fix")
        print(
            json.dumps(
                {
                    "blocks": [dict(zip(keys, b, strict=False)) for b in blocks],
                    "warns": [dict(zip(keys, w, strict=False)) for w in warns],
                }
            )
        )
    else:
        name = Path(root).resolve().name
        if blocks:
            print(f"🔴 BLOCK — {name} ({len(blocks)}):")
            for b in blocks:
                print(_fmt(b))
        if warns:
            print(f"🟡 WARN — {name} ({len(warns)}):")
            for w in warns:
                print(_fmt(w))
        if not blocks and not warns:
            print(f"✅ {name}: ecosystem-standard clean")
    return 2 if blocks else 0


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except NotADirectoryError as e:
        sys.stderr.write(f"shimpz-stdcheck: not a directory: {e}\n")
        sys.exit(64)
