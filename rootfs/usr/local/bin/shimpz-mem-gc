#!/opt/venv/bin/python
"""Memory garbage-collector — fights 'memory rot' (stale entries that mislead recall).

Conservative on purpose: it ARCHIVES (never hard-deletes) topic files that haven't been
surfaced by recall nor edited in SHIMPZ_MEM_TTL_DAYS, moving them to memory/.archive/ so they
stop polluting retrieval but remain recoverable. Also clears stale Stop-hook sentinels.
Self-throttles to once per day via a stamp file, so it's cheap to call on every gateway boot.
"""

import logging
import os
import shutil
import time
from pathlib import Path

log = logging.getLogger("shimpz-mem-gc")

MEM = Path(os.environ.get("SHIMPZ_MEMORY_DIR", "/config/.shimpz/memory"))
TTL = int(os.environ.get("SHIMPZ_MEM_TTL_DAYS", "90")) * 86400
NOW = int(time.time())


def throttled():
    stamp = MEM / ".gc-stamp"
    try:
        if stamp.is_file() and NOW - stamp.stat().st_mtime < 86400:
            return True
        stamp.write_text("")
    except OSError as e:
        log.warning("gc throttle stamp unavailable: %s", e)
    return False


def last_access():
    """File -> latest access ts, from .access.log written by shimpz-recall."""
    acc = {}
    p = MEM / ".access.log"
    if p.is_file():
        with p.open(encoding="utf-8", errors="ignore") as fh:
            for line in fh:
                try:
                    ts, rel = line.rstrip("\n").split("\t", 1)
                    acc[rel] = max(acc.get(rel, 0), int(ts))
                except ValueError:
                    continue
    return acc


def main():
    if not MEM.is_dir():
        return
    # 1) clear sentinels older than 2 days
    guard = MEM / ".memguard"
    for s in guard.glob("*"):
        try:
            if NOW - s.stat().st_mtime > 2 * 86400:
                s.unlink()
        except OSError as e:
            log.warning("could not clear stale sentinel %s: %s", s, e)
    if throttled():
        return
    # 2) archive stale topic files (combat memory-rot).
    acc = last_access()
    arch = MEM / ".archive"
    for f in [*(MEM / "playbooks").glob("*.md"), *(MEM / "facts").glob("*.md")]:
        rel = str(f.relative_to(MEM))
        try:
            seen = max(acc.get(rel, 0), int(f.stat().st_mtime))
        except OSError:
            continue
        if NOW - seen > TTL:
            try:
                dst = arch / rel
                dst.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(f, dst)
            except (OSError, shutil.Error) as e:
                log.warning("could not archive %s: %s", rel, e)


if __name__ == "__main__":
    main()
