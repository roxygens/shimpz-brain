#!/usr/bin/env bash
# shimpz-project-sync — Stop hook: STANDARDIZE every project Shimpz builds as its own git repo and
# auto-commit ALL changes after each task. One repo per project under workspace/projects/<name>.
#
# - First time it sees a project dir: `git init` (branch main) + a safe default .gitignore (only if
#   the project doesn't already ship one — scaffolders usually do) + an initial commit.
# - Every Stop: `git add -A` and commit if anything changed (respecting .gitignore, so secrets in
#   .env and heavy build dirs like node_modules/.venv never get committed).
# - LOCAL by default. If (and only if) a project has an `origin` remote configured, it also does a
#   best-effort `git push` — so Shimpz can opt a project into a remote later with `git remote add`.
#
# Always exits 0 (never blocks the agent from stopping). Quiet. Reads nothing it needs from stdin.
set +e
PROOT="${SHIMPZ_PROJECTS_DIR:-/config/workspace/projects}"
GIT_NAME="${SHIMPZ_GIT_NAME:-Shimpz}"
GIT_EMAIL="${SHIMPZ_GIT_EMAIL:-shimpz-brain@roxygens.com}"
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo now)"
MEM="${SHIMPZ_MEMORY_DIR:-/config/.shimpz/memory}"

[ -d "$PROOT" ] || exit 0

# Every project committed this Stop gets its name appended here — the LAST one recorded becomes
# shimpz-recall's ".last-project" fallback, so a rotated/fresh session that doesn't restate the
# project name still finds its memory/projects/<slug>.md on the next turn.
TOUCHED="$(mktemp)"
trap 'rm -f "$TOUCHED"' EXIT

for d in "$PROOT"/*/; do
    [ -d "$d" ] || continue
    base="$(basename "$d")"
    case "$base" in .*) continue;; esac     # skip dotdirs
    (
        cd "$d" 2>/dev/null || exit 0
        if [ ! -d .git ]; then
            git init -q -b main 2>/dev/null || exit 0
            if [ ! -f .gitignore ]; then
                # ONE source of truth, shared with shimpz-new's scaffold. If the copy fails there is
                # no .gitignore guarding .env → skip this project rather than risk committing secrets.
                cp "$(dirname "$0")/../share/shimpz-std/gitignore" .gitignore || exit 0
            fi
        fi
        git add -A 2>/dev/null || exit 0
        # commit only when something is actually staged
        if ! git diff --cached --quiet 2>/dev/null; then
            git -c user.name="$GIT_NAME" -c user.email="$GIT_EMAIL" \
                commit -q -m "shimpz-brain: auto-sync $TS" 2>/dev/null || exit 0
            # opt-in remote: push only if origin exists; bounded so a slow remote can't hang Stop
            if git remote get-url origin >/dev/null 2>&1; then
                # commit is already local (the critical part); a failed push must NOT be silent — surface it.
                timeout 15 git push -q || echo "shimpz-project-sync: push failed for '$base' (commit is local, push it manually)" >&2
            fi
            echo "$base" >> "$TOUCHED"
        fi
    )
done
# Only touch the marker when something actually changed this Stop — an idle turn must not erase
# the last real signal of which project Shimpz was working on.
if [ -s "$TOUCHED" ]; then
    mkdir -p "$MEM" 2>/dev/null && tail -n1 "$TOUCHED" > "$MEM/.last-project" 2>/dev/null
fi

# The memory store is ALSO its own git repo (R121): every turn that changed a memory gets a
# snapshot commit — history/rollback/audit of what Shimpz knows, for free. Derived/runtime files
# (.access.log, the embedding index, hook sentinels) stay untracked; .archive/ IS tracked (content).
if [ -d "$MEM" ]; then (
    cd "$MEM" 2>/dev/null || exit 0
    if [ ! -d .git ]; then
        git init -q -b main 2>/dev/null || exit 0
        [ -f .gitignore ] || printf '%s\n' '.access.log' '.memguard/' '.gc-stamp' '.last-project' '.embindex.npz' > .gitignore
    fi
    git add -A 2>/dev/null || exit 0
    if ! git diff --cached --quiet 2>/dev/null; then
        git -c user.name="$GIT_NAME" -c user.email="$GIT_EMAIL" \
            commit -q -m "memory: auto-snapshot $TS" 2>/dev/null
    fi
) fi
exit 0
