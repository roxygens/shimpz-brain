#!/opt/venv/bin/python
"""webread <url> [max_chars].

Reads a page and returns the CLEAN TEXT of the article (title + main body) — NOT the
whole DOM/innerText. Use this to READ articles in research/deep-research, instead of
`browser_navigate` + dumping innerText: it's much faster, MUCH cheaper (a few KB
of clean text vs 20-30k chars of innerText), and doesn't drive the heavy browser per page.

Static/SEO articles come from a cheap fetch (trafilatura). JS-only pages fall back to a single
render via the already-running headful Chrome (browser-agent, in the `shimpz-browser` container). On
failure, it WARNS clearly: do NOT retry the SAME URL — move on to another source.
"""

import os
import sys

import trafilatura

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzbrowser  # shared browser-agent HTTP client (see /opt/shimpz-lib/shimpzbrowser.py)


def _clean(html, url):
    if not html:
        return None
    return trafilatura.extract(html, include_comments=False, include_tables=True, url=url, favor_recall=True)


def _title(html, url):
    try:
        md = trafilatura.extract_metadata(html, default_url=url)
        return getattr(md, "title", None) if md else None
    except Exception:  # noqa: BLE001 — best-effort optional metadata (3rd-party HTML parse); title degrades to the URL
        return None


def _via_cdp(url):
    """Render JS-only pages with the already-running headful Chrome.

    Calls browser-agent's /v1/browser/render — opens a fresh tab, waits, reads outerHTML, closes
    the tab; see browser-agent/cdp_client.py's `render()`, ported from this function's old
    direct-CDP version.
    """
    result = shimpzbrowser.call_json("POST", "/v1/browser/render", {"url": url})
    return result["html"]


def main():
    if len(sys.argv) < 2:
        print("usage: webread <url> [max_chars]", file=sys.stderr)
        sys.exit(2)
    url = sys.argv[1]
    maxc = int(sys.argv[2]) if len(sys.argv) > 2 else 8000

    html = trafilatura.fetch_url(url)
    txt = _clean(html, url)
    title = _title(html, url) if html else None

    # SPA shell (Next/React) → short/empty text → render once via browser-agent.
    if not txt or len(txt) < 300:
        try:
            html2 = _via_cdp(url)
            txt2 = _clean(html2, url)
            if txt2 and len(txt2) > len(txt or ""):
                txt, title = txt2, (_title(html2, url) or title)
        except shimpzbrowser.BrowserAgentError as e:
            # best-effort render — surface WHY (never swallow), then fall through to the ERROR below
            print(f"webread: CDP render failed for {url}: {e}", file=sys.stderr)

    if not txt:
        print(
            f"ERROR: could not extract content from {url} (blocked/no readable text). "
            f"Do NOT retry the SAME URL — go to another source.",
            file=sys.stderr,
        )
        sys.exit(1)

    body = txt[:maxc]
    print(f"# {title or url}\nURL: {url}\n\n{body}")
    if len(txt) > maxc:
        print(
            f"\n[... truncated: {maxc} of {len(txt)} chars; ask for more with webread {url} {len(txt)} if needed ...]"
        )


main()
