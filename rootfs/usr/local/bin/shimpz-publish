#!/usr/bin/env bash
# shimpz-publish — publish a local app on a custom domain through the Cloudflare Tunnel, in ONE shot.
# Does the full flow via cf-driver (SECURITY_ENGINEERING_PLAN.md item 3 — `shimpz-brain` never holds
# SHIMPZ_CF_TOKEN; calls a narrow, named, audited API instead of the old permissive `cf` helper):
# tunnel ingress rule → proxied DNS record → Caddy route → Access (public/private). Idempotent +
# safe: on ANY later-step failure, rolls back every earlier step THIS run touched
# (SECURITY_ENGINEERING_PLAN.md item 4), so it can't strand the domain in a broken half-state.
#
#   shimpz-publish <fqdn> <port> [public|private] [api-port] [ws-port]
#   e.g. shimpz-publish app.medsec.com.br 3100            # public (default)
#        shimpz-publish painel.zyon.network 3101 private  # Cloudflare Access (one-time PIN)
#        shimpz-publish app.x.com 3100 public 3101 3102   # fullstack: /api → 3101, /ws → 3102 (realtime)
#
# Each step prints OK/FAIL. The one permission that can block it is DNS:Edit (records) on the token
# cf-driver holds — everything else still applies and it's instant once DNS:Edit is added.
# Origin served by shimpz-caddy:8080 (extracted out of `shimpz-brain` — SECURITY_ENGINEERING_PLAN.md section 4).
set -uo pipefail
# Shared helpers (ONE source of truth with shimpz-app/shimpz-unpublish): _owner_note, the backend/SvelteKit
# detection rules (_haspy/_svelte_server_files/_isbackend), _projroot.
. "${SHIMPZ_LIB:-/opt/shimpz-lib}/shimpzdetect.sh"
# cf-driver client (zone resolve, tunnel ingress, DNS, Access — SECURITY_ENGINEERING_PLAN.md
# item 3) and shimpz-driver client — _driver_app_for_port resolves which app container owns a
# port (shimpz-brain has no Docker access of its own to inspect containers/supervisor state directly).
. "${SHIMPZ_LIB:-/opt/shimpz-lib}/cfdriver.sh"
. "${SHIMPZ_LIB:-/opt/shimpz-lib}/shimpzdriver.sh"
fqdn="${1:?usage: shimpz-publish <fqdn> <web-port> [public|private] [api-port] [ws-port]}"; port="${2:?need <port>}"
scope="${3:-public}"; api="${4:-}"; ws="${5:-}"   # api → /api/* backend; ws → /ws realtime gateway
# Validate inputs up front (fail-fast, before any Cloudflare mutation): fqdn/port feed the tunnel
# ingress JSON, DNS record, and the Caddyfile (see shimpz-route) — reject anything that isn't a plain
# hostname / numeric port so a newline or metacharacter can't inject config downstream.
case "$fqdn" in *[!A-Za-z0-9.-]*|'') echo "shimpz-publish: fqdn must be [A-Za-z0-9.-]" >&2; exit 2;; esac
case "$port" in ''|*[!0-9]*) echo "shimpz-publish: port must be numeric" >&2; exit 2;; esac
case "$api" in *[!0-9]*) echo "shimpz-publish: api port must be numeric" >&2; exit 2;; esac
case "$ws" in *[!0-9]*) echo "shimpz-publish: ws port must be numeric" >&2; exit 2;; esac
case "$scope" in public|private) : ;; *) echo "shimpz-publish: scope must be public|private" >&2; exit 2;; esac
# EXPOSURE GATE (Round 128): the ONLY publishable surfaces are a project's FRONT (web slot) and
# that project's own backend/ws riding BEHIND the front (/api, /ws proxies on the same fqdn —
# single public origin per product: no CORS, one Access policy, minimal edge surface). An
# `internal` service (registry manifest internal=true — the microservice plane) must never be
# reachable from the edge on ANY slot; consume it via shimpzbus.call/topics instead. Runs BEFORE any
# Cloudflare mutation, so a refusal has zero side effects to roll back.
_REG="${SHIMPZ_REGISTRY:-/config/workspace/registry}"
_gate_exposure(){  # $1=port $2=slot(web|api|ws)
  local p="$1" slot="$2" name mf
  [ -n "$p" ] || return 0
  name=$(_driver_app_for_port "$p") || true
  [ -n "$name" ] || return 0        # nothing on the port yet → later steps fail loudly on their own
  mf="$_REG/$name.json"
  if [ -f "$mf" ] && jq -e '.internal == true' "$mf" >/dev/null 2>&1; then
    echo "shimpz-publish: REFUSED — '$name' (port $p) is an INTERNAL service (registry internal=true)." >&2
    echo "  Internal microservices are never exposed on a domain; other services consume them via" >&2
    echo "  shimpzbus.call('$name', ...) or their topics." >&2
    exit 2
  fi
  if [ "$slot" = web ]; then
    case "$name" in *-backend|*-ws)
      echo "shimpz-publish: REFUSED — '$name' is a role container and cannot BE the public web target." >&2
      echo "  Publish the project's FRONT and ride this behind it on the same domain:" >&2
      echo "    shimpz-publish <fqdn> <web-port> [public|private] <api-port> [ws-port]" >&2
      exit 2 ;;
    esac
  fi
}
_gate_exposure "$port" web
_gate_exposure "$api" api
_gate_exposure "$ws" ws

# GRANT SCOPE GATE: an app whose shimpz.app.toml DECLARES [grants].publish/dns is PINNED to its own
# <project>.grid.shimpz.com — refuse any other fqdn (it can't publish itself elsewhere or hijack another
# app's subdomain). Apps that declare NEITHER keep the owner-driven behavior (publish to any domain). The
# pinned fqdn comes from `shimpz-manifest` (Python owns the grid convention — no bash hardcode). Runs BEFORE
# any Cloudflare mutation, so a refusal has zero side effects. The grant is the PROJECT's (its web tier).
_gate_publish_scope(){  # $1=fqdn  $2=web-port
  local fqdn="$1" p="$2" app proot project dir pinned
  [ -n "$p" ] || return 0
  app=$(_driver_app_for_port "$p") || return 0
  [ -n "$app" ] || return 0
  project="$app"
  case "$app" in *-backend) project="${app%-backend}" ;; *-ws) project="${app%-ws}" ;; esac
  proot="${SHIMPZ_PROJECTS_DIR:-/config/workspace/projects}"; dir="$proot/$project"
  [ -f "$dir/shimpz.app.toml" ] || return 0                 # no manifest → no grant to enforce
  pinned=$(shimpz-manifest show "$dir" 2>/dev/null | jq -r '.publish_domain // ""')
  [ -n "$pinned" ] || return 0                           # app didn't request publish/dns → not governed
  if [ "$fqdn" != "$pinned" ]; then
    echo "shimpz-publish: REFUSED — '$project' holds a scoped publish/dns grant, so it may ONLY be published at" >&2
    echo "  its own $pinned (requested: $fqdn). A granted app can't publish elsewhere or hijack another" >&2
    echo "  app's subdomain. Publish it at $pinned, or drop [grants].publish/dns from its shimpz.app.toml." >&2
    exit 2
  fi
}
_gate_publish_scope "$fqdn" "$port"

ok(){ printf '  \033[32mOK\033[0m  %s\n' "$1"; }
no(){ printf '  \033[31mFAIL\033[0m %s\n' "$1"; }

# WAIVER FILE (SECURITY_ENGINEERING_PLAN.md item 6): a gate that couldn't run must ABORT a PUBLIC
# publish — UNLESS the project's own repo carries an explicit, versioned waiver for that exact
# gate (reviewable in that project's `git log`, not a throwaway flag). JSON, not YAML: this
# repo's tooling is jq-based everywhere already — no new parser dependency for one small file.
_WAIVER_FILE=".shimpz-waivers.json"
_waived(){  # $1=root $2=gate  → 0 if an unexpired waiver exists for this gate, 1 otherwise
  local root="$1" gate="$2" now
  local f="$root/$_WAIVER_FILE"
  [ -f "$f" ] || return 1
  now=$(date -u +%Y-%m-%d)
  jq -e --arg g "$gate" --arg now "$now" \
    'any(.[]?; .gate == $g and ((.expires == null) or (.expires >= $now)))' "$f" >/dev/null 2>&1
}
_waiver_hint(){  # $1=root $2=gate
  cat >&2 <<EOF
  No waiver on file for gate '$2' in $1/$_WAIVER_FILE — add one and commit it (in that project's
  own repo) to un-block a PUBLIC publish:
    [{"gate": "$2", "reason": "<why this is OK>", "approved_by": "<you>", "expires": null}]
  (or, better: fix the tool so the gate can actually run.)
EOF
}
echo "▶ shimpz-publish $fqdn → app on port $port ($scope)"

# 0) SECURITY JUDGMENT GATE — before exposing a PUBLIC backend to the internet, an Opus auditor
#    (shimpz-secaudit) threat-models it for BOLA/IDOR, unauthenticated private data, injection, etc.
#    Runs ONLY for a public API (private = Access-guarded; static = no backend). R132: a non-SAFE
#    verdict BLOCKS the publish with the auditor's fix so Shimpz auto-corrects — it never asks Juliano to
#    rubber-stamp an internet-facing vuln; a genuine accepted-risk exposure is a committed, reviewable
#    .shimpz-waivers.json. Runs step 0 on purpose: nothing (ingress/DNS/route/Access) has changed yet.
_secdir(){  # port -> the app's source directory (empty if no app container owns that port).
            # Resolves via shimpz-driver's port index (shimpz-brain has no local supervisor state, and
            # no Docker access, to inspect containers directly — SECURITY_ENGINEERING_PLAN.md 1.1),
            # then app name → dir via the SAME naming convention shimpz-app/validate.py use: a bare
            # name is the project's web tier (project root); "<project>-backend"/"<project>-ws" is
            # that SAME project's backend/ subdir. NEVER guessed from which subdirs happen to exist
            # (a bare-named web app's project root routinely ALSO has its own backend/ — confirmed
            # against the real live laudoctor/laudoctor-backend apps) — a stale heuristic here once
            # silently skipped the mandatory public-internet security audit for every "-backend"/
            # "-ws" app (resolved to a nonexistent $proot/<name>, treated as "source not found").
  local pp="$1" app proot project role dir
  app=$(_driver_app_for_port "$pp") || return 0
  [ -n "$app" ] || return 0
  proot="${SHIMPZ_PROJECTS_DIR:-/config/workspace/projects}"
  project="$app"; role=""
  case "$app" in *-backend) project="${app%-backend}"; role=backend ;; *-ws) project="${app%-ws}"; role=backend ;; esac
  dir="$proot/$project"; [ -n "$role" ] && dir="$dir/$role"
  [ -d "$dir" ] && echo "$dir"
}
_secgate(){  # audit ONE backend dir (_isbackend decides — see shimpzdetect.sh); non-SAFE → BLOCK + fix
  # R132: the gate BLOCKS + explains + Shimpz FIXES; it NEVER asks Juliano to rubber-stamp an
  # internet-facing vuln (that just trains a human to approve real exposures). A non-SAFE verdict
  # ABORTS the publish printing the auditor's own fix; Shimpz corrects and re-publishes (re-publish
  # re-audits, so it can't go public unless genuinely fixed). A GENUINE accepted-risk exposure (a
  # false positive, or a deliberately-public surface the auditor misjudges) is a COMMITTED,
  # reviewable `.shimpz-waivers.json` (gate "secaudit") in the project's OWN repo — an audit trail in
  # git, not a throwaway Telegram tap. Same waiver mechanism the sveltecheck/stdcheck/depaudit gates use.
  local d="$1" root audit arc
  root=$(_projroot "$d")
  echo "▶ security audit of $d (public) …"
  audit=$(shimpz-secaudit "$d"); arc=$?
  [ "$arc" -eq 0 ] && { ok "security audit: SAFE ($d)"; return 0; }
  if _waived "$root" secaudit; then
    ok "security audit non-SAFE but WAIVED for '$d' (committed .shimpz-waivers.json) — exposing on the owner's recorded, reviewable acceptance"
    return 0
  fi
  no "publish ABORTED by the security gate — a REAL exposure about to go PUBLIC, NOT a decision to approve:"
  printf '%s\n' "$audit" >&2
  echo "  FIX the vulnerability above (the auditor gave the exact fix), then re-publish — the re-publish re-audits." >&2
  _waiver_hint "$root" secaudit >&2
  exit 1
}
if [ "$scope" = public ]; then
  # Audit EVERY routed port that is a backend — the single/web port ($port), the api port ($api) AND
  # the ws gateway port ($ws): the gateway is a real Python server on the public internet, exactly as
  # auditable as the API. The default form `shimpz-publish <fqdn> <port> public` exposes whatever is on
  # $port, so $port can be a backend; a static front (no .py) is skipped. An explicitly-declared
  # api/ws port that resolves to nothing is suspicious → ask. Runs at step 0: nothing is exposed yet.
  for p in "$port" ${api:+"$api"} ${ws:+"$ws"}; do
    d=$(_secdir "$p")
    if [ -z "$d" ] || [ ! -d "$d" ]; then
      # SYMMETRIC fail-safe: ANY public port with no supervised app (web OR api) can't be audited and
      # can't be assumed static — a live backend on an unregistered port would otherwise ship unaudited
      # AND unannounced. Ask before exposing it; deny aborts. (A shimpz-app-deployed static front resolves
      # to its dir and is skipped below, so this only fires on a genuinely unknown port.)
      if shimpz-approve "I can't locate the source for PUBLIC port $p of $fqdn (not a shimpz-app deploy?), so I can't security-audit it before exposing it to the internet. Publish anyway?"; then
        ok "owner approved publishing port $p without a security audit (source not found)"
      else
        no "publish ABORTED — source for public port $p not found and not approved; nothing exposed"; exit 1
      fi
      continue
    fi
    _isbackend "$d" && _secgate "$d"
  done
fi

# 0.5) DEPENDENCY AUDIT (item 2) — before shipping, surface ACTIONABLE security vulns (severity + a fix
#      available) so the AGENT bumps them and re-publishes. NOT a shimpz-approve decision and NOT cosmetic:
#      shimpz-depaudit reports only fixable security vulns (exit 3 → ABORT here with the fix commands) and
#      FAILS OPEN on a tool error (exit 0, surfaced to stderr) so a hiccup never wedges a publish while
#      you're driving. Runs for BOTH scopes (vulnerable deps are bad behind Access too). Still step 0-ish:
#      nothing is exposed yet, so an abort ships nothing. SHIMPZ_DEPAUDIT=0 kill-switches it (shimpz-depaudit).

# FRONTEND TYPE GATE (R90): the web tier had NO deterministic gate at all — a type-broken SvelteKit
# front (vite builds it anyway; vite does not typecheck) went live silently. Pre-live, run the
# project's own `check` script (svelte-kit sync && svelte-check) — errors ABORT the publish; missing
# tooling (no pnpm / dep not installed) fails OPEN, surfaced + owner-noted. SHIMPZ_SVELTECHECK=0 skips.
_sveltecheck(){  # $1=project root
  local sc dir out
  sc=$(find "$1" \( -name node_modules -o -name .git -o -name build -o -name .svelte-kit \) -prune -o \
       -name 'svelte.config.*' -print -quit 2>/dev/null)
  [ -n "$sc" ] || return 0                       # no SvelteKit front → nothing to typecheck
  dir=$(dirname "$sc")
  if [ "${SHIMPZ_SVELTECHECK:-1}" = 0 ]; then
    _owner_note "⚠️ SHIMPZ_SVELTECHECK=0 — frontend type gate SKIPPED for $dir ($fqdn)"; return 0
  fi
  if ! (cd "$dir" && command -v pnpm >/dev/null 2>&1 \
        && grep -q '"check"' package.json 2>/dev/null \
        && pnpm exec svelte-check --version >/dev/null 2>&1); then
    if [ "$scope" = public ] && ! _waived "$1" sveltecheck; then
      no "publish ABORTED — svelte-check tooling unavailable in $dir and no waiver on file (public scope is fail-closed):"
      _waiver_hint "$1" sveltecheck
      exit 1
    fi
    no "svelte-check tooling unavailable in $dir — proceeding WITHOUT the frontend type gate (surfaced$([ "$scope" = public ] && echo ', WAIVED'))"
    _owner_note "⚠️ publish gate degraded: svelte-check unavailable for $dir — $fqdn published WITHOUT the frontend type gate"
    return 0
  fi
  echo "▶ svelte-check of $dir (pre-live) …"
  if out=$(cd "$dir" && pnpm run --silent check 2>&1); then
    ok "svelte-check clean ($dir)"
  else
    no "publish ABORTED — svelte-check found errors in $dir (they would go live):"
    echo "$out" | tail -30 | sed 's/^/  /'
    exit 1
  fi
}
seen_roots=""
for p in "$port" ${api:+$api} ${ws:+$ws}; do
  d=$(_secdir "$p"); [ -n "$d" ] && [ -d "$d" ] || continue
  root=$(_projroot "$d")
  case " $seen_roots " in *" $root "*) continue ;; esac        # audit each project root once
  seen_roots="$seen_roots $root"
  # Deterministic ecosystem standards must hold before ANYTHING goes live (both scopes) — the
  # Stop-hook gate fires only at end of turn, potentially after this publish already exposed it.
  if command -v shimpz-stdcheck >/dev/null 2>&1; then
    echo "▶ ecosystem-standard check of $root (pre-live) …"
    scout=$(shimpz-stdcheck "$root"); src=$?
    if [ "$src" -eq 2 ]; then
      no "publish ABORTED — hard standard violations in $root (they would go live):"
      echo "$scout" | sed 's/^/  /'
      exit 1
    elif [ "$src" -ne 0 ]; then
      if [ "$scope" = public ] && ! _waived "$root" stdcheck; then
        no "publish ABORTED — stdcheck could not run for $root (exit $src) and no waiver on file (public scope is fail-closed):"
        _waiver_hint "$root" stdcheck
        exit 1
      fi
      no "stdcheck could not run for $root (exit $src) — proceeding (surfaced, fail-open$([ "$scope" = public ] && echo ', WAIVED'))"
      _owner_note "⚠️ publish gate degraded: stdcheck could not run for $root (exit $src) — $fqdn published WITHOUT the standards check"
    else
      ok "standards clean ($root)"
    fi
  fi
  _sveltecheck "$root"    # frontend type gate: svelte-check errors must not go live (R90)
  echo "▶ dependency audit of $root …"
  out=$(shimpz-depaudit "$root"); drc=$?
  if [ "$drc" -eq 3 ]; then
    no "publish ABORTED — fixable security vulns in dependencies; fix them and re-run shimpz-publish:"
    echo "$out" | sed 's/^/  /'
    exit 1
  elif [ "$drc" -ne 0 ]; then
    # exit 1/64 = an INFRA/usage error (bad dir, tool wrapper), NOT a vuln. shimpz-depaudit's contract is
    # fail-open for PRIVATE (a hiccup must never wedge a private publish) but fail-CLOSED for PUBLIC
    # unless waived (SECURITY_ENGINEERING_PLAN.md item 6) — under a banner distinct from the vuln one
    # (an infra error must never be mislabeled a dependency vulnerability).
    if [ "$scope" = public ] && ! _waived "$root" depaudit; then
      no "publish ABORTED — dependency audit could not run for $root (exit $drc) and no waiver on file (public scope is fail-closed):"
      _waiver_hint "$root" depaudit
      if [ -n "$out" ]; then echo "$out" | sed 's/^/  /' >&2; fi
      exit 1
    fi
    no "dependency audit could not run for $root (exit $drc) — proceeding WITHOUT it (surfaced, not blocking$([ "$scope" = public ] && echo ', WAIVED'))"
    _owner_note "⚠️ publish gate degraded: dependency audit could not run for $root (exit $drc) — $fqdn published WITHOUT it"
    if [ -n "$out" ]; then echo "$out" | sed 's/^/  /'; fi
  else
    # NOTE: `[ -n "$out" ] && echo ...` as a bare statement is a `set -e` landmine (a false test
    # is itself a non-zero exit status, which — unlike inside an if/while condition — aborts the
    # whole script here) — an explicit `if` avoids a hiccup-free depaudit with empty output
    # silently killing the rest of this loop/the whole publish.
    if [ -n "$out" ]; then echo "$out" | sed 's/^/  /'; fi
  fi
done

# 1) resolve zone (longest zone name that is a suffix of fqdn — handles .com.br etc.) — server-side
#    in cf-driver now (validate.py::longest_matching_zone); _cfdriver_zone_for is a thin client.
zone=$(_cfdriver_zone_for "$fqdn") || { no "no Cloudflare zone matches $fqdn"; exit 1; }
best="${zone% *}"; zid="${zone##* }"
sub="@"; [ "$fqdn" != "$best" ] && sub="${fqdn%.$best}"
ok "zone $best ($zid), record name '$sub'"

# 2) active tunnel id
tid=$(_cfdriver_tunnel_id) || { no "no active cfd tunnel"; exit 1; }
[ -n "$tid" ] || { no "no active cfd tunnel"; exit 1; }
ok "tunnel $tid"

# TRANSACTIONAL PUBLISH (SECURITY_ENGINEERING_PLAN.md item 4): steps 3–6 mutate 4 independent
# Cloudflare-side systems (tunnel ingress, DNS, Caddy route, Access) plus a final local health
# check. Every step below records what it actually changed; `_rollback_all` undoes exactly those
# changes, in reverse order, on ANY later failure — so a failed publish leaves the domain in
# whichever state existed BEFORE this run started, never a new broken half-state. Rollback for
# route is "remove what THIS run added" (shimpz-route has no per-host snapshot/restore primitive);
# ingress/DNS/Access are all precise restores now — cf-driver's own endpoints (item 3) hand
# back exactly what a rollback needs (previous_service/previous_content/the full removed Access app
# body), so this script never has to snapshot or reconstruct Cloudflare's raw JSON itself anymore.
_did_ingress=0; _ingress_previous_service=""
_did_dns=0; _dns_existed=0; _dns_old_content=""
_did_route=0
_did_access=0; _access_created=0; _access_snap="[]"

_rollback_all(){
  echo "▶ rolling back this publish attempt (a later step failed — undoing what THIS run changed) …" >&2
  if [ "$_did_access" = 1 ]; then
    if [ "$_access_created" = 1 ]; then
      _cfdriver_access_public "$fqdn" >/dev/null 2>&1   # undo: remove the private app we just created
    else
      echo "$_access_snap" | jq -c '.[]?' | while IFS= read -r app; do
        [ -n "$app" ] || continue
        _cfdriver_access_restore "$app" >/dev/null 2>&1   # undo: recreate what we removed, verbatim
      done
    fi
  fi
  if [ "$_did_route" = 1 ]; then
    shimpz-route del "$fqdn" >/dev/null 2>&1 || true
  fi
  if [ "$_did_dns" = 1 ]; then
    if [ "$_dns_existed" = 1 ]; then
      _cfdriver_dns_upsert "$fqdn" CNAME "$_dns_old_content" >/dev/null 2>&1   # restore old content
    else
      _cfdriver_dns_delete "$fqdn" CNAME >/dev/null 2>&1   # undo: delete the record we just created
    fi
  fi
  if [ "$_did_ingress" = 1 ]; then
    if [ -n "$_ingress_previous_service" ]; then
      _cfdriver_ingress_upsert "$fqdn" "$_ingress_previous_service" >/dev/null 2>&1   # restore old rule
    else
      _cfdriver_ingress_delete "$fqdn" >/dev/null 2>&1   # undo: remove the rule we just added
    fi
  fi
  echo "  rollback attempted for every step this run touched — fix the underlying issue and re-run shimpz-publish" >&2
}

# 3) tunnel ingress rule — cf-driver does the ENTIRE read-modify-write server-side (preserve
#    every other hostname's rule, replace/add only this one, preserve the catch-all): shimpz-brain never
#    sees or manipulates the full ingress config at all anymore (SECURITY_ENGINEERING_PLAN.md item 3).
if out=$(_cfdriver_ingress_upsert "$fqdn" "http://shimpz-caddy:8080"); then
  _did_ingress=1
  _ingress_previous_service=$(echo "$out" | jq -r '.previous_service // empty')
  ok "tunnel ingress updated ($fqdn → http://shimpz-caddy:8080; $(echo "$out" | jq -r '.rule_count') hostname rule(s) total)"
else
  no "tunnel ingress update FAILED — aborting (nothing touched yet this run): $out"
  exit 1
fi

# 4) proxied DNS record (CNAME → <tunnel>.cfargotunnel.com). THIS needs DNS:Edit.
content="$tid.cfargotunnel.com"
if out=$(_cfdriver_dns_upsert "$fqdn" CNAME "$content"); then
  _did_dns=1
  if [ "$(echo "$out" | jq -r '.created')" = "false" ]; then
    _dns_existed=1; _dns_old_content=$(echo "$out" | jq -r '.previous_content')
  fi
  ok "DNS $fqdn → $content (proxied)"
else
  no "DNS record FAILED — rolling back and aborting: $out  ← token needs Zone:DNS:Edit"
  _rollback_all
  exit 1
fi

# 5) Caddy route (hostname → the app container that owns each port; /api and the /ws websocket
#    ride the same fqdn, commonly proxying to a DIFFERENT app container than the web port)
if route_out=$(shimpz-route add "$fqdn" "$port" "${api:-}" "${ws:-}" 2>&1); then
  _did_route=1
  ok "$route_out"
else
  no "Caddy route FAILED — rolling back and aborting: $route_out"
  _rollback_all
  exit 1
fi

# 6) Access: public = remove any Access app guarding it; private = create one WITH an allow-policy
#    for the owner. An Access app with NO policy denies EVERYONE (including you) — so a private
#    deploy must ship the policy, not just the app (cf-driver's /v1/access/private endpoint
#    builds that policy server-side). Owner from env (same resolution Shimpz uses elsewhere).
owner="${TELEGRAM_OWNER_EMAIL:-${ACCESS_EMAIL:-ceo@roxygens.com}}"
if [ "$scope" = private ]; then
  if out=$(_cfdriver_access_private "$fqdn" "$owner"); then
    [ "$(echo "$out" | jq -r '.created')" = "true" ] && _did_access=1 && _access_created=1
    ok "Access: PRIVATE (allow-policy for $owner; identity + one-time PIN)"
  else
    no "Access app creation FAILED — rolling back and aborting: $out"
    _rollback_all
    exit 1
  fi
else
  if out=$(_cfdriver_access_public "$fqdn"); then
    removed_json=$(echo "$out" | jq -c '.removed')
    if [ "$(echo "$removed_json" | jq 'length')" -gt 0 ]; then
      _did_access=1; _access_created=0; _access_snap="$removed_json"
    fi
    ok "Access: PUBLIC (no Access app)"
  else
    no "Access app removal FAILED — rolling back and aborting: $out"
    _rollback_all
    exit 1
  fi
fi

# 7) FINAL HEALTH GATE (SECURITY_ENGINEERING_PLAN.md item 4: the final HTTP check must be a real
#    gate, not merely informative) — everything above reported success, but the only proof the
#    domain actually WORKS is a real request through the exact path a visitor's request takes: THIS
#    Caddy instance, with the Host header a browser would send. A connection failure or 5xx here
#    means the publish is BROKEN despite every individual step succeeding (e.g. Caddy reloaded but
#    the upstream app container isn't actually listening) — roll back and report failure instead of
#    printing "Done" on a domain that doesn't work.
echo "── final health gate: curl -H 'Host: $fqdn' http://shimpz-caddy:8080/"
code=$(curl -sS -H "Host: $fqdn" http://shimpz-caddy:8080/ -o /dev/null -w '%{http_code}' --max-time 8 2>/dev/null || echo "ERR")
case "$code" in
  ERR|000|5??)
    no "final health gate FAILED (HTTP $code through shimpz-caddy) — rolling back and aborting"
    _rollback_all
    exit 1
    ;;
  *)
    ok "final health gate: HTTP $code through shimpz-caddy"
    ;;
esac
echo "Done. Public URL (once DNS resolves): https://$fqdn"
