#!/usr/bin/env bash
# shimpz-route — app hostname→container routing via shimpz-driver (SECURITY_ENGINEERING_PLAN.md
# section 4). Caddy runs in its OWN container (shimpz-caddy), joined to app_net so it can reach
# app_<name> containers by name — `shimpz-brain` is never on that network and never touches Caddy's admin
# API directly; shimpz-driver applies the templated route and reloads Caddy via `docker exec`
# (see drivers/apps/caddy_routes.py). This script resolves each port to its owning app via the
# driver's port index (shimpz-brain has no Docker access of its own to inspect containers directly).
#
#   shimpz-route add <fqdn> <web-port> [api-port] [ws-port]
#       route http://<fqdn> → the app container that owns <web-port>; fullstack: /api/* → the app
#       that owns <api-port> (strip /api), /ws → the app that owns <ws-port> (proxies upgrades
#       natively) — web/api/ws are commonly THREE DIFFERENT app containers. Pass api as "" for
#       web+ws with no api.
#   shimpz-route del <fqdn>     drop the route, reload
#   shimpz-route list           list mapped domains
#
# The old `add-legacy` (migration bridge routing straight to `shimpz-brain`'s own supervisord apps) was
# removed once the live migration confirmed no route depended on it (SECURITY_ENGINEERING_PLAN.md
# item 4) — a route to `shimpz-brain` would be a public-hostname path into the one container holding the
# whole credential keyring. Routes now go ONLY to driver-managed `app_<name>` containers.
set -euo pipefail
. "${SHIMPZ_LIB:-/opt/shimpz-lib}/shimpzdriver.sh"

# SECURITY: fqdn/port/api/ws feed the driver's Caddyfile template. Validate here BEFORE any
# network round-trip — fail fast on garbage input, and defense-in-depth alongside the driver's
# OWN server-side re-validation (validate.py), the same two-layer pattern shimpz-app/shimpz-publish use.
_valid_fqdn(){ case "$1" in *[!A-Za-z0-9.-]*|'') echo "shimpz-route: fqdn must be [A-Za-z0-9.-]" >&2; exit 2;; esac; }
_valid_port_opt(){ case "$1" in ''|*[!0-9]*) [ -z "$1" ] || { echo "shimpz-route: ${2:-port} must be numeric" >&2; exit 2; };; esac; }

_app_target_for_port(){  # $1=port → prints "app_<name>", fails loudly if no app owns it
  local port="$1" app
  app=$(_driver_app_for_port "$port")
  if [ -z "$app" ]; then
    echo "shimpz-route: no app container owns port $port (deploy it first: shimpz-app deploy <name> $port -- ...)" >&2
    return 1
  fi
  echo "app_$app"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  add)
    fqdn="${1:?usage: shimpz-route add <fqdn> <web-port> [api-port] [ws-port]}"
    web="${2:?need <web-port>}"; api="${3:-}"; ws="${4:-}"
    _valid_fqdn "$fqdn"
    case "$web" in ''|*[!0-9]*) echo "shimpz-route: web port must be numeric" >&2; exit 2;; esac
    _valid_port_opt "$api" "api port"; _valid_port_opt "$ws" "ws port"
    wt=$(_app_target_for_port "$web")
    at=""; [ -n "$api" ] && at=$(_app_target_for_port "$api")
    st=""; [ -n "$ws" ] && st=$(_app_target_for_port "$ws")
    _driver_route_apply "$fqdn" "$wt" "$web" "$at" "$api" "$st" "$ws" >/dev/null
    echo "→ $fqdn → web $wt:$web${api:+, /api → $at:$api}${ws:+, /ws → $st:$ws} (live)" ;;
  del)
    fqdn="${1:?need <fqdn>}"
    _driver_route_del "$fqdn" >/dev/null
    echo "removed route $fqdn" ;;
  list)
    routes=$(_driver_route_list | jq -r '.routes[]?')
    [ -n "$routes" ] && printf '%s\n' "$routes" || echo "(no routes)" ;;
  *) echo "usage: shimpz-route add|del|list ..." >&2; exit 2 ;;
esac
