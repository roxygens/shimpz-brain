#!/opt/venv/bin/python
"""shimpz-approve / shimpz-captcha — ask Juliano for a decision via Telegram buttons, and BLOCK.

  shimpz-approve "I'm going to send this LinkedIn invite to So-and-so"   → exit 0 if ✅ Approve, 1 if ❌ Deny
  shimpz-captcha "a CAPTCHA appeared on the LinkedIn login"          → exit 0 if ✅ Resolved, 1 if ❌ Cancel

How: drops a request file in $SHIMPZ_HOME/ipc; the gateway (which owns the Telegram poll) sends
the inline buttons and writes back your choice. Use `shimpz-approve` BEFORE any outward/irreversible
action; use `shimpz-captcha` when you hit a CAPTCHA or a wall only a human can pass (then re-screenshot
to verify before continuing). exit 2 = timeout / no answer.
"""

import os
import sys
from pathlib import Path

sys.path.insert(0, "/opt/shimpz-lib")
import shimpzipc  # single source of truth for the $SHIMPZ_HOME/ipc request/response protocol

kind = "captcha" if Path(sys.argv[0]).name == "shimpz-captcha" else "approve"
text = sys.argv[1] if len(sys.argv) > 1 else ("CAPTCHA" if kind == "captcha" else "action")
timeout = int(os.environ.get("SHIMPZ_ASK_TIMEOUT", "600" if kind == "captcha" else "300"))

responded, decision = shimpzipc.request({"type": kind, "text": text}, timeout, "decision")
if not responded:
    print("NO ANSWER (timeout) — do NOT proceed; ask Juliano.", file=sys.stderr)
    sys.exit(2)
if decision == "ok":
    print("APPROVED" if kind == "approve" else "RESOLVED")
    sys.exit(0)
print("DENIED" if kind == "approve" else "CANCELLED")
sys.exit(1)
