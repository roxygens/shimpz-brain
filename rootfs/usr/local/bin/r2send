#!/opt/venv/bin/python
"""r2send <file-or-folder> [expire] — upload to Cloudflare R2, print a temporary download link.

The shortcut for "send this to the cloud / give me the link". A folder is zipped first (into a
private temp dir, removed on exit) then uploaded. `expire` = link validity (default 168h = 7 days,
the S3 presign max).

SECURITY_ENGINEERING_PLAN.md item 7: the R2 credentials live in the separate `r2-driver`
container now — this streams the file bytes to its restricted API (shimpzr2), which holds the secret and
does the rclone copy + presign. The brain no longer holds the R2 key at all.
"""

from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, os.environ.get("SHIMPZ_LIB", "/opt/shimpz-lib"))
import shimpzr2  # shared r2-driver HTTP client (see /opt/shimpz-lib/shimpzr2.py)


def _human(n: int) -> str:
    size = float(n)
    for unit in ("B", "K", "M", "G"):
        if size < 1024 or unit == "G":
            return f"{size:.0f}{unit}" if unit == "B" else f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}G"


def main() -> None:
    if len(sys.argv) < 2:
        sys.exit("usage: r2send <file-or-folder> [expire, e.g. 24h]")
    src = Path(sys.argv[1])
    expire = sys.argv[2] if len(sys.argv) > 2 else "168h"
    if not src.exists():
        sys.exit(f"ERROR: does not exist: {src}")

    tmpdir = None
    try:
        if src.is_dir():
            # Zip into a FRESH private temp dir per run (never a fixed /tmp/<base>.zip): a fixed path
            # leaked on failure, let `zip -r` UPDATE a stale archive, and collided across runs.
            tmpdir = tempfile.mkdtemp()
            up = Path(tmpdir) / f"{src.name}.zip"
            subprocess.run(["zip", "-rq", str(up), src.name], cwd=str(src.parent), check=True)
        else:
            up = src

        try:
            result = shimpzr2.upload(str(up), up.name, expire)
        except shimpzr2.R2DriverError as exc:
            sys.exit(f"ERROR on upload: {exc}")
    finally:
        if tmpdir:
            subprocess.run(["rm", "-rf", tmpdir], check=False)

    print(f"OK in the cloud (R2): {result['key']}  ({_human(result['size'])})")
    print(f"Link ({expire}): {result['link']}")


if __name__ == "__main__":
    main()
