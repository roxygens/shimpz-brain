#!/usr/bin/with-contenv bash
# NOTE: openbox launches this via `sh <file>`, so the shebang is ignored and the
# body must be POSIX-sh safe (no `set -o pipefail`, no bashisms). Container env
# (TELEGRAM_BOT_TOKEN, SHIMPZ_HOME, …) is inherited from the KasmVNC service.
#
# SECURITY_ENGINEERING_PLAN.md item 0: Chrome/the desktop/XTEST/CDP moved entirely to the
# `shimpz-browser` container — this is now JUST the brain's own startup (the Shimpz gateway, plus the
# legacy Caddy/supervisord blocks below). The base image's own Xvnc/openbox/kclient still exist and
# still trigger this script (untouched — see the main Dockerfile's own note on why), but there's
# nothing left for the desktop to actually show; the gateway runs headless regardless.

SHIMPZ_HOME="${SHIMPZ_HOME:-/config/.shimpz}"
mkdir -p "$SHIMPZ_HOME" "$SHIMPZ_HOME/logs" 2>/dev/null

# Node 24 for Shimpz's code lives in /opt/node24 (NOT in the system PATH, so KasmVNC's kclient keeps
# the base Node 20 it needs — see the Dockerfile). Put it on PATH here so the Shimpz gateway and every
# command it runs (pnpm/node for SvelteKit) get Node 24. This is the openbox session only; the
# kclient s6 service has its own env and stays on the system Node.
export PATH="/opt/node24/bin:$PATH"

# --- Shimpz gateway — HEADLESS Telegram bot (voice + text) that drives the Claude Code
# brain. Launched only when a bot token is set AND the gateway is present (it's added in
# the Shimpz build phase). Logs → gateway.log. Supervised respawn so a crash self-heals.
GATEWAY="/usr/local/bin/shimpz-gateway"
if [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -x "$GATEWAY" ]; then
    ( while true; do
        ( cd "$SHIMPZ_HOME" && exec "$GATEWAY" ) >> "$SHIMPZ_HOME/logs/gateway.log" 2>&1
        sleep 3
      done ) &
fi

# --- Shimpz installer — consumes the store's 'Install' bus requests and installs the app, gated by
# your Telegram approval (the store at shimpz.com is PUBLIC, so approval is the auth). Runs only when a
# bot token is set (approval needs Telegram) AND the installer is present. Supervised respawn (self-heal).
INSTALLER="/usr/local/bin/shimpz-installer"
if [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -x "$INSTALLER" ]; then
    ( while true; do
        ( cd "$SHIMPZ_HOME" && exec "$INSTALLER" ) >> "$SHIMPZ_HOME/logs/shimpz-installer.log" 2>&1
        sleep 3
      done ) &
fi

# --- Caddy (internal reverse proxy) + supervisor (Shimpz's app process manager) ----------
# Caddy: Host header → local app port, behind the single Cloudflare Tunnel (TLS at the edge →
# plain HTTP on :8080). supervisord: keeps Shimpz's web apps (one port each) alive. Both run as
# this desktop user with persistent configs under $SHIMPZ_HOME, supervised respawn (self-heal).
if [ -x /usr/local/bin/caddy ] && [ -f "$SHIMPZ_HOME/caddy/Caddyfile" ]; then
    ( while true; do
        /usr/local/bin/caddy run --config "$SHIMPZ_HOME/caddy/Caddyfile" --adapter caddyfile \
            >> "$SHIMPZ_HOME/logs/caddy.log" 2>&1
        sleep 3
      done ) &
fi
if command -v supervisord >/dev/null 2>&1 && [ -f "$SHIMPZ_HOME/supervisor/supervisord.conf" ]; then
    ( while true; do
        supervisord -n -c "$SHIMPZ_HOME/supervisor/supervisord.conf" >/dev/null 2>&1
        sleep 3
      done ) &
fi

# openbox keeps the session/desktop alive after this script exits.
