#!/usr/bin/with-contenv bash
# shellcheck shell=bash  # s6-overlay's `with-contenv` wrapper is not a shell ShellCheck recognizes.
# Explicit s6 longrun for the platform Brain's headless gateway/installer/app supervisors. The
# inherited desktop/openbox chain is disabled in the Brain image; shimpz-browser owns it. Capsule
# Brains deliberately take the inert branch below, because Apps share their core network and must not
# gain a listening surface on the Brain. Bash is intentional for child supervision and clean shutdown.
set -euo pipefail

if [[ -n "${SHIMPZ_CAPSULE_ID:-}" ]]; then
    exec sleep infinity
fi

SHIMPZ_HOME="${SHIMPZ_HOME:-/config/.shimpz}"
mkdir -p "$SHIMPZ_HOME" "$SHIMPZ_HOME/logs" 2>/dev/null
touch "$SHIMPZ_HOME/.headless-autostart-ready"

# Node 24 for Shimpz's code lives in /opt/node24. Put it on PATH for the headless gateway and every
# command it runs (pnpm/node for SvelteKit).
export PATH="/opt/node24/bin:$PATH"

declare -a supervisors=()

supervise() {
    local workdir="$1" logfile="$2" child=""
    shift 2
    stop_child() {
        if [[ -n "$child" ]]; then
            kill "$child" 2>/dev/null || true
            wait "$child" 2>/dev/null || true
        fi
        exit 0
    }
    trap stop_child TERM INT
    while true; do
        (cd "$workdir" && exec "$@") >>"$logfile" 2>&1 &
        child=$!
        wait "$child" || true
        child=""
        sleep 3 &
        child=$!
        wait "$child" || true
        child=""
    done
}

start_supervised() {
    supervise "$@" &
    supervisors+=("$!")
}

stop_supervisors() {
    trap - TERM INT
    if ((${#supervisors[@]})); then
        kill "${supervisors[@]}" 2>/dev/null || true
        wait "${supervisors[@]}" 2>/dev/null || true
    fi
    exit 0
}

trap stop_supervisors TERM INT

# --- Shimpz gateway — HEADLESS Telegram bot (voice + text) that drives the Claude Code
# brain. Launched only when a bot token is set AND the gateway is present (it's added in
# the Shimpz build phase). Logs → gateway.log. Supervised respawn so a crash self-heals.
GATEWAY="/usr/local/bin/shimpz-gateway"
if [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -x "$GATEWAY" ]; then
    start_supervised "$SHIMPZ_HOME" "$SHIMPZ_HOME/logs/gateway.log" "$GATEWAY"
fi

# --- Shimpz installer — consumes the store's 'Install' bus requests and installs the app, gated by
# your Telegram approval (the store at shimpz.com is PUBLIC, so approval is the auth). Runs only when a
# bot token is set (approval needs Telegram) AND the installer is present. Supervised respawn (self-heal).
INSTALLER="/usr/local/bin/shimpz-installer"
if [ -n "${TELEGRAM_BOT_TOKEN:-}" ] && [ -x "$INSTALLER" ]; then
    start_supervised "$SHIMPZ_HOME" "$SHIMPZ_HOME/logs/shimpz-installer.log" "$INSTALLER"
fi

# --- Caddy (internal reverse proxy) + supervisor (Shimpz's app process manager) ----------
# Caddy: Host header → local app port, behind the single Cloudflare Tunnel (TLS at the edge →
# plain HTTP on :8080). supervisord: keeps Shimpz's web apps (one port each) alive. Both run as
# the unprivileged Brain user with persistent configs under $SHIMPZ_HOME, supervised respawn (self-heal).
if [ -x /usr/local/bin/caddy ] && [ -f "$SHIMPZ_HOME/caddy/Caddyfile" ]; then
    start_supervised "$SHIMPZ_HOME" "$SHIMPZ_HOME/logs/caddy.log" \
        /usr/local/bin/caddy run --config "$SHIMPZ_HOME/caddy/Caddyfile" --adapter caddyfile
fi
if command -v supervisord >/dev/null 2>&1 && [ -f "$SHIMPZ_HOME/supervisor/supervisord.conf" ]; then
    start_supervised "$SHIMPZ_HOME" /dev/null supervisord -n -c "$SHIMPZ_HOME/supervisor/supervisord.conf"
fi

# Keep the s6 longrun alive even on an unconfigured image. Any configured child is independently
# supervised above; s6 owns this aggregate service's lifecycle and stop propagation.
if ((${#supervisors[@]} == 0)); then
    exec sleep infinity
fi
wait "${supervisors[@]}"
